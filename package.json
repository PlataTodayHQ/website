{
  "name": "plata-today",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "preview": "npm run preview --workspace=apps/web",
    "server:start": "tsx apps/server/src/index.ts",
    "server:dev": "tsx apps/server/src/index.ts",
    "pipeline:run": "tsx apps/pipeline/src/main.ts",
    "pipeline:migrate": "tsx apps/pipeline/src/db/migrate.ts",
    "db:migrate": "tsx apps/pipeline/src/db/migrate.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p apps/pipeline/tsconfig.json && tsc --noEmit -p apps/server/tsconfig.json",
    "backfill:financials": "tsx apps/server/src/scripts/backfill-financials.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "tsx": "^4.19.0"
  }
}
