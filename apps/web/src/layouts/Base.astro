---
import "@/styles/global.css";
import { LANGUAGES, CATEGORIES, CATEGORY_LIST, SUBCATEGORIES } from "@plata-today/shared";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import BreakingNews from "@/components/BreakingNews.astro";
import MarketTicker from "@/components/MarketTicker.astro";
import { t } from "@/i18n";
import { getBreakingNews } from "@/lib/db";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  lang?: string;
  canonicalUrl?: string;
  alternateUrls?: Record<string, string>;
  activeCategory?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
  breadcrumbs?: BreadcrumbItem[];
  articleMeta?: {
    publishedTime?: string;
    modifiedTime?: string;
    section?: string;
    tags?: string[];
    author?: string;
  };
}

const {
  title,
  lang = "en",
  description = t(lang, "common.siteDescription"),
  canonicalUrl,
  alternateUrls,
  activeCategory,
  ogImage,
  ogUrl,
  ogType = "website",
  noindex = false,
  jsonLd,
  breadcrumbs,
  articleMeta,
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? "https://plata.today";
// Normalize: strip trailing slash (keep for / and /{lang}/ roots)
const rawPath = Astro.url.pathname;
const currentPath = rawPath === '/' || /^\/[a-z]{2}\/$/.test(rawPath)
  ? rawPath
  : rawPath.replace(/\/$/, '');
const fullTitle = `${title} | Plata`;
const resolvedCanonical = canonicalUrl ?? `${siteUrl}${currentPath}`;
const resolvedOgUrl = ogUrl ?? resolvedCanonical;

// Generate hreflang for all languages if not explicitly provided
const resolvedAlternates = alternateUrls ?? Object.fromEntries(
  Object.keys(LANGUAGES).map((code) => [
    code,
    `${siteUrl}${currentPath.replace(`/${lang}/`, `/${code}/`)}`,
  ])
);

// Language CTA map for browser language detection
const langCtaMap = JSON.stringify(
  Object.fromEntries(
    Object.entries(LANGUAGES).map(([code, info]) => [
      code,
      { flag: info.flag, label: `${info.flag} ${t(code, "langCta.readIn").replace("{lang}", info.nativeName)}` }
    ])
  )
);

// OG locale mapping (BCP47 → OG format)
const OG_LOCALE: Record<string, string> = {
  en: "en_US", pt: "pt_BR", de: "de_DE", it: "it_IT", fr: "fr_FR",
  ru: "ru_RU", zh: "zh_CN", pl: "pl_PL", uk: "uk_UA", ja: "ja_JP",
  ko: "ko_KR", es: "es_AR", sv: "sv_SE", da: "da_DK", nl: "nl_NL",
  no: "nb_NO", fi: "fi_FI", hi: "hi_IN",
};
const ogLocale = OG_LOCALE[lang] ?? lang;

const breakingArticle = getBreakingNews(lang);

const navItems = [
  { label: t(lang, "nav.home"), href: `/${lang}/` },
  { label: t(lang, "nav.feed" as any), href: `/${lang}/feed` },
  ...CATEGORY_LIST.map((key) => ({
    label: t(lang, `cat.${key}` as any),
    href: `/${lang}/category/${key}`,
  })),
];

// Build breadcrumb JSON-LD
const breadcrumbJsonLd = breadcrumbs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((item, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: item.name,
        item: item.url.startsWith("http") ? item.url : `${siteUrl}${item.url}`,
      })),
    }
  : null;

// Collect all JSON-LD blocks
const allJsonLd = [
  breadcrumbJsonLd,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
].filter(Boolean);
---

<!doctype html>
<html lang={lang} data-lang-map={langCtaMap}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="theme-color" content="#112e51" />
    <meta name="color-scheme" content="light dark" />

    <!-- Web fonts: Libre Caslon Display (logo) + Source Serif 4 (headings) + Inter (UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Libre+Caslon+Display&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;0,8..60,800;1,8..60,400;1,8..60,600&display=swap" rel="stylesheet" />

    {!noindex && <link rel="canonical" href={resolvedCanonical} />}
    <link rel="alternate" type="application/rss+xml" title="Plata News" href={`${siteUrl}/rss.xml`} />

    {!noindex && Object.entries(resolvedAlternates).map(([hrefLang, url]) => (
      <link rel="alternate" hreflang={hrefLang} href={url} />
    ))}
    {!noindex && <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:site_name" content="Plata" />
    <meta property="og:locale" content={ogLocale} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Article-specific OG tags -->
    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {articleMeta?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- JSON-LD Structured Data -->
    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- Google Analytics (GA4) with Consent Mode v2 -->
    {import.meta.env.PUBLIC_GA_ID && (
      <script is:inline async data-cfasync="false" src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
    )}
    {import.meta.env.PUBLIC_GA_ID && (
      <script is:inline data-cfasync="false" define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
        window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
        gtag('consent','default',{'analytics_storage':'granted','ad_storage':'denied','ad_user_data':'denied','ad_personalization':'denied'});
        gtag('js',new Date());
        gtag('config',gaId,{'send_page_view':true});
      </script>
    )}

    <!-- Blocking theme script — prevents flash of wrong theme -->
    <script is:inline>
      (function(){var t=localStorage.getItem('plata-theme');if(t==='dark'||t==='light')document.documentElement.setAttribute('data-theme',t)})();
    </script>
  </head>
  <body>
    <!-- Skip to content — accessibility -->
    <a href="#main-content" class="skip-link">{t(lang, "nav.skipToContent")}</a>

    {breakingArticle && (
      <BreakingNews
        headline={breakingArticle.title}
        href={`/${lang}/news/${breakingArticle.slug}`}
        isLive={true}
        lang={lang}
      />
    )}

    <header class="header" role="banner">
      <!-- Top bar: brand + actions -->
      <!-- Utility bar: date + actions -->
      <div class="utility-bar">
        <div class="utility-inner">
          <time class="utility-date" datetime={new Date().toISOString().slice(0, 10)}>
            {new Date().toLocaleDateString(lang, { weekday: "long", year: "numeric", month: "long", day: "numeric" })}
          </time>
          <div class="utility-actions">
            <button class="header-icon-btn" aria-label={t(lang, "nav.search")} aria-expanded="false" aria-controls="search-overlay" data-search-trigger>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
            <button class="header-icon-btn" aria-label={t(lang, "theme.toDark")} data-theme-toggle data-label-light={t(lang, "theme.toLight")} data-label-dark={t(lang, "theme.toDark")} data-label-system={t(lang, "theme.toSystem")}>
              <svg class="theme-icon theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              <svg class="theme-icon theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <LanguageSwitcher lang={lang} />
          </div>
        </div>
      </div>
      <!-- Masthead: NYT-style centered logo -->
      <div class="masthead">
        <div class="masthead-inner">
          <button
            class="menu-btn"
            aria-label={t(lang, "nav.openMenu")}
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <a href={`/${lang}/`} class="logo" aria-label="Plata — Home">
            <span class="logo-text">Plata</span>
          </a>
        </div>
      </div>
      <!-- Nav bar: categories -->
      <nav class="nav-bar" aria-label="Main navigation">
        <div class="nav-inner">
          {navItems.map((item) => {
            const isActive = currentPath === item.href ||
              (item.href.includes('/category/') && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={["nav-link", { active: isActive }]}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })}
        </div>
      </nav>
    </header>

    <MarketTicker lang={lang} />

    <!-- Mobile menu overlay -->
    <div
      class="mobile-overlay"
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
      hidden
    >
      <div class="overlay-header">
        <span class="overlay-title" id="mobile-menu-title">{t(lang, "nav.menu")}</span>
        <button class="overlay-close" aria-label={t(lang, "nav.closeMenu")}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <nav class="overlay-nav" aria-label="Mobile navigation">
        {navItems.map((item) => {
          const isActive = currentPath === item.href ||
            (item.href.includes('/category/') && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={["overlay-nav-link", { active: isActive }]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- Mobile language overlay -->
    <div
      class="mobile-overlay"
      id="mobile-langs"
      role="dialog"
      aria-modal="true"
      aria-label="Language selection"
      hidden
    >
      <div class="overlay-header">
        <span class="overlay-title" id="mobile-langs-title">{t(lang, "nav.language")}</span>
        <button class="overlay-close" aria-label={t(lang, "nav.closeLangPicker")}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div class="overlay-langs" role="list" aria-label="Available languages">
        {Object.entries(LANGUAGES).map(([code, info]) => (
          <a
            href={`/${code}/`}
            class:list={["overlay-lang-option", { active: code === lang }]}
            role="listitem"
            lang={code}
            aria-current={code === lang ? "true" : undefined}
          >
            <span class="overlay-lang-flag" aria-hidden="true">{info.flag}</span>
            <span class="overlay-lang-name">{info.nativeName}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Search overlay -->
    <div
      class="mobile-overlay"
      id="search-overlay"
      role="dialog"
      aria-modal="true"
      aria-label={t(lang, "nav.search")}
      hidden
    >
      <div class="overlay-header">
        <span class="overlay-title">{t(lang, "nav.search")}</span>
        <button class="overlay-close" aria-label={t(lang, "nav.closeSearch")}>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div class="search-body">
        <div class="search-input-wrap">
          <svg class="search-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input type="search" class="search-input" placeholder={t(lang, "search.placeholder")} autocomplete="off" aria-label={t(lang, "search.label")} />
        </div>
        <p class="search-placeholder-text">{t(lang, "search.comingSoon")}</p>
      </div>
    </div>

    <!-- Pull to refresh indicator -->
    <div class="ptr" id="ptr" aria-hidden="true">
      <div class="ptr-spinner">
        <svg class="ptr-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 4V1L8 5l4 4V6a6 6 0 11-6 6H4a8 8 0 108-8z" fill="currentColor"/>
        </svg>
      </div>
    </div>

    <main class="main" id="main-content" role="main">
      <div class="main-inner">
        <slot />
      </div>
    </main>

    <footer class="footer" role="contentinfo">
      <div class="footer-inner">
        <!-- Logo + tagline -->
        <div class="footer-brand">
          <div class="footer-brand-row">
            <a href={`/${lang}/`} class="footer-logo" aria-label="Plata — Home">Plata</a>
            <span class="footer-est">Est. 2025</span>
          </div>
          <p class="footer-tagline">{t(lang, "footer.tagline")}</p>
        </div>

        <!-- Categories + subcategories -->
        <nav class="footer-cats" aria-label={t(lang, "footer.categories")}>
          {Object.entries(CATEGORIES).map(([catKey, _catLabel]) => (
            <div class="footer-cat-group">
              <a href={`/${lang}/category/${catKey}`} class="footer-cat-title">{t(lang, `cat.${catKey}` as any)}</a>
              <ul class="footer-sub-list">
                {Object.entries(SUBCATEGORIES[catKey as keyof typeof SUBCATEGORIES]).map(([subKey, _subLabel]) => (
                  <li>
                    <a href={`/${lang}/category/${catKey}`} class="footer-sub-link">{t(lang, `sub.${subKey}` as any)}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>

        <div class="footer-divider" role="separator"></div>

        <!-- Utility links -->
        <nav class="footer-util" aria-label="Utility links">
          <a href={`/${lang}/about`}>{t(lang, "footer.about")}</a>
          <a href={`/${lang}/about#contact`}>{t(lang, "footer.contact")}</a>
          <a href={`/${lang}/terms`}>{t(lang, "footer.terms")}</a>
          <a href={`/${lang}/privacy`}>{t(lang, "footer.privacy")}</a>
        </nav>

        <div class="footer-divider" role="separator"></div>

        <!-- Newsletter -->
        <div class="footer-newsletter">
          <p class="footer-newsletter-title">{t(lang, "footer.newsletterTitle")}</p>
          <form class="footer-newsletter-form" data-newsletter-form aria-label={t(lang, "newsletter.ariaLabel")}>
            <label for="footer-email" class="sr-only">{t(lang, "newsletter.emailLabel")}</label>
            <input type="email" id="footer-email" class="footer-newsletter-input" placeholder={t(lang, "newsletter.placeholder")} required autocomplete="email" />
            <button type="submit" class="footer-newsletter-btn">{t(lang, "newsletter.subscribe")}</button>
            <p class="footer-newsletter-success" hidden>{t(lang, "newsletter.success")}</p>
          </form>
        </div>

        <div class="footer-divider" role="separator"></div>

        <!-- Languages grid -->
        <div class="footer-langs">
          <p class="footer-langs-title" id="footer-langs-heading">{t(lang, "footer.otherLanguages")}</p>
          <nav class="footer-langs-grid" aria-labelledby="footer-langs-heading">
            {Object.entries(LANGUAGES).map(([code, info]) => (
              <a
                href={`/${code}/`}
                class:list={["footer-lang-link", { active: code === lang }]}
                lang={code}
                aria-current={code === lang ? "true" : undefined}
              >
                <span class="footer-lang-flag" aria-hidden="true">{info.flag}</span>
                <span>{info.nativeName}</span>
              </a>
            ))}
          </nav>
        </div>

        <div class="footer-divider" role="separator"></div>

        <!-- Disclaimer + copyright -->
        <div class="footer-bottom">
          <p class="disclaimer">
            {t(lang, "footer.disclaimer")}
          </p>
          <p class="copyright">
            {t(lang, "footer.copyright").replace("{year}", String(new Date().getFullYear()))}
          </p>
        </div>
      </div>
    </footer>

    <!-- Language suggestion CTA (mobile) -->
    <div class="lang-cta" id="lang-cta" hidden role="complementary" aria-label="Language suggestion">
      <div class="lang-cta-inner">
        <a href="#" class="lang-cta-link" id="lang-cta-link"></a>
        <button class="lang-cta-dismiss" aria-label={t(lang, "langCta.dismiss")} data-dismiss-lang-cta>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <script is:inline>
      // --- Smooth header shrink on scroll ---
      (function() {
        const header = document.querySelector('.header');
        if (header) {
          var SCROLL_DISTANCE = 80;
          var onScroll = function() {
            var progress = Math.min(window.scrollY / SCROLL_DISTANCE, 1);
            header.style.setProperty('--scroll-progress', progress);
          };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }
      })();

      // --- Overlay system ---
      const menuBtn = document.querySelector('.menu-btn');
      const langBtn = document.querySelector('[data-lang-trigger]');
      const menuOverlay = document.getElementById('mobile-menu');
      const langOverlay = document.getElementById('mobile-langs');
      const searchOverlay = document.getElementById('search-overlay');
      const searchBtn = document.querySelector('[data-search-trigger]');
      const isMobile = () => window.matchMedia('(max-width: 768px)').matches;
      let lastFocusedElement = null;

      function openOverlay(el, trigger) {
        lastFocusedElement = trigger || document.activeElement;
        el.hidden = false;
        el.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (el === menuOverlay && menuBtn) menuBtn.setAttribute('aria-expanded', 'true');
        if (el === searchOverlay && searchBtn) searchBtn.setAttribute('aria-expanded', 'true');
        const closeBtn = el.querySelector('.overlay-close');
        if (closeBtn) closeBtn.focus();
        el.addEventListener('keydown', trapFocus);
      }

      function closeOverlay(el) {
        if (!el || el.hidden) return;
        el.classList.remove('open');
        el.hidden = true;
        document.body.style.overflow = '';
        if (el === menuOverlay && menuBtn) menuBtn.setAttribute('aria-expanded', 'false');
        if (el === searchOverlay && searchBtn) searchBtn.setAttribute('aria-expanded', 'false');
        el.removeEventListener('keydown', trapFocus);
        if (lastFocusedElement) {
          lastFocusedElement.focus();
          lastFocusedElement = null;
        }
      }

      function trapFocus(e) {
        if (e.key !== 'Tab') return;
        const overlay = e.currentTarget;
        const focusable = overlay.querySelectorAll(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        );
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      if (menuBtn) menuBtn.addEventListener('click', () => openOverlay(menuOverlay, menuBtn));

      if (langBtn) {
        langBtn.addEventListener('click', (e) => {
          if (isMobile()) { e.stopPropagation(); openOverlay(langOverlay, langBtn); }
        });
      }

      // Search overlay
      if (searchBtn && searchOverlay) {
        searchBtn.addEventListener('click', () => {
          openOverlay(searchOverlay, searchBtn);
          const input = searchOverlay.querySelector('.search-input');
          if (input) setTimeout(() => input.focus(), 50);
        });
      }

      // Close buttons in all overlays
      document.querySelectorAll('.overlay-close').forEach((btn) => {
        btn.addEventListener('click', () => {
          const overlay = btn.closest('.mobile-overlay');
          if (overlay) closeOverlay(overlay);
        });
      });

      // Escape closes any open overlay
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          [menuOverlay, langOverlay, searchOverlay].forEach(ov => {
            if (ov && !ov.hidden) closeOverlay(ov);
          });
        }
      });

      // --- Theme toggle ---
      (function() {
        const btn = document.querySelector('[data-theme-toggle]');
        if (!btn) return;
        function getTheme() { return localStorage.getItem('plata-theme') || 'system'; }
        function updateLabel() {
          const th = getTheme();
          const labels = { system: btn.dataset.labelLight, light: btn.dataset.labelDark, dark: btn.dataset.labelSystem };
          btn.setAttribute('aria-label', labels[th] || labels.system);
        }
        updateLabel();
        btn.addEventListener('click', () => {
          const cur = getTheme();
          let next = cur === 'system' ? 'light' : cur === 'light' ? 'dark' : 'system';
          if (next === 'system') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            document.documentElement.setAttribute('data-theme', next);
          }
          localStorage.setItem('plata-theme', next);
          updateLabel();
        });
      })();

      // --- Breaking news dismiss ---
      (function() {
        const bar = document.getElementById('breaking-news');
        if (!bar) return;
        if (sessionStorage.getItem('breaking-dismissed')) { bar.hidden = true; return; }
        const dismiss = bar.querySelector('[data-dismiss-breaking]');
        if (dismiss) dismiss.addEventListener('click', () => {
          bar.hidden = true;
          sessionStorage.setItem('breaking-dismissed', '1');
        });
      })();

      // --- Language suggestion CTA (mobile) ---
      (function() {
        const cta = document.getElementById('lang-cta');
        if (!cta || sessionStorage.getItem('lang-cta-dismissed')) return;
        if (window.matchMedia('(min-width: 769px)').matches) return;
        const pageLang = document.documentElement.lang;
        const browserLang = (navigator.language || '').split('-')[0].toLowerCase();
        if (browserLang === pageLang) return;
        try {
          const map = JSON.parse(document.documentElement.dataset.langMap || '{}');
          const match = map[browserLang];
          if (!match) return;
          const link = document.getElementById('lang-cta-link');
          if (link) { link.textContent = match.label; link.href = '/' + browserLang + '/'; }
          cta.hidden = false;
        } catch(e) {}
        cta.querySelector('[data-dismiss-lang-cta]')?.addEventListener('click', () => {
          cta.hidden = true;
          sessionStorage.setItem('lang-cta-dismissed', '1');
        });
      })();

      // Newsletter forms
      document.querySelectorAll('[data-newsletter-form]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var input = form.querySelector('input[type="email"]');
          var btn = form.querySelector('button[type="submit"]');
          var success = form.querySelector('[class*="success"]');
          if (input) input.hidden = true;
          if (btn) btn.hidden = true;
          if (success) success.hidden = false;
          // Hide any hint/label siblings
          var hint = form.querySelector('[class*="hint"]');
          if (hint) hint.hidden = true;
          var label = form.querySelector('label');
          if (label) label.hidden = true;
        });
      });
    </script>
    <!-- Pull to refresh -->
    <script is:inline>
      (function() {
        var ptr = document.getElementById('ptr');
        if (!ptr || !('ontouchstart' in window)) return;

        var startY = 0;
        var pulling = false;
        var threshold = 80;
        var maxPull = 120;
        var currentPull = 0;

        function isAtTop() {
          return window.scrollY <= 0;
        }

        function hasOpenOverlay() {
          var overlays = document.querySelectorAll('.mobile-overlay');
          for (var i = 0; i < overlays.length; i++) {
            if (!overlays[i].hidden) return true;
          }
          return false;
        }

        document.addEventListener('touchstart', function(e) {
          if (isAtTop() && !hasOpenOverlay()) {
            startY = e.touches[0].clientY;
            pulling = true;
            currentPull = 0;
          }
        }, { passive: true });

        document.addEventListener('touchmove', function(e) {
          if (!pulling) return;
          var dy = e.touches[0].clientY - startY;
          if (dy < 0) { pulling = false; return; }
          currentPull = Math.min(dy * 0.5, maxPull);
          if (currentPull > 10) {
            ptr.classList.add('ptr--visible');
            ptr.style.transform = 'translateY(' + (currentPull - 50) + 'px)';
            var rotation = (currentPull / threshold) * 360;
            var icon = ptr.querySelector('.ptr-icon');
            if (icon) icon.style.transform = 'rotate(' + rotation + 'deg)';
            if (currentPull >= threshold) {
              ptr.classList.add('ptr--ready');
            } else {
              ptr.classList.remove('ptr--ready');
            }
          }
        }, { passive: true });

        document.addEventListener('touchend', function() {
          if (!pulling) return;
          if (currentPull >= threshold) {
            ptr.classList.add('ptr--loading');
            ptr.classList.remove('ptr--ready');
            ptr.style.transform = 'translateY(10px)';
            setTimeout(function() { location.reload(); }, 200);
          } else {
            ptr.classList.remove('ptr--visible', 'ptr--ready');
            ptr.style.transform = '';
          }
          pulling = false;
          currentPull = 0;
          startY = 0;
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
