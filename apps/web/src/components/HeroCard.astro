---
interface Props {
  title: string;
  description?: string;
  href: string;
  imageUrl: string;
  timeAgo?: string;
  category?: string;
  readingTime?: string;
  size?: "large" | "medium";
}

const {
  title,
  description,
  href,
  imageUrl,
  timeAgo,
  category,
  readingTime,
  size = "medium",
} = Astro.props;
---

<article class:list={["hero-card", `hero-card--${size}`]}>
  <a href={href} class="hero-card-link">
    <img src={imageUrl} alt={title} loading="lazy" class="hero-card-img" />
    <div class="hero-card-overlay">
      {category && <span class="hero-card-category">{category}</span>}
      <h3 class="hero-card-title">{title}</h3>
      {description && <p class="hero-card-desc">{description}</p>}
      <div class="hero-card-meta">
        {timeAgo && <span class="hero-card-time">{timeAgo}</span>}
        {readingTime && <span class="hero-card-reading">{readingTime}</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .hero-card {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }

  .hero-card-link {
    display: block;
    position: relative;
    color: #fff;
    text-decoration: none;
  }

  .hero-card-link:hover {
    text-decoration: none;
    color: #fff;
  }

  .hero-card-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .hero-card-link:hover .hero-card-img {
    transform: scale(1.03);
  }

  .hero-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.4) 60%, transparent 100%);
  }

  .hero-card-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-gold);
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .hero-card-title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .hero-card-desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 10px;
  }

  .hero-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-card-time {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-card-reading {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Large variant */
  .hero-card--large .hero-card-img {
    aspect-ratio: 16 / 10;
  }

  .hero-card--large .hero-card-title {
    font-size: 1.75rem;
  }

  .hero-card--large .hero-card-desc {
    font-size: 0.95rem;
  }

  .hero-card--large .hero-card-overlay {
    padding: 32px;
  }

  @media (max-width: 640px) {
    .hero-card--large .hero-card-title {
      font-size: 1.35rem;
    }

    .hero-card-title {
      font-size: 1.05rem;
    }
  }
</style>
