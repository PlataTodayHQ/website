---
interface Props {
  title: string;
  description?: string;
  href: string;
  imageUrl?: string;
  timeAgo?: string;
  category?: string;
  categoryKey?: string;
  readingTime?: string;
  isNew?: boolean;
  sourceLabel?: string;
  variant?: "default" | "hero" | "sidebar" | "compact";
}

const {
  title,
  description,
  href,
  imageUrl,
  timeAgo,
  category,
  categoryKey,
  readingTime,
  isNew,
  sourceLabel,
  variant = "default",
} = Astro.props;
---

<article
  class:list={["card", `card--${variant}`]}
  style={categoryKey ? `--cat-color: var(--cat-${categoryKey}, var(--color-gold-dark))` : undefined}
>
  <a href={href} class="card-link">
    {/* Category header — Instagram-style top bar */}
    {(category || isNew) && (
      <div class="card-header">
        {category && <span class="card-category">{category}</span>}
        {isNew && <span class="card-badge-new">NEW</span>}
      </div>
    )}
    {imageUrl && (
      <div class="card-image">
        <img src={imageUrl} alt={title} loading="lazy" onerror="this.parentElement.style.display='none'" />
      </div>
    )}
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      {description && <p class="card-desc">{description}</p>}
      <div class="card-meta">
        {timeAgo && <time class="card-time">{timeAgo}</time>}
        {readingTime && <><span class="card-divider" aria-hidden="true">&middot;</span><span class="card-reading-time">{readingTime}</span></>}
        {sourceLabel && <><span class="card-divider" aria-hidden="true">&middot;</span><span class="card-source">via {sourceLabel}</span></>}
      </div>
    </div>
  </a>
</article>

<style>
  /* ====================== */
  /* BASE CARD (Instagram)  */
  /* ====================== */
  .card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
  }

  .card-category {
    color: var(--cat-color, var(--color-gold-dark));
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .card-badge-new {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    background: #b91c1c;
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .card-image {
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card-link:hover .card-image img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 14px 16px 16px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 6px;
    color: var(--color-text);
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    font-size: 0.75rem;
    color: var(--color-text-meta);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .card-source {
    font-style: italic;
  }

  .card-divider {
    color: var(--color-border);
  }

  .card-reading-time {
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  /* ====================== */
  /* HERO VARIANT            */
  /* ====================== */
  .card--hero {
    border-radius: 16px;
  }

  .card--hero .card-image img {
    aspect-ratio: 1 / 1;
  }

  .card--hero .card-header {
    padding: 14px 20px;
  }

  .card--hero .card-body {
    padding: 16px 20px 20px;
  }

  .card--hero .card-title {
    font-size: 1.5rem;
    line-height: 1.25;
    -webkit-line-clamp: 4;
  }

  .card--hero .card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    -webkit-line-clamp: 3;
  }

  /* ========================= */
  /* SIDEBAR VARIANT            */
  /* ========================= */
  .card--sidebar {
    background: transparent;
    border: none;
    border-radius: 0;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }

  .card--sidebar:hover {
    box-shadow: none;
    transform: none;
  }

  .card--sidebar:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .card--sidebar .card-header {
    padding: 0 0 6px;
  }

  .card--sidebar .card-body {
    padding: 0;
  }

  .card--sidebar .card-title {
    font-size: 1rem;
  }

  .card--sidebar .card-desc {
    display: none;
  }

  /* ============================== */
  /* COMPACT VARIANT (Instagram)    */
  /* ============================== */
  .card--compact {
    border-radius: 10px;
  }

  .card--compact .card-image img {
    aspect-ratio: 4 / 5;
  }

  .card--compact .card-title {
    font-size: 0.95rem;
    -webkit-line-clamp: 2;
  }

  .card--compact .card-desc {
    display: none;
  }

  .card--compact .card-meta {
    font-size: 0.7rem;
  }

  /* ====================== */
  /* MOBILE                  */
  /* ====================== */
  @media (max-width: 640px) {
    .card {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }

    .card--hero {
      border-radius: 0;
    }

    .card--compact {
      border-radius: 0;
    }

    .card--hero .card-image img {
      aspect-ratio: 4 / 5;
    }
  }
</style>
