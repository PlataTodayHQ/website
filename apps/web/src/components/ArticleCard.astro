---
import { t } from "@/i18n";

interface Props {
  title: string;
  description?: string;
  href: string;
  imageUrl?: string;
  timeAgo?: string;
  category?: string;
  categoryKey?: string;
  readingTime?: string;
  isNew?: boolean;
  sourceLabel?: string;
  variant?: "default" | "hero" | "sidebar" | "compact" | "list";
  lang?: string;
}

const {
  title,
  description,
  href,
  imageUrl,
  timeAgo,
  category,
  categoryKey,
  readingTime,
  isNew,
  sourceLabel,
  variant = "default",
  lang = "en",
} = Astro.props;

const isList = variant === "list";
---

{isList ? (
  <article
    class="card card--list"
    style={categoryKey ? `--cat-color: var(--cat-${categoryKey}, var(--color-gold-dark))` : undefined}
  >
    <div class="card-body">
      <div class="card-meta">
        {category && <span class="card-category">{category}</span>}
        {category && timeAgo && <span class="card-divider" aria-hidden="true">&middot;</span>}
        {timeAgo && <time class="card-time">{timeAgo}</time>}
        {readingTime && <><span class="card-divider" aria-hidden="true">&middot;</span><span class="card-reading-time">{readingTime}</span></>}
      </div>
      <a href={href} class="card-link">
        <h3 class="card-title">{title}</h3>
      </a>
      {description && <p class="card-desc">{description}</p>}
    </div>
    {imageUrl && (
      <a href={href} class="card-thumb" aria-hidden="true" tabindex="-1">
        <img src={imageUrl} alt={title} loading="lazy" width="270" height="180" onerror="this.parentElement.style.display='none'" />
      </a>
    )}
  </article>
) : (
  <article
    class:list={["card", `card--${variant}`]}
    style={categoryKey ? `--cat-color: var(--cat-${categoryKey}, var(--color-gold-dark))` : undefined}
  >
    <a href={href} class="card-link">
      {imageUrl && (
        <div class="card-image">
          <img src={imageUrl} alt={title} loading="lazy" width="600" height="400" onerror="this.parentElement.style.display='none'" />
        </div>
      )}
      <div class="card-body">
        {(category || isNew) && (
          <div class="card-meta-top">
            {category && <span class="card-category">{category}</span>}
            {isNew && <span class="card-badge-new">{t(lang, "article.badgeNew")}</span>}
          </div>
        )}
        <h3 class="card-title">{title}</h3>
        {description && <p class="card-desc">{description}</p>}
        <div class="card-meta">
          {timeAgo && <time class="card-time">{timeAgo}</time>}
          {readingTime && <><span class="card-divider" aria-hidden="true">&middot;</span><span class="card-reading-time">{readingTime}</span></>}
          {sourceLabel && <><span class="card-divider" aria-hidden="true">&middot;</span><span class="card-source">{t(lang, "article.via")} {sourceLabel}</span></>}
        </div>
      </div>
    </a>
  </article>
)}

<style>
  /* ========================= */
  /* BASE CARD — Newspaper     */
  /* ========================= */
  .card {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    transition: none;
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .card-link:hover .card-title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .card-meta-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .card-category {
    color: var(--cat-color, var(--color-gold-dark));
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
  }

  .card-badge-new {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    background: #b91c1c;
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .card-image {
    overflow: hidden;
    border-radius: 2px;
    margin-bottom: 10px;
  }

  .card-image img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .card-body {
    padding: 0;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 6px;
    color: var(--color-text);
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    font-size: 0.73rem;
    color: var(--color-text-meta);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .card-source {
    font-style: italic;
  }

  .card-divider {
    color: var(--color-border);
  }

  .card-reading-time {
    font-size: 0.73rem;
    color: var(--color-text-meta);
  }

  /* ========================= */
  /* HERO VARIANT               */
  /* ========================= */
  .card--hero .card-image img {
    aspect-ratio: 16 / 9;
  }

  .card--hero .card-title {
    font-size: 1.5rem;
    line-height: 1.2;
    -webkit-line-clamp: 4;
  }

  .card--hero .card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    -webkit-line-clamp: 3;
  }

  /* ========================= */
  /* SIDEBAR VARIANT             */
  /* ========================= */
  .card--sidebar {
    background: transparent;
    border: none;
    border-radius: 0;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }

  .card--sidebar:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .card--sidebar .card-title {
    font-size: 1rem;
  }

  .card--sidebar .card-desc {
    display: none;
  }

  /* ============================== */
  /* COMPACT VARIANT                 */
  /* ============================== */
  .card--compact .card-image img {
    aspect-ratio: 3 / 2;
  }

  .card--compact .card-title {
    font-size: 0.95rem;
    -webkit-line-clamp: 2;
  }

  .card--compact .card-desc {
    display: none;
  }

  .card--compact .card-meta {
    font-size: 0.7rem;
  }

  /* ============================== */
  /* LIST VARIANT (horizontal)       */
  /* ============================== */
  .card--list {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    background: transparent;
    border: none;
    border-radius: 0;
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .card--list:first-child {
    padding-top: 0;
  }

  .card--list:last-child {
    border-bottom: none;
  }

  .card--list .card-body {
    flex: 1;
    min-width: 0;
    padding: 0;
  }

  .card--list .card-meta {
    margin-bottom: 6px;
  }

  .card--list .card-category {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .card--list .card-link {
    color: var(--color-text);
  }

  .card--list .card-link:hover .card-title {
    text-decoration: underline;
  }

  .card--list .card-title {
    font-size: 1.15rem;
    -webkit-line-clamp: unset;
    margin-bottom: 4px;
  }

  .card--list .card-desc {
    font-size: 0.88rem;
    line-height: 1.5;
    margin-bottom: 0;
  }

  .card-thumb {
    flex-shrink: 0;
    width: 180px;
  }

  .card-thumb img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 2px;
  }

  /* ========================= */
  /* MOBILE                     */
  /* ========================= */
  @media (max-width: 640px) {
    .card--hero .card-image img {
      aspect-ratio: 3 / 2;
    }

    .card-category {
      font-size: 0.75rem;
    }

    .card-badge-new {
      font-size: 0.62rem;
    }

    .card-title {
      font-size: 1.05rem;
    }

    .card-desc {
      font-size: 0.88rem;
    }

    .card-meta {
      font-size: 0.78rem;
    }

    .card-reading-time {
      font-size: 0.78rem;
    }

    .card--hero .card-title {
      font-size: 1.35rem;
    }

    .card--hero .card-desc {
      font-size: 0.92rem;
    }

    .card--compact .card-meta {
      font-size: 0.75rem;
    }

    .card--list .card-title {
      font-size: 1rem;
    }

    .card--list .card-category {
      font-size: 0.78rem;
    }

    .card--list .card-desc {
      display: none;
    }

    .card-thumb {
      width: 110px;
    }
  }
</style>
