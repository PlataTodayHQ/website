---
interface Props {
  title: string;
  href?: string;
  accentColor?: string;
}

const { title, href, accentColor } = Astro.props;
---

<div class="section-header" style={accentColor ? `border-color: ${accentColor}` : undefined}>
  {href ? (
    <a href={href} class="section-title-link">
      <h2 class="section-title">{title}</h2>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M7 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  ) : (
    <h2 class="section-title">{title}</h2>
  )}
</div>

<style>
  .section-header {
    border-top: 2px solid var(--color-border-section);
    padding-top: 10px;
    margin-bottom: var(--spacing-lg);
    margin-top: var(--spacing-2xl);
    position: relative;
  }

  .section-header::after {
    content: "";
    position: absolute;
    top: 4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-border-section);
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-title-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text);
  }

  .section-title-link .section-title {
    margin-bottom: 0;
  }

  .section-title-link svg {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  @media (max-width: 640px) {
    .section-title {
      font-size: 0.82rem;
    }

    .section-title-link svg {
      width: 16px;
      height: 16px;
    }
  }

  .section-title-link:hover {
    text-decoration: none;
    color: var(--color-link-hover);
  }
</style>
