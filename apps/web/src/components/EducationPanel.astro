---
interface InfoCard {
  label: string;
  value: string;
  wide?: boolean;
}

interface Props {
  title: string;
  text: string;
  cards: InfoCard[];
  /** Whether the panel starts open (default: false) */
  open?: boolean;
}

const { title, text, cards, open = false } = Astro.props;
---

<details class="fi-info-panel" data-fi-info {...(open ? { open: true } : {})}>
  <summary class="fi-info-toggle">
    <svg class="fi-info-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    <span>{title}</span>
    <svg class="fi-info-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
  </summary>
  <div class="fi-info-content">
    <p class="fi-info-text">{text}</p>
    <div class="fi-info-grid">
      {cards.map(card => (
        <div class:list={["fi-info-card", { "fi-info-card--wide": card.wide }]}>
          <div class="fi-info-card-label">{card.label}</div>
          <div class="fi-info-card-val">{card.value}</div>
        </div>
      ))}
    </div>
  </div>
</details>
