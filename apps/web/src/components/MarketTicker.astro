---
import { t } from "@/i18n";

interface Props {
  lang?: string;
}
const { lang = "en" } = Astro.props;
---

<div class="ticker" role="complementary" aria-label={t(lang, "common.marketData")} data-market-ticker>
  <div class="ticker-inner">
    <!-- Dollar rates -->
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="oficial">
      <span class="ticker-name">{t(lang, "ticker.usdOficial")}</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="oficial">---</span>
        <span class="ticker-change" data-tc="oficial"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="blue">
      <span class="ticker-name ticker-name--blue">{t(lang, "ticker.usdBlue")}</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="blue">---</span>
        <span class="ticker-change" data-tc="blue"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="mep">
      <span class="ticker-name">{t(lang, "ticker.mep")}</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="mep">---</span>
        <span class="ticker-change" data-tc="mep"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="ccl">
      <span class="ticker-name">{t(lang, "ticker.ccl")}</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="ccl">---</span>
        <span class="ticker-change" data-tc="ccl"></span>
      </span>
    </a>

    <span class="ticker-sep"></span>

    <!-- Merval index -->
    <a href={`/${lang}/markets/merval`} class="ticker-item" data-ticker="merval">
      <span class="ticker-name ticker-name--merval">{t(lang, "ticker.merval")}</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="merval">---</span>
        <span class="ticker-change" data-tc="merval"></span>
      </span>
    </a>

    <!-- Top 10 stocks by market cap (populated dynamically) -->
    <div id="stocks-container" class="ticker-group"></div>

    <span class="ticker-sep"></span>

    <!-- Commodities -->
    <div id="commodities-container" class="ticker-group"></div>

    <span class="ticker-sep"></span>

    <!-- Top 10 crypto (populated dynamically) -->
    <div id="crypto-container" class="ticker-group"></div>
  </div>
</div>

<script is:inline src="/js/market-helpers.js?v=2"></script>
<script is:inline src="/js/market-ticker.js"></script>

<style>
  /* Root — scoped by Astro, all children via :global() */
  .ticker {
    background: #0d1f38;
    border-bottom: 1px solid rgba(117, 170, 219, 0.15);
    position: relative;
    z-index: 1;
  }

  .ticker :global(.ticker-inner) {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    padding: 0;
    overflow-x: auto;
    scrollbar-width: none;
    gap: 0;
  }

  .ticker :global(.ticker-inner)::-webkit-scrollbar {
    display: none;
  }

  .ticker :global(.ticker-item) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2px;
    padding: 6px 14px;
    white-space: nowrap;
    text-decoration: none;
    color: #e8e6e3;
    font-variant-numeric: tabular-nums;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.15s;
    flex: 0 0 auto;
    min-width: 80px;
    text-align: left;
    align-items: flex-start;
  }

  .ticker :global(.ticker-item:last-child) {
    border-right: none;
  }

  .ticker :global(.ticker-item:hover) {
    background: rgba(255, 255, 255, 0.05);
    text-decoration: none;
  }

  .ticker :global(.ticker-sep) {
    flex: 0 0 auto;
    width: 1px;
    background: rgba(117, 170, 219, 0.2);
    margin: 5px 2px;
  }

  .ticker :global(.ticker-group) {
    display: contents;
  }

  .ticker :global(.ticker-name) {
    font-size: 0.68rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.2;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .ticker :global(.ticker-name--blue) { color: rgba(117, 170, 219, 0.7); }
  .ticker :global(.ticker-name--merval) { color: rgba(246, 180, 14, 0.7); }
  .ticker :global(.ticker-name--stock) { color: rgba(255, 255, 255, 0.5); }
  .ticker :global(.ticker-name--commodity) { color: rgba(246, 180, 14, 0.6); }
  .ticker :global(.ticker-name--crypto) { color: rgba(117, 170, 219, 0.6); }

  .ticker :global(.ticker-row) {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 6px;
  }

  .ticker :global(.ticker-price) {
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .ticker :global(.ticker-change) {
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .ticker :global(.ticker-up) { color: #34d399; }
  .ticker :global(.ticker-down) { color: #f87171; }

  @media (max-width: 768px) {
    .ticker :global(.ticker-inner) {
      padding: 0;
    }

    .ticker :global(.ticker-item) {
      padding: 5px 10px;
      min-width: 76px;
    }

    .ticker :global(.ticker-name) {
      font-size: 0.64rem;
    }

    .ticker :global(.ticker-price) {
      font-size: 0.78rem;
    }

    .ticker :global(.ticker-change) {
      font-size: 0.6rem;
    }
  }
</style>
