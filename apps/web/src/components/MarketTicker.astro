---
import { t } from "@/i18n";

interface Props {
  lang?: string;
}
const { lang = "en" } = Astro.props;
---

<div class="ticker" role="complementary" aria-label="Market data" data-market-ticker>
  <div class="ticker-inner">
    <!-- Dollar rates -->
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="oficial">
      <span class="ticker-name">USD Oficial</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="oficial">---</span>
        <span class="ticker-change" data-tc="oficial"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="blue">
      <span class="ticker-name ticker-name--blue">USD Blue</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="blue">---</span>
        <span class="ticker-change" data-tc="blue"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="mep">
      <span class="ticker-name">Dólar MEP</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="mep">---</span>
        <span class="ticker-change" data-tc="mep"></span>
      </span>
    </a>
    <a href={`/${lang}/markets/currencies`} class="ticker-item" data-ticker="ccl">
      <span class="ticker-name">Dólar CCL</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="ccl">---</span>
        <span class="ticker-change" data-tc="ccl"></span>
      </span>
    </a>

    <span class="ticker-sep"></span>

    <!-- Merval index -->
    <a href={`/${lang}/markets/merval`} class="ticker-item" data-ticker="merval">
      <span class="ticker-name ticker-name--merval">Merval</span>
      <span class="ticker-row">
        <span class="ticker-price" data-tv="merval">---</span>
        <span class="ticker-change" data-tc="merval"></span>
      </span>
    </a>

    <!-- Top 10 stocks by market cap (populated dynamically) -->
    <div id="stocks-container" class="ticker-group"></div>

    <span class="ticker-sep"></span>

    <!-- Commodities -->
    <div id="commodities-container" class="ticker-group"></div>

    <span class="ticker-sep"></span>

    <!-- Top 10 crypto (populated dynamically) -->
    <div id="crypto-container" class="ticker-group"></div>
  </div>
</div>

<script is:inline>
(function() {
  var CACHE_KEY = 'plata-market-v5';
  var RATES_URL = '/api/rates';
  var EVO_URL = 'https://api.bluelytics.com.ar/v2/evolution.json?days=10';
  var BYMA_URL = 'https://open.bymadata.com.ar/vanoms-be-core/rest/api/bymadata/free/index-price';
  var YAHOO_URL = 'https://query1.finance.yahoo.com/v8/finance/chart/%5EMERV?interval=1d&range=1d';
  var SCREENER_URL = '/api/screener';
  var COMMODITIES_URL = '/api/commodities';
  var CRYPTO_URL = '/api/crypto';
  var REFRESH_MS = 5 * 60 * 1000;
  var lastFetchTime = 0;

  var lang = document.documentElement.lang || 'en';

  function pct(current, previous) {
    if (!previous || previous === 0) return null;
    var p = ((current - previous) / previous) * 100;
    if (Math.abs(p) < 0.01) return null;
    return p;
  }

  function formatARS(val) {
    return Math.round(val).toLocaleString('es-AR');
  }

  function formatMerval(val) {
    if (val >= 1000000) return (val / 1000000).toFixed(2) + 'M';
    if (val >= 1000) return (val / 1000).toFixed(0) + 'K';
    return Math.round(val).toLocaleString('es-AR');
  }

  function formatUSD(val) {
    if (val >= 10000) return Math.round(val).toLocaleString('en-US');
    if (val >= 1000) return val.toFixed(0);
    if (val >= 1) return val.toFixed(2);
    return val.toFixed(4);
  }

  function applyItem(key, displayText, percent) {
    var el = document.querySelector('[data-tv="' + key + '"]');
    var chEl = document.querySelector('[data-tc="' + key + '"]');
    if (!el || !chEl) return;

    el.textContent = displayText;

    if (percent != null) {
      var sign = percent > 0 ? '+' : '';
      var arrow = percent > 0 ? '\u25B2' : percent < 0 ? '\u25BC' : '';
      chEl.textContent = arrow + ' ' + sign + percent.toFixed(2) + '%';
      chEl.className = 'ticker-change ' + (percent >= 0 ? 'ticker-up' : 'ticker-down');
    } else {
      chEl.textContent = '';
      chEl.className = 'ticker-change';
    }
  }

  function createTickerItem(key, label, href, nameClass) {
    var a = document.createElement('a');
    a.href = href;
    a.className = 'ticker-item';
    a.setAttribute('data-ticker', key);
    a.innerHTML =
      '<span class="ticker-name' + (nameClass ? ' ' + nameClass : '') + '">' + label + '</span>' +
      '<span class="ticker-row">' +
        '<span class="ticker-price" data-tv="' + key + '">---</span>' +
        '<span class="ticker-change" data-tc="' + key + '"></span>' +
      '</span>';
    return a;
  }

  // Build dynamic containers on first load
  var stocksBuilt = false;
  var commoditiesBuilt = false;
  var cryptoBuilt = false;

  function buildStocks(stocks) {
    if (stocksBuilt) return;
    var container = document.getElementById('stocks-container');
    if (!container) return;
    var top10 = stocks.slice(0, 10);
    for (var i = 0; i < top10.length; i++) {
      var s = top10[i];
      var key = 'stock-' + s.symbol;
      var el = createTickerItem(key, s.symbol, '/' + lang + '/markets/stocks/' + s.symbol, 'ticker-name--stock');
      container.appendChild(el);
    }
    stocksBuilt = true;
  }

  function buildCommodities(commodities) {
    if (commoditiesBuilt) return;
    var container = document.getElementById('commodities-container');
    if (!container) return;
    for (var i = 0; i < commodities.length; i++) {
      var c = commodities[i];
      var key = 'comm-' + c.symbol.replace('=', '');
      var el = createTickerItem(key, c.name, '/' + lang + '/markets', 'ticker-name--commodity');
      container.appendChild(el);
    }
    commoditiesBuilt = true;
  }

  function buildCrypto(cryptos) {
    if (cryptoBuilt) return;
    var container = document.getElementById('crypto-container');
    if (!container) return;
    for (var i = 0; i < cryptos.length; i++) {
      var c = cryptos[i];
      var key = 'crypto-' + c.symbol;
      var el = createTickerItem(key, c.symbol, '/' + lang + '/markets', 'ticker-name--crypto');
      container.appendChild(el);
    }
    cryptoBuilt = true;
  }

  function render(data) {
    if (data.oficial) applyItem('oficial', formatARS(data.oficial), data.oficialPct);
    if (data.blue) applyItem('blue', formatARS(data.blue), data.bluePct);
    if (data.mep) applyItem('mep', formatARS(data.mep), data.mepPct);
    if (data.ccl) applyItem('ccl', formatARS(data.ccl), data.cclPct);
    if (data.merval) applyItem('merval', formatMerval(data.merval), data.mervalPct);

    // Stocks
    if (data.stocks && data.stocks.length) {
      buildStocks(data.stocks);
      for (var i = 0; i < data.stocks.length; i++) {
        var s = data.stocks[i];
        var key = 'stock-' + s.symbol;
        var price = s.price;
        if (price != null) {
          applyItem(key, formatARS(price), s.change != null ? s.change * 100 : null);
        }
      }
    }

    // Commodities
    if (data.commodities && data.commodities.length) {
      buildCommodities(data.commodities);
      for (var i = 0; i < data.commodities.length; i++) {
        var c = data.commodities[i];
        var key = 'comm-' + c.symbol.replace('=', '');
        if (c.price != null) {
          applyItem(key, '$' + formatUSD(c.price), c.change);
        }
      }
    }

    // Crypto
    if (data.cryptos && data.cryptos.length) {
      buildCrypto(data.cryptos);
      for (var i = 0; i < data.cryptos.length; i++) {
        var c = data.cryptos[i];
        var key = 'crypto-' + c.symbol;
        if (c.price != null) {
          applyItem(key, '$' + formatUSD(c.price), c.change);
        }
      }
    }
  }

  function loadCached() {
    try {
      var raw = localStorage.getItem(CACHE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch (e) { return null; }
  }

  function saveCache(data) {
    try {
      data.ts = Date.now();
      localStorage.setItem(CACHE_KEY, JSON.stringify(data));
    } catch (e) {}
  }

  function parseEvolution(entries) {
    var bySource = {};
    for (var i = 0; i < entries.length; i++) {
      var e = entries[i];
      var key = e.source.toLowerCase();
      if (!bySource[key]) bySource[key] = [];
      bySource[key].push(e);
    }

    function sortDesc(a, b) { return a.date < b.date ? 1 : a.date > b.date ? -1 : 0; }

    var result = {};
    var sources = ['oficial', 'blue'];
    for (var s = 0; s < sources.length; s++) {
      var arr = bySource[sources[s]];
      if (arr && arr.length > 0) {
        arr.sort(sortDesc);
        result[sources[s]] = { current: arr[0].value_sell };
        if (arr.length > 1) {
          result[sources[s]].previous = arr[1].value_sell;
        }
      }
    }
    return result;
  }

  function fetchAll() {
    var now = Date.now();
    if (now - lastFetchTime < 60000) return;
    lastFetchTime = now;

    var cached = loadCached() || {};

    Promise.all([
      // 1. Rates
      fetch(RATES_URL).then(function(r) { return r.json(); }).catch(function() { return null; }),
      // 2. Evolution for % change
      fetch(EVO_URL).then(function(r) { return r.json(); }).catch(function() { return null; }),
      // 3. Merval
      fetch(BYMA_URL, { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: '{}' })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(d) {
          if (!d || !d.data) return null;
          var m = null;
          for (var i = 0; i < d.data.length; i++) { if (d.data[i].symbol === 'M') { m = d.data[i]; break; } }
          if (!m) return null;
          return { price: m.price, previousClose: m.previousClosingPrice, variation: m.variation };
        })
        .catch(function() { return null; })
        .then(function(byma) {
          if (byma) return byma;
          return fetch(YAHOO_URL).then(function(r) { return r.ok ? r.json() : null; }).then(function(d) {
            var meta = d && d.chart && d.chart.result && d.chart.result[0] && d.chart.result[0].meta;
            if (!meta) return null;
            var p = meta.regularMarketPrice, pc = meta.chartPreviousClose;
            return { price: p, previousClose: pc, variation: pc > 0 ? (p - pc) / pc : null };
          }).catch(function() { return null; });
        }),
      // 4. Screener (top 10 stocks)
      fetch(SCREENER_URL).then(function(r) { return r.ok ? r.json() : null; }).catch(function() { return null; }),
      // 5. Commodities
      fetch(COMMODITIES_URL).then(function(r) { return r.ok ? r.json() : null; }).catch(function() { return null; }),
      // 6. Crypto
      fetch(CRYPTO_URL).then(function(r) { return r.ok ? r.json() : null; }).catch(function() { return null; })
    ]).then(function(results) {
      var rates = results[0];
      var evo = results[1];
      var mervalData = results[2];
      var screenerData = results[3];
      var commoditiesData = results[4];
      var cryptoData = results[5];

      var data = {
        oficial: cached.oficial || null, oficialPct: cached.oficialPct || null,
        blue: cached.blue || null, bluePct: cached.bluePct || null,
        mep: cached.mep || null, mepPct: cached.mepPct || null,
        ccl: cached.ccl || null, cclPct: cached.cclPct || null,
        merval: cached.merval || null, mervalPct: cached.mervalPct || null,
        stocks: cached.stocks || null,
        commodities: cached.commodities || null,
        cryptos: cached.cryptos || null
      };

      // Dollar rates
      if (rates && rates.oficial) {
        data.oficial = rates.oficial.value_sell;
        data.blue = rates.blue.value_sell;

        if (evo && evo.length > 0) {
          var parsed = parseEvolution(evo);
          if (parsed.oficial && parsed.oficial.previous) {
            data.oficialPct = pct(data.oficial, parsed.oficial.previous);
          }
          if (parsed.blue && parsed.blue.previous) {
            data.bluePct = pct(data.blue, parsed.blue.previous);
          }
        }
      }

      // MEP & CCL
      if (rates && rates.mep) {
        data.mep = rates.mep.value_sell;
        data.mepPct = null;
      }
      if (rates && rates.ccl) {
        data.ccl = rates.ccl.value_sell;
        data.cclPct = null;
      }

      // Merval
      if (mervalData && mervalData.price) {
        data.merval = mervalData.price;
        data.mervalPct = mervalData.variation != null
          ? mervalData.variation * 100
          : pct(mervalData.price, mervalData.previousClose);
      }

      // Top 10 stocks
      if (screenerData && screenerData.length) {
        data.stocks = screenerData.slice(0, 10).map(function(s) {
          return { symbol: s.symbol, name: s.name, price: s.price, change: s.change };
        });
      }

      // Commodities
      if (commoditiesData && commoditiesData.length) {
        data.commodities = commoditiesData;
      }

      // Crypto
      if (cryptoData && cryptoData.length) {
        data.cryptos = cryptoData;
      }

      render(data);
      saveCache(data);
    }).catch(function() {});
  }

  // 1. Show cached immediately
  var cached = loadCached();
  if (cached) render(cached);

  // 2. Fetch live
  fetchAll();

  // 3. Auto-refresh
  setInterval(fetchAll, REFRESH_MS);

  // 4. Refresh on tab return
  document.addEventListener('visibilitychange', function() {
    if (!document.hidden) fetchAll();
  });

  // 5. Refresh on focus
  window.addEventListener('focus', fetchAll);
})();
</script>

<style>
  .ticker {
    background: var(--color-bg, #fff);
    border-bottom: 1px solid var(--color-border, #e0e0e0);
    position: relative;
    z-index: 1;
  }

  .ticker-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    padding: 0;
    overflow-x: auto;
    scrollbar-width: none;
    gap: 0;
  }

  .ticker-inner::-webkit-scrollbar {
    display: none;
  }

  .ticker-item {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1px;
    padding: 8px 12px;
    white-space: nowrap;
    text-decoration: none;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    border-right: 1px solid var(--color-border, #e8e8e8);
    transition: background 0.15s;
    flex: 0 0 auto;
    text-align: center;
    align-items: center;
  }

  .ticker-item:last-child {
    border-right: none;
  }

  .ticker-item:hover {
    background: var(--color-bg-secondary, #f5f5f5);
    text-decoration: none;
  }

  .ticker-sep {
    flex: 0 0 auto;
    width: 3px;
    background: var(--color-border, #e0e0e0);
    margin: 4px 0;
  }

  .ticker-group {
    display: contents;
  }

  .ticker-name {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }

  .ticker-name--blue { color: var(--color-gold-dark); }
  .ticker-name--merval { color: #0056b3; }
  .ticker-name--stock { color: #0056b3; }
  .ticker-name--commodity { color: #b8860b; }
  .ticker-name--crypto { color: #f7931a; }

  .ticker-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .ticker-price {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .ticker-change {
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .ticker-up { color: #00853e; }
  .ticker-down { color: #d32f2f; }

  @media (max-width: 768px) {
    .ticker-inner {
      padding: 0;
    }

    .ticker-item {
      padding: 6px 10px;
    }

    .ticker-name {
      font-size: 0.68rem;
    }

    .ticker-price {
      font-size: 0.8rem;
    }

    .ticker-change {
      font-size: 0.65rem;
    }

    .ticker-row {
      gap: 4px;
    }
  }
</style>
