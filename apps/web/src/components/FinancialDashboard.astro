---
import { t } from "@/i18n";

interface Props {
  lang?: string;
}
const { lang = "en" } = Astro.props;
---

<section class="fd" data-fin-dashboard aria-label={t(lang, "finDash.title" as any)}>
  <!-- Market Cards Strip -->
  <div class="fd-strip">
    <a href={`/${lang}/markets/currencies`} class="fd-card" data-fd-card="oficial">
      <div class="fd-card-head">
        <span class="fd-card-name">USD Oficial</span>
        <span class="fd-card-badge" data-fd-ch="oficial"></span>
      </div>
      <div class="fd-card-price" data-fd="oficial-sell">---</div>
      <div class="fd-card-sub">
        <span class="fd-card-meta">{t(lang, "finDash.buy" as any)}</span>
        <span class="fd-card-meta-val" data-fd="oficial-buy">---</span>
      </div>
    </a>

    <a href={`/${lang}/markets/currencies`} class="fd-card fd-card--blue" data-fd-card="blue">
      <div class="fd-card-head">
        <span class="fd-card-name">USD Blue</span>
        <span class="fd-card-badge" data-fd-ch="blue"></span>
      </div>
      <div class="fd-card-price" data-fd="blue-sell">---</div>
      <div class="fd-card-sub">
        <span class="fd-card-meta">{t(lang, "finDash.buy" as any)}</span>
        <span class="fd-card-meta-val" data-fd="blue-buy">---</span>
      </div>
    </a>

    <a href={`/${lang}/markets/currencies`} class="fd-card" data-fd-card="mep">
      <div class="fd-card-head">
        <span class="fd-card-name">MEP</span>
        <span class="fd-card-badge" data-fd-ch="mep"></span>
      </div>
      <div class="fd-card-price" data-fd="mep-sell">---</div>
      <div class="fd-card-sub">
        <span class="fd-card-meta">{t(lang, "finDash.buy" as any)}</span>
        <span class="fd-card-meta-val" data-fd="mep-buy">---</span>
      </div>
    </a>

    <a href={`/${lang}/markets/currencies`} class="fd-card" data-fd-card="ccl">
      <div class="fd-card-head">
        <span class="fd-card-name">CCL</span>
        <span class="fd-card-badge" data-fd-ch="ccl"></span>
      </div>
      <div class="fd-card-price" data-fd="ccl-sell">---</div>
      <div class="fd-card-sub">
        <span class="fd-card-meta">{t(lang, "finDash.buy" as any)}</span>
        <span class="fd-card-meta-val" data-fd="ccl-buy">---</span>
      </div>
    </a>

    <a href={`/${lang}/markets/merval`} class="fd-card fd-card--merval" data-fd-card="merval">
      <div class="fd-card-head">
        <span class="fd-card-name">Merval</span>
        <span class="fd-card-badge" data-fd-ch="merval"></span>
      </div>
      <div class="fd-card-price" data-fd="merval-price">---</div>
      <div class="fd-card-sub">
        <span class="fd-card-meta">{t(lang, "finDash.volume" as any)}</span>
        <span class="fd-card-meta-val" data-fd="merval-vol">---</span>
      </div>
    </a>
  </div>

  <!-- Top Movers -->
  <div class="fd-movers">
    <div class="fd-movers-head">
      <span class="fd-movers-title">{t(lang, "finDash.topMovers" as any)}</span>
      <a href={`/${lang}/markets`} class="fd-movers-link">{t(lang, "finDash.viewAll" as any)} &rarr;</a>
    </div>
    <div class="fd-movers-table" data-fd-stocks></div>
  </div>
</section>

<script is:inline>
(function() {
  var CACHE_KEY = 'plata-fin-dash-v2';
  var REFRESH_MS = 5 * 60 * 1000;
  var lastFetch = 0;

  function fmt(val) {
    return Math.round(val).toLocaleString('es-AR');
  }

  function fmtLarge(val) {
    if (val >= 1e9) return (val / 1e9).toFixed(2) + 'B';
    if (val >= 1e6) return (val / 1e6).toFixed(1) + 'M';
    if (val >= 1e3) return (val / 1e3).toFixed(0) + 'K';
    return Math.round(val).toLocaleString('es-AR');
  }

  function pct(cur, prev) {
    if (!prev || prev === 0) return null;
    var p = ((cur - prev) / prev) * 100;
    return Math.abs(p) < 0.01 ? null : p;
  }

  function setVal(attr, text) {
    document.querySelectorAll('[data-fd="' + attr + '"]').forEach(function(el) {
      el.textContent = text;
    });
  }

  function setBadge(attr, percent) {
    document.querySelectorAll('[data-fd-ch="' + attr + '"]').forEach(function(el) {
      if (percent == null) { el.textContent = ''; el.className = 'fd-card-badge'; return; }
      var sign = percent > 0 ? '+' : '';
      el.textContent = sign + percent.toFixed(1) + '%';
      el.className = 'fd-card-badge ' + (percent >= 0 ? 'fd-up' : 'fd-down');
    });

    // Also update the card's accent bar
    var card = document.querySelector('[data-fd-card="' + attr + '"]');
    if (card) {
      card.classList.remove('fd-card--positive', 'fd-card--negative');
      if (percent != null) {
        card.classList.add(percent >= 0 ? 'fd-card--positive' : 'fd-card--negative');
      }
    }
  }

  function renderRates(data) {
    if (data.oficial_sell) setVal('oficial-sell', fmt(data.oficial_sell));
    if (data.oficial_buy) setVal('oficial-buy', fmt(data.oficial_buy));
    if (data.blue_sell) setVal('blue-sell', fmt(data.blue_sell));
    if (data.blue_buy) setVal('blue-buy', fmt(data.blue_buy));
    if (data.mep_sell) setVal('mep-sell', fmt(data.mep_sell));
    if (data.mep_buy) setVal('mep-buy', fmt(data.mep_buy));
    if (data.ccl_sell) setVal('ccl-sell', fmt(data.ccl_sell));
    if (data.ccl_buy) setVal('ccl-buy', fmt(data.ccl_buy));
    setBadge('oficial', data.oficialPct);
    setBadge('blue', data.bluePct);
    setBadge('mep', data.mepPct);
    setBadge('ccl', data.cclPct);
  }

  function renderMerval(data) {
    if (data.merval_price) setVal('merval-price', fmtLarge(data.merval_price));
    if (data.merval_vol) setVal('merval-vol', fmtLarge(data.merval_vol));
    setBadge('merval', data.mervalPct);
  }

  function renderStocks(stocks) {
    var container = document.querySelector('[data-fd-stocks]');
    if (!container || !stocks || stocks.length === 0) return;
    container.innerHTML = '';
    for (var i = 0; i < stocks.length; i++) {
      var s = stocks[i];
      var row = document.createElement('a');
      var langPath = window.location.pathname.split('/')[1] || 'en';
      row.href = '/' + langPath + '/markets/stock?s=' + encodeURIComponent(s.symbol.replace('.BA', ''));
      row.className = 'fd-mover-row';
      var isUp = s.variation >= 0;
      var sign = s.variation > 0 ? '+' : '';
      row.innerHTML =
        '<span class="fd-mover-rank">' + (i + 1) + '</span>' +
        '<span class="fd-mover-sym">' + s.symbol + '</span>' +
        '<span class="fd-mover-price">' + fmt(s.price) + '</span>' +
        '<span class="fd-mover-chg ' + (isUp ? 'fd-up' : 'fd-down') + '">' +
          sign + s.variation.toFixed(1) + '%' +
        '</span>';
      container.appendChild(row);
    }
  }

  function render(data) {
    renderRates(data);
    renderMerval(data);
    if (data.stocks) renderStocks(data.stocks);
  }

  function loadCached() {
    try { var r = localStorage.getItem(CACHE_KEY); return r ? JSON.parse(r) : null; }
    catch(e) { return null; }
  }

  function saveCache(data) {
    try { data.ts = Date.now(); localStorage.setItem(CACHE_KEY, JSON.stringify(data)); }
    catch(e) {}
  }

  function fetchAll() {
    var now = Date.now();
    if (now - lastFetch < 60000) return;
    lastFetch = now;

    var cached = loadCached() || {};

    Promise.all([
      fetch('/api/rates').then(function(r) { return r.json(); }).catch(function() { return null; }),
      fetch('/api/merval').then(function(r) { return r.json(); }).catch(function() { return null; }),
      fetch('/api/leading-equity').then(function(r) { return r.json(); }).catch(function() { return null; }),
      fetch('https://api.bluelytics.com.ar/v2/evolution.json?days=10').then(function(r) { return r.json(); }).catch(function() { return null; })
    ]).then(function(results) {
      var rates = results[0];
      var merval = results[1];
      var equity = results[2];
      var evo = results[3];

      var data = Object.assign({}, cached);

      if (rates) {
        if (rates.oficial) {
          data.oficial_buy = rates.oficial.value_buy;
          data.oficial_sell = rates.oficial.value_sell;
        }
        if (rates.blue) {
          data.blue_buy = rates.blue.value_buy;
          data.blue_sell = rates.blue.value_sell;
        }
        if (rates.mep) {
          data.mep_buy = rates.mep.value_buy;
          data.mep_sell = rates.mep.value_sell;
        }
        if (rates.ccl) {
          data.ccl_buy = rates.ccl.value_buy;
          data.ccl_sell = rates.ccl.value_sell;
        }
      }

      if (evo && evo.length > 0) {
        var bySource = {};
        for (var i = 0; i < evo.length; i++) {
          var key = evo[i].source.toLowerCase();
          if (!bySource[key]) bySource[key] = [];
          bySource[key].push(evo[i]);
        }
        ['oficial', 'blue'].forEach(function(src) {
          var arr = bySource[src];
          if (arr && arr.length > 1) {
            arr.sort(function(a, b) { return a.date < b.date ? 1 : -1; });
            data[src + 'Pct'] = pct(arr[0].value_sell, arr[1].value_sell);
          }
        });
      }
      data.mepPct = null;
      data.cclPct = null;

      if (merval) {
        data.merval_price = merval.price;
        data.merval_high = merval.high;
        data.merval_low = merval.low;
        data.merval_prev = merval.previousClose;
        data.merval_vol = merval.volume;
        data.mervalPct = merval.variation != null
          ? merval.variation * 100
          : pct(merval.price, merval.previousClose);
      }

      if (equity && equity.data && equity.data.length > 0) {
        var stocks = equity.data.slice();
        stocks.sort(function(a, b) { return Math.abs(b.variation || 0) - Math.abs(a.variation || 0); });
        data.stocks = stocks.slice(0, 5).map(function(s) {
          return { symbol: s.symbol, price: s.price, variation: (s.variation || 0) * 100 };
        });
      }

      render(data);
      saveCache(data);
    }).catch(function() {});
  }

  var cached = loadCached();
  if (cached) render(cached);
  fetchAll();
  setInterval(fetchAll, REFRESH_MS);
  document.addEventListener('visibilitychange', function() { if (!document.hidden) fetchAll(); });
  window.addEventListener('focus', fetchAll);
})();
</script>

<style>
  .fd {
    margin-bottom: var(--spacing-2xl);
  }

  /* ── Market Cards Strip ── */
  .fd-strip {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 2px;
    margin-bottom: 16px;
  }

  .fd-strip::-webkit-scrollbar {
    display: none;
  }

  .fd-card {
    flex: 1 0 0;
    min-width: 160px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 16px;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .fd-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-border);
    transition: background 0.2s;
  }

  .fd-card--positive::before {
    background: #16a34a;
  }

  .fd-card--negative::before {
    background: #dc2626;
  }

  :global([data-theme="dark"]) .fd-card--positive::before {
    background: #4ade80;
  }

  :global([data-theme="dark"]) .fd-card--negative::before {
    background: #f87171;
  }

  .fd-card:hover {
    border-color: var(--color-text-meta);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    color: var(--color-text);
  }

  :global([data-theme="dark"]) .fd-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .fd-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .fd-card-name {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-meta);
  }

  .fd-card--blue .fd-card-name {
    color: var(--color-gold);
  }

  .fd-card--merval .fd-card-name {
    color: #60a5fa;
  }

  .fd-card-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .fd-card-badge.fd-up {
    color: #16a34a;
    background: rgba(22, 163, 74, 0.08);
  }

  .fd-card-badge.fd-down {
    color: #dc2626;
    background: rgba(220, 38, 38, 0.08);
  }

  :global([data-theme="dark"]) .fd-card-badge.fd-up {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
  }

  :global([data-theme="dark"]) .fd-card-badge.fd-down {
    color: #f87171;
    background: rgba(248, 113, 113, 0.12);
  }

  .fd-card-price {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    margin-bottom: 8px;
  }

  .fd-card-sub {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--color-border);
    padding-top: 8px;
  }

  .fd-card-meta {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-meta);
  }

  .fd-card-meta-val {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  /* ── Top Movers ── */
  .fd-movers {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .fd-movers-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .fd-movers-title {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-meta);
  }

  .fd-movers-link {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-meta);
    text-decoration: none;
  }

  .fd-movers-link:hover {
    color: var(--color-gold-dark);
  }

  .fd-movers-table {
    display: flex;
    flex-direction: column;
  }

  .fd-movers-table :global(.fd-mover-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border);
    font-variant-numeric: tabular-nums;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.12s;
  }

  .fd-movers-table :global(.fd-mover-row:last-child) {
    border-bottom: none;
  }

  .fd-movers-table :global(.fd-mover-row:hover) {
    background: var(--color-bg-secondary);
    text-decoration: none;
    color: var(--color-text);
  }

  .fd-movers-table :global(.fd-mover-rank) {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-text-meta);
    width: 18px;
    text-align: center;
  }

  .fd-movers-table :global(.fd-mover-sym) {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--color-text);
    min-width: 56px;
  }

  .fd-movers-table :global(.fd-mover-price) {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    flex: 1;
    text-align: right;
  }

  .fd-movers-table :global(.fd-mover-chg) {
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 64px;
    text-align: right;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .fd-movers-table :global(.fd-up) {
    color: #16a34a;
    background: rgba(22, 163, 74, 0.08);
  }

  .fd-movers-table :global(.fd-down) {
    color: #dc2626;
    background: rgba(220, 38, 38, 0.08);
  }

  :global([data-theme="dark"]) .fd-movers-table :global(.fd-up) {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
  }

  :global([data-theme="dark"]) .fd-movers-table :global(.fd-down) {
    color: #f87171;
    background: rgba(248, 113, 113, 0.12);
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .fd-strip {
      gap: 10px;
    }

    .fd-card {
      min-width: 140px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .fd-strip {
      gap: 8px;
      margin-left: calc(-1 * var(--spacing-md));
      margin-right: calc(-1 * var(--spacing-md));
      padding-left: var(--spacing-md);
      padding-right: var(--spacing-md);
    }

    .fd-card {
      min-width: 130px;
      flex: 0 0 auto;
      padding: 12px;
    }

    .fd-card-name {
      font-size: 0.75rem;
    }

    .fd-card-price {
      font-size: 1.25rem;
    }

    .fd-card-badge {
      font-size: 0.75rem;
    }

    .fd-card-meta {
      font-size: 0.72rem;
    }

    .fd-card-meta-val {
      font-size: 0.82rem;
    }

    .fd-movers-title {
      font-size: 0.78rem;
    }

    .fd-movers-link {
      font-size: 0.78rem;
    }
  }
</style>
