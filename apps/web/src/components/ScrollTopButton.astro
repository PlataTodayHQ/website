---
/**
 * Scroll-to-top button with built-in show/hide behavior.
 * CSS lives in global.css (.scroll-top-btn, .scroll-top-btn--visible).
 * Used by: all market pages.
 */
interface Props {
  /** aria-label / title text. Defaults to "↑" */
  label?: string;
  /** Scroll threshold in px before button appears. Defaults to 600 */
  threshold?: number;
}

const { label = '↑', threshold = 600 } = Astro.props;
---

<button class="scroll-top-btn" data-scroll-top data-scroll-threshold={threshold} aria-label={label} title={label}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
</button>

<script is:inline>
(function() {
  var btn = document.querySelector('[data-scroll-top]');
  if (!btn) return;
  var threshold = parseInt(btn.getAttribute('data-scroll-threshold') || '600', 10);
  var visible = false;
  window.addEventListener('scroll', function() {
    var show = window.scrollY > threshold;
    if (show !== visible) {
      visible = show;
      btn.classList.toggle('scroll-top-btn--visible', show);
    }
  }, { passive: true });
  btn.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>
