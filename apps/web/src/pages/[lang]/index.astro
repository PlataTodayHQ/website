---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TrendingSection from "@/components/TrendingSection.astro";
import JustInFeed from "@/components/JustInFeed.astro";
import NewsletterBanner from "@/components/NewsletterBanner.astro";
import { LANGUAGES, CATEGORIES } from "@plata-today/shared";
import { t } from "@/i18n";
import type { Category } from "@plata-today/shared";
import {
  getArticlesByLang,
  timeAgo,
  readingTime,
  type ArticleRow,
} from "@/lib/db";

export const prerender = false;

const { lang } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/");
}

const langName = LANGUAGES[lang as keyof typeof LANGUAGES]?.name ?? lang;

// ---------------------------------------------------------------------------
// Fetch articles from SQLite (server-rendered)
// ---------------------------------------------------------------------------
const allArticles = getArticlesByLang(lang!, 50);

function catLabel(cat: string) {
  return t(lang!, `cat.${cat}` as any) || CATEGORIES[cat as Category] || cat;
}

function mapRow(a: ArticleRow) {
  return {
    title: a.title,
    description: a.meta_description ?? "",
    href: `/${lang}/news/${a.slug}`,
    imageUrl:
      a.image_url ??
      `https://placehold.co/800x450/1e2a3d/e8e6e3?text=${encodeURIComponent(CATEGORIES[a.category as Category] ?? a.category)}`,
    timeAgo: timeAgo(a.published_at),
    subcategory: catLabel(a.category),
    readingTime: readingTime(a.word_count),
  };
}

const byImportance = [...allArticles].sort(
  (a, b) => b.importance_score - a.importance_score,
);

const byCat = (cat: string) =>
  allArticles.filter((a) => a.category === cat).map(mapRow);

// Hero — most important article
const heroRow = byImportance[0];
const heroArticle = heroRow
  ? mapRow(heroRow)
  : {
      title: t(lang!, "home.heroFallbackTitle"),
      description: t(lang!, "home.heroFallbackDesc"),
      href: `/${lang}/`,
      imageUrl:
        "https://placehold.co/1200x600/1e2a3d/e8e6e3?text=Plata+Today",
      timeAgo: "",
      subcategory: "",
      readingTime: "",
    };

const relatedLinks = byImportance.slice(1, 4).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
}));

// Trending — top 5 by importance
const trendingItems = byImportance.slice(0, 5).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  category: catLabel(a.category),
  timeAgo: timeAgo(a.published_at),
}));

// Just In — latest 10 (allArticles already sorted by published_at DESC)
const justInItems = allArticles.slice(0, 10).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  timeAgo: timeAgo(a.published_at),
}));

// Top Stories — 6 items
const topStories = allArticles.slice(0, 6).map(mapRow);

// Economy & Business
const econAll = byCat("economy");
const econFeatured = econAll[0] ?? null;
const econSidebar = econAll.slice(1, 5);

// Sports
const sportsAll = byCat("sports");
const sportsFeatured = sportsAll[0] ?? null;
const sportsSidebar = sportsAll.slice(1, 5);

// Culture & Society
const cultureSociety = [...byCat("culture"), ...byCat("society")].slice(0, 4);

// World
const worldNews = byCat("world").slice(0, 4);

// Science & Tech
const scienceTech = byCat("science").slice(0, 4);

// More News — remaining articles
const moreNews = allArticles.slice(6, 14).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  timeAgo: timeAgo(a.published_at),
  subcategory: catLabel(a.category),
}));
---

<Base
  title={t(lang!, "home.title").replace("{lang}", langName)}
  lang={lang}
  ogType="website"
  ogImage="https://placehold.co/1200x630/3D6B99/ffffff?text=Plata+News"
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
  ]}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today",
      "description": t(lang!, "common.siteDescription"),
      "inLanguage": lang,
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://plata.today/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Plata",
      "url": "https://plata.today",
      "logo": "https://plata.today/logo.png"
    }
  ]}
>
  <!-- HERO -->
  <section class="hero" aria-label={t(lang!, "home.featuredStory")}>
    <a href={heroArticle.href} class="hero-link">
      <div class="hero-image">
        <img src={heroArticle.imageUrl} alt={heroArticle.title} loading="eager" />
      </div>
      <div class="hero-body">
        <h1 class="hero-title">{heroArticle.title}</h1>
        <p class="hero-desc">{heroArticle.description}</p>
        <div class="meta">
          {heroArticle.timeAgo && <span class="meta-time">{heroArticle.timeAgo}</span>}
          {heroArticle.subcategory && <span class="meta-dot"></span>}
          {heroArticle.subcategory && <span class="meta-sub">{heroArticle.subcategory}</span>}
          {heroArticle.readingTime && <span class="meta-dot"></span>}
          {heroArticle.readingTime && <span class="meta-reading">{heroArticle.readingTime}</span>}
        </div>
      </div>
    </a>
    {relatedLinks.length > 0 && (
      <ul class="hero-related">
        {relatedLinks.map((link) => (
          <li>
            <a href={link.href} class="hero-related-link">{link.title}</a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- TRENDING -->
  {trendingItems.length > 0 && <TrendingSection items={trendingItems} lang={lang} />}

  <!-- JUST IN -->
  {justInItems.length > 0 && <JustInFeed items={justInItems} lang={lang} />}

  <!-- TOP STORIES -->
  {topStories.length > 0 && <SectionHeader title={t(lang!, "home.topStories")} />}
  {topStories.length > 0 && (
    <section class="top-stories" aria-label={t(lang!, "home.topStories")}>
      {topStories.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          readingTime={a.readingTime}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- ECONOMY & BUSINESS -->
  {econAll.length > 0 && <SectionHeader title={t(lang!, "home.economyBusiness")} href={`/${lang}/category/economy`} />}
  {econAll.length > 0 && (
    <section class="topic-section" aria-label={t(lang!, "home.economyBusiness")}>
      {econFeatured && (
        <div class="topic-featured">
          <ArticleCard
            title={econFeatured.title}
            description={econFeatured.description}
            href={econFeatured.href}
            imageUrl={econFeatured.imageUrl}
            timeAgo={econFeatured.timeAgo}
            category={econFeatured.subcategory}
            readingTime={econFeatured.readingTime}
          />
        </div>
      )}
      <aside class="topic-sidebar">
        {econSidebar.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            timeAgo={a.timeAgo}
            category={a.subcategory}
            readingTime={a.readingTime}
            variant="sidebar"
          />
        ))}
      </aside>
    </section>
  )}

  <!-- SPORTS -->
  {sportsAll.length > 0 && <SectionHeader title={t(lang!, "cat.sports")} href={`/${lang}/category/sports`} />}
  {sportsAll.length > 0 && (
    <section class="topic-section" aria-label={t(lang!, "cat.sports")}>
      {sportsFeatured && (
        <div class="topic-featured">
          <ArticleCard
            title={sportsFeatured.title}
            description={sportsFeatured.description}
            href={sportsFeatured.href}
            imageUrl={sportsFeatured.imageUrl}
            timeAgo={sportsFeatured.timeAgo}
            category={sportsFeatured.subcategory}
            readingTime={sportsFeatured.readingTime}
          />
        </div>
      )}
      <aside class="topic-sidebar">
        {sportsSidebar.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            timeAgo={a.timeAgo}
            category={a.subcategory}
            readingTime={a.readingTime}
            variant="sidebar"
          />
        ))}
      </aside>
    </section>
  )}

  <!-- NEWSLETTER BANNER -->
  <NewsletterBanner lang={lang} />

  <!-- CULTURE & SOCIETY -->
  {cultureSociety.length > 0 && <SectionHeader title={t(lang!, "home.cultureSociety")} href={`/${lang}/category/culture`} />}
  {cultureSociety.length > 0 && (
    <section class="compact-grid" aria-label={t(lang!, "home.cultureSociety")}>
      {cultureSociety.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          readingTime={a.readingTime}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- WORLD -->
  {worldNews.length > 0 && <SectionHeader title={t(lang!, "cat.world")} href={`/${lang}/category/world`} />}
  {worldNews.length > 0 && (
    <section class="compact-grid" aria-label={t(lang!, "cat.world")}>
      {worldNews.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          readingTime={a.readingTime}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- SCIENCE & TECH -->
  {scienceTech.length > 0 && <SectionHeader title={t(lang!, "cat.science")} href={`/${lang}/category/science`} />}
  {scienceTech.length > 0 && (
    <section class="sidebar-list" aria-label={t(lang!, "cat.science")}>
      {scienceTech.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          variant="sidebar"
        />
      ))}
    </section>
  )}

  <!-- MORE NEWS -->
  {moreNews.length > 0 && <SectionHeader title={t(lang!, "home.moreNews")} />}
  {moreNews.length > 0 && (
    <section class="more-news" aria-label={t(lang!, "home.moreNews")}>
      {moreNews.map((a) => (
        <div class="mn-item">
          <a href={a.href} class="mn-link">
            <h3 class="mn-title">{a.title}</h3>
          </a>
          <div class="meta">
            <span class="meta-time">{a.timeAgo}</span>
            <span class="meta-dot"></span>
            <span class="meta-sub">{a.subcategory}</span>
          </div>
        </div>
      ))}
    </section>
  )}
</Base>

<style>
  /* ====================== */
  /* SHARED META            */
  /* ====================== */
  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--color-text-meta);
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-meta);
    flex-shrink: 0;
  }

  .meta-sub {
    color: var(--color-gold-dark);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .meta-reading {
    font-size: 0.7rem;
  }

  /* ====================== */
  /* HERO                   */
  /* ====================== */
  .hero {
    margin-bottom: var(--spacing-xl);
  }

  .hero-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .hero-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .hero-link:hover .hero-title {
    text-decoration: underline;
  }

  .hero-image {
    overflow: hidden;
    margin-bottom: 20px;
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .hero-link:hover .hero-image img {
    transform: scale(1.02);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
    max-width: var(--content-width);
  }

  .hero-related {
    list-style: none;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-related li {
    padding-left: 18px;
    position: relative;
  }

  .hero-related li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .hero-related-link {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .hero-related-link:hover {
    text-decoration: underline;
    color: var(--color-link-hover);
  }

  /* ====================== */
  /* TOP STORIES            */
  /* ====================== */
  .top-stories {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: var(--spacing-2xl);
  }

  .top-stories :global(.card--compact) {
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .top-stories :global(.card--compact:nth-child(odd)) {
    padding-right: var(--spacing-xl);
    border-right: 1px solid var(--color-border);
  }

  .top-stories :global(.card--compact:nth-child(even)) {
    padding-left: var(--spacing-xl);
  }

  .top-stories :global(.card--compact:nth-last-child(-n+2)) {
    border-bottom: none;
  }

  /* ========================= */
  /* TOPIC SECTIONS            */
  /* (Economy, Sports, etc.)   */
  /* ========================= */
  .topic-section {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
  }

  .topic-sidebar {
    border-left: 1px solid var(--color-border);
    padding-left: var(--spacing-2xl);
  }

  /* ========================= */
  /* COMPACT GRID              */
  /* (Culture, World)          */
  /* ========================= */
  .compact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: var(--spacing-2xl);
  }

  .compact-grid :global(.card--compact) {
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .compact-grid :global(.card--compact:nth-child(odd)) {
    padding-right: var(--spacing-xl);
    border-right: 1px solid var(--color-border);
  }

  .compact-grid :global(.card--compact:nth-child(even)) {
    padding-left: var(--spacing-xl);
  }

  .compact-grid :global(.card--compact:nth-last-child(-n+2)) {
    border-bottom: none;
  }

  /* ========================= */
  /* SIDEBAR LIST              */
  /* (Science & Tech)          */
  /* ========================= */
  .sidebar-list {
    max-width: var(--content-width);
    margin-bottom: var(--spacing-2xl);
  }

  /* ========================= */
  /* MORE NEWS — single col    */
  /* ========================= */
  .more-news {
    max-width: var(--content-width);
    margin-bottom: var(--spacing-2xl);
  }

  .mn-item {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .mn-item:first-child {
    padding-top: 0;
  }

  .mn-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .mn-link {
    color: var(--color-text);
  }

  .mn-link:hover {
    text-decoration: none;
  }

  .mn-link:hover .mn-title {
    text-decoration: underline;
  }

  .mn-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  /* ========================= */
  /* TABLET                    */
  /* ========================= */
  @media (max-width: 1024px) {
    .hero-title {
      font-size: 1.75rem;
    }

    .topic-section {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-xl);
    }

    .topic-sidebar {
      padding-left: var(--spacing-xl);
    }
  }

  /* ========================= */
  /* MOBILE                    */
  /* ========================= */
  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.4rem;
    }

    .hero-image img {
      aspect-ratio: 16 / 10;
    }

    .hero-desc {
      font-size: 0.9rem;
    }

    .top-stories,
    .compact-grid {
      grid-template-columns: 1fr;
    }

    .top-stories :global(.card--compact),
    .compact-grid :global(.card--compact) {
      padding: 16px 0;
      border-bottom: 1px solid var(--color-border);
    }

    .top-stories :global(.card--compact:nth-child(odd)),
    .compact-grid :global(.card--compact:nth-child(odd)) {
      padding-right: 0;
      border-right: none;
    }

    .top-stories :global(.card--compact:nth-child(even)),
    .compact-grid :global(.card--compact:nth-child(even)) {
      padding-left: 0;
    }

    .top-stories :global(.card--compact:last-child),
    .compact-grid :global(.card--compact:last-child) {
      border-bottom: none;
    }

    .topic-section {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .topic-sidebar {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--color-border);
      padding-top: var(--spacing-lg);
    }
  }
</style>
