---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TrendingSection from "@/components/TrendingSection.astro";
import JustInFeed from "@/components/JustInFeed.astro";
import NewsletterBanner from "@/components/NewsletterBanner.astro";
import FinancialDashboard from "@/components/FinancialDashboard.astro";
import { LANGUAGES, CATEGORIES, CATEGORY_LIST } from "@plata-today/shared";
import { t } from "@/i18n";
import type { Category } from "@plata-today/shared";
import {
  getArticlesByLang,
  timeAgo,
  readingTime,
  type ArticleRow,
} from "@/lib/db";

export const prerender = false;

const { lang } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const langName = LANGUAGES[lang as keyof typeof LANGUAGES]?.name ?? lang;

// ---------------------------------------------------------------------------
// Fetch articles from SQLite (server-rendered)
// ---------------------------------------------------------------------------
const allArticles = getArticlesByLang(lang!, 50);

function catLabel(cat: string) {
  return t(lang!, `cat.${cat}` as any) || CATEGORIES[cat as Category] || cat;
}

const parseSources = (raw: string): string[] => {
  try { return JSON.parse(raw) as string[]; }
  catch { return []; }
};

function mapRow(a: ArticleRow) {
  const ageHours = (Date.now() - new Date(a.published_at).getTime()) / 3600000;
  const sources = parseSources(a.source_names);
  return {
    title: a.title,
    description: a.meta_description ?? "",
    href: `/${lang}/news/${a.slug}`,
    imageUrl: a.image_url ?? "/images/placeholder.svg",
    timeAgo: timeAgo(a.published_at, lang!),
    subcategory: catLabel(a.category),
    category: a.category,
    readingTime: readingTime(a.word_count, lang!),
    isNew: ageHours < 2,
    sourceLabel: sources.length > 0 ? sources.slice(0, 2).join(", ") : undefined,
  };
}

// Trending score: importance weighted by recency (exponential decay, half-life 12h)
const trendingScore = (a: ArticleRow): number => {
  const ageHours = (Date.now() - new Date(a.published_at).getTime()) / 3600000;
  const recency = Math.exp(-ageHours / 18);
  return a.importance_score * (0.1 + 0.9 * recency);
};

const byImportance = [...allArticles].sort(
  (a, b) => trendingScore(b) - trendingScore(a),
);

// ---------------------------------------------------------------------------
// Global deduplication: each article appears at most once on the homepage
// ---------------------------------------------------------------------------
const usedSlugs = new Set<string>();

const claim = (articles: ArticleRow[], count: number): ArticleRow[] => {
  const result: ArticleRow[] = [];
  for (const a of articles) {
    if (result.length >= count) break;
    if (usedSlugs.has(a.slug)) continue;
    result.push(a);
    usedSlugs.add(a.slug);
  }
  return result;
};

const claimByCat = (cat: string, count: number) => {
  const catArticles = allArticles
    .filter((a) => a.category === cat && !usedSlugs.has(a.slug))
    .sort((a, b) => trendingScore(b) - trendingScore(a));
  return claim(catArticles, count).map(mapRow);
};

// Hero — most important article
const [heroRow] = claim(byImportance, 1);
const heroArticle = heroRow
  ? mapRow(heroRow)
  : {
      title: t(lang!, "home.heroFallbackTitle"),
      description: t(lang!, "home.heroFallbackDesc"),
      href: `/${lang}/`,
      imageUrl: "/images/placeholder.svg",
      timeAgo: "",
      subcategory: "",
      category: "",
      readingTime: "",
      isNew: false,
      sourceLabel: undefined as string | undefined,
    };

// Trending — top 5 from remaining by trendingScore
const trendingItems = claim(byImportance, 5).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  category: catLabel(a.category),
  timeAgo: timeAgo(a.published_at, lang!),
}));

// Politics
const politicsAll = claimByCat("politics", 4);

// Just In — 8 latest, deduplicated
const justInItems = claim([...allArticles], 8).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  timeAgo: timeAgo(a.published_at, lang!),
  category: catLabel(a.category),
}));

// Economy & Business
const econAll = claimByCat("economy", 4);

// Sports
const sportsAll = claimByCat("sports", 4);

// World
const worldNews = claimByCat("world", 4);

// Culture & Society (combined)
const cultureSociety = [...claimByCat("culture", 2), ...claimByCat("society", 2)];

// Science & Tech
const scienceTech = claimByCat("science", 4);

// More News — remaining articles with images
const moreNews = claim(allArticles, 8).map(mapRow);
---

<Base
  title={t(lang!, "home.title").replace("{lang}", langName)}
  description={t(lang!, "home.description").replace("{lang}", langName)}
  lang={lang}
  ogType="website"
  ogImage={`${import.meta.env.SITE ?? "https://plata.today"}/images/placeholder.svg`}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
  ]}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today",
      "description": t(lang!, "common.siteDescription"),
      "inLanguage": lang,
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Plata",
      "url": "https://plata.today",
      "logo": "https://plata.today/logo.svg"
    }
  ]}
>
  <!-- HERO -->
  <section class="hero-section" aria-label={t(lang!, "home.featuredStory")}>
    <ArticleCard
      title={heroArticle.title}
      description={heroArticle.description}
      href={heroArticle.href}
      imageUrl={heroArticle.imageUrl}
      timeAgo={heroArticle.timeAgo}
      category={heroArticle.subcategory}
      categoryKey={heroArticle.category}
      readingTime={heroArticle.readingTime}
      isNew={heroArticle.isNew}
      sourceLabel={heroArticle.sourceLabel}
      variant="hero"
    />
  </section>

  <!-- TRENDING -->
  {trendingItems.length > 0 && <TrendingSection items={trendingItems} lang={lang} />}

  <!-- POLITICS -->
  {politicsAll.length > 0 && <SectionHeader title={t(lang!, "home.politics")} href={`/${lang}/category/politics`} accentColor="var(--cat-politics)" />}
  {politicsAll.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "home.politics")}>
      {politicsAll.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- JUST IN -->
  {justInItems.length > 0 && <JustInFeed items={justInItems} lang={lang} />}

  <!-- ECONOMY & BUSINESS -->
  {econAll.length > 0 && <SectionHeader title={t(lang!, "home.economyBusiness")} href={`/${lang}/category/economy`} accentColor="var(--cat-economy)" />}
  {econAll.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "home.economyBusiness")}>
      {econAll.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- FINANCIAL DASHBOARD -->
  <SectionHeader title={t(lang!, "finDash.title" as any)} href={`/${lang}/markets`} accentColor="var(--cat-economy)" />
  <FinancialDashboard lang={lang} />

  <!-- SPORTS -->
  {sportsAll.length > 0 && <SectionHeader title={t(lang!, "cat.sports")} href={`/${lang}/category/sports`} accentColor="var(--cat-sports)" />}
  {sportsAll.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "cat.sports")}>
      {sportsAll.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- NEWSLETTER BANNER -->
  <NewsletterBanner lang={lang} />

  <!-- WORLD -->
  {worldNews.length > 0 && <SectionHeader title={t(lang!, "cat.world")} href={`/${lang}/category/world`} accentColor="var(--cat-world)" />}
  {worldNews.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "cat.world")}>
      {worldNews.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- CULTURE & SOCIETY -->
  {cultureSociety.length > 0 && <SectionHeader title={t(lang!, "home.cultureSociety")} href={`/${lang}/category/culture`} accentColor="var(--cat-culture)" />}
  {cultureSociety.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "home.cultureSociety")}>
      {cultureSociety.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- SCIENCE & TECH -->
  {scienceTech.length > 0 && <SectionHeader title={t(lang!, "cat.science")} href={`/${lang}/category/science`} accentColor="var(--cat-science)" />}
  {scienceTech.length > 0 && (
    <section class="feed-grid" aria-label={t(lang!, "cat.science")}>
      {scienceTech.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          sourceLabel={a.sourceLabel}
        />
      ))}
    </section>
  )}

  <!-- MORE NEWS -->
  <SectionHeader title={t(lang!, "home.moreNews")} />
  <section class="feed-grid" id="more-news-grid" aria-label={t(lang!, "home.moreNews")}>
    {moreNews.map((a) => (
      <ArticleCard
        title={a.title}
        description={a.description}
        href={a.href}
        imageUrl={a.imageUrl}
        timeAgo={a.timeAgo}
        category={a.subcategory}
        categoryKey={a.category}
        readingTime={a.readingTime}
        isNew={a.isNew}
        sourceLabel={a.sourceLabel}
      />
    ))}
  </section>

  <!-- LOAD MORE -->
  <div id="load-more-container">
    <button class="load-more-btn" id="load-more-btn" type="button">
      {t(lang!, "home.loadMore" as any)}
    </button>
    <p class="load-more-end" id="load-more-end" hidden>
      {t(lang!, "home.noMoreArticles" as any)}
    </p>
  </div>
</Base>

<script is:inline define:vars={{
  initialSlugs: Array.from(usedSlugs),
  lang,
  initialOffset: allArticles.length,
  loadMoreLabel: t(lang!, "home.loadMore" as any),
  catLabels: Object.fromEntries(
    CATEGORY_LIST.map((c: string) => [c, t(lang!, `cat.${c}` as any)])
  )
}}>
(function() {
  var btn = document.getElementById('load-more-btn');
  var endMsg = document.getElementById('load-more-end');
  var grid = document.getElementById('more-news-grid');
  if (!btn || !grid) return;

  var offset = initialOffset;
  var LIMIT = 12;
  var seenSlugs = new Set(initialSlugs);
  var loading = false;

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function createCard(a) {
    var article = document.createElement('article');
    article.className = 'card card--default';
    if (a.category) {
      article.style.setProperty('--cat-color', 'var(--cat-' + a.category + ', var(--color-gold-dark))');
    }

    var catLabel = catLabels[a.category] || a.category;
    var html = '<a href="' + escapeHtml(a.href) + '" class="card-link">';
    if (catLabel) {
      html += '<div class="card-header"><span class="card-category">' + escapeHtml(catLabel) + '</span></div>';
    }
    if (a.imageUrl) {
      html += '<div class="card-image"><img src="' + escapeHtml(a.imageUrl) + '" alt="' + escapeHtml(a.title) + '" loading="lazy" /></div>';
    }
    html += '<div class="card-body">';
    html += '<h3 class="card-title">' + escapeHtml(a.title) + '</h3>';
    html += '<div class="card-meta">';
    if (a.timeAgo) html += '<time class="card-time">' + escapeHtml(a.timeAgo) + '</time>';
    if (a.readingTime) html += '<span class="card-divider" aria-hidden="true">&middot;</span><span class="card-reading-time">' + escapeHtml(a.readingTime) + '</span>';
    html += '</div></div></a>';

    article.innerHTML = html;
    return article;
  }

  function loadMore() {
    if (loading) return;
    loading = true;
    btn.textContent = '...';
    btn.disabled = true;

    fetch('/api/feed?lang=' + encodeURIComponent(lang) + '&offset=' + offset + '&limit=' + LIMIT)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var articles = data.articles.filter(function(a) {
          return !seenSlugs.has(a.slug);
        });

        articles.forEach(function(a) {
          seenSlugs.add(a.slug);
          grid.appendChild(createCard(a));
        });

        offset += LIMIT;

        if (!data.hasMore || articles.length === 0) {
          btn.hidden = true;
          if (endMsg) endMsg.hidden = false;
        } else {
          btn.textContent = loadMoreLabel;
          btn.disabled = false;
        }
        loading = false;
      })
      .catch(function() {
        btn.textContent = loadMoreLabel;
        btn.disabled = false;
        loading = false;
      });
  }

  btn.addEventListener('click', loadMore);
})();
</script>

<style>
  /* ====================== */
  /* HERO SECTION            */
  /* ====================== */
  .hero-section {
    margin-bottom: var(--spacing-xl);
  }

  /* ========================= */
  /* FEED GRID (Instagram)     */
  /* ========================= */
  .feed-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: var(--spacing-2xl);
  }

  /* ========================= */
  /* MOBILE                    */
  /* ========================= */
  @media (max-width: 640px) {
    .feed-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  /* ========================= */
  /* LARGE DESKTOP — 3 cols    */
  /* ========================= */
  @media (min-width: 1025px) {
    .feed-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ========================= */
  /* LOAD MORE                 */
  /* ========================= */
  #load-more-container {
    text-align: center;
    padding: var(--spacing-xl) 0;
    margin-bottom: var(--spacing-2xl);
  }

  .load-more-btn[hidden] {
    display: none;
  }

  .load-more-btn {
    display: inline-block;
    padding: 14px 48px;
    font-size: 0.9rem;
    font-weight: 700;
    font-family: var(--font-sans);
    background: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
    border-radius: 24px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .load-more-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold-dark);
    background: rgba(246, 180, 14, 0.06);
  }

  .load-more-btn:disabled {
    opacity: 0.5;
    cursor: wait;
  }

  .load-more-end {
    font-size: 0.85rem;
    color: var(--color-text-meta);
    font-style: italic;
  }

  /* ========================= */
  /* DYNAMIC CARD STYLES       */
  /* (for JS-appended cards)   */
  /* ========================= */
  #more-news-grid :global(.card) {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  #more-news-grid :global(.card:hover) {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  #more-news-grid :global(.card-link) {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  #more-news-grid :global(.card-link:hover) {
    text-decoration: none;
    color: inherit;
  }

  #more-news-grid :global(.card-header) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
  }

  #more-news-grid :global(.card-category) {
    color: var(--cat-color, var(--color-gold-dark));
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  #more-news-grid :global(.card-image) {
    overflow: hidden;
  }

  #more-news-grid :global(.card-image img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  #more-news-grid :global(.card-link:hover .card-image img) {
    transform: scale(1.03);
  }

  #more-news-grid :global(.card-body) {
    padding: 14px 16px 16px;
  }

  #more-news-grid :global(.card-title) {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 6px;
    color: var(--color-text);
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #more-news-grid :global(.card-meta) {
    font-size: 0.75rem;
    color: var(--color-text-meta);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  #more-news-grid :global(.card-divider) {
    color: var(--color-border);
  }

  #more-news-grid :global(.card-reading-time) {
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  @media (max-width: 640px) {
    #more-news-grid :global(.card) {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
  }
</style>
