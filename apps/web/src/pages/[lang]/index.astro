---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TrendingSection from "@/components/TrendingSection.astro";
import JustInFeed from "@/components/JustInFeed.astro";
import NewsletterBanner from "@/components/NewsletterBanner.astro";
import FinancialDashboard from "@/components/FinancialDashboard.astro";
import { LANGUAGES, CATEGORIES, CATEGORY_LIST } from "@plata-today/shared";
import { t } from "@/i18n";
import type { Category } from "@plata-today/shared";
import {
  getArticlesByLang,
  timeAgo,
  readingTime,
  type ArticleRow,
} from "@/lib/db";

export const prerender = false;

const { lang } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const langName = LANGUAGES[lang as keyof typeof LANGUAGES]?.name ?? lang;

// ---------------------------------------------------------------------------
// Fetch articles from SQLite (server-rendered)
// ---------------------------------------------------------------------------
const allArticles = getArticlesByLang(lang!, 50);

function catLabel(cat: string) {
  return t(lang!, `cat.${cat}` as any) || CATEGORIES[cat as Category] || cat;
}

const parseSources = (raw: string): string[] => {
  try { return JSON.parse(raw) as string[]; }
  catch { return []; }
};

function mapRow(a: ArticleRow) {
  const ageHours = (Date.now() - new Date(a.published_at).getTime()) / 3600000;
  const sources = parseSources(a.source_names);
  return {
    title: a.title,
    description: a.meta_description ?? "",
    href: `/${lang}/news/${a.slug}`,
    imageUrl: a.image_url ?? "/images/placeholder.svg",
    timeAgo: timeAgo(a.published_at, lang!),
    subcategory: catLabel(a.category),
    category: a.category,
    readingTime: readingTime(a.word_count, lang!),
    isNew: ageHours < 2,
    sourceLabel: sources.length > 0 ? sources.slice(0, 2).join(", ") : undefined,
  };
}

// Trending score: importance weighted by recency (exponential decay, half-life 12h)
const trendingScore = (a: ArticleRow): number => {
  const ageHours = (Date.now() - new Date(a.published_at).getTime()) / 3600000;
  const recency = Math.exp(-ageHours / 18);
  return a.importance_score * (0.1 + 0.9 * recency);
};

const byImportance = [...allArticles].sort(
  (a, b) => trendingScore(b) - trendingScore(a),
);

// ---------------------------------------------------------------------------
// Global deduplication: each article appears at most once on the homepage
// ---------------------------------------------------------------------------
const usedSlugs = new Set<string>();

const claim = (articles: ArticleRow[], count: number): ArticleRow[] => {
  const result: ArticleRow[] = [];
  for (const a of articles) {
    if (result.length >= count) break;
    if (usedSlugs.has(a.slug)) continue;
    result.push(a);
    usedSlugs.add(a.slug);
  }
  return result;
};

const claimByCat = (cat: string, count: number) => {
  const catArticles = allArticles
    .filter((a) => a.category === cat && !usedSlugs.has(a.slug))
    .sort((a, b) => trendingScore(b) - trendingScore(a));
  return claim(catArticles, count).map(mapRow);
};

// Hero — most important article
const [heroRow] = claim(byImportance, 1);
const heroArticle = heroRow
  ? mapRow(heroRow)
  : {
      title: t(lang!, "home.heroFallbackTitle"),
      description: t(lang!, "home.heroFallbackDesc"),
      href: `/${lang}/`,
      imageUrl: "/images/placeholder.svg",
      timeAgo: "",
      subcategory: "",
      category: "",
      readingTime: "",
      isNew: false,
      sourceLabel: undefined as string | undefined,
    };

// Related links (3) with category labels
const relatedArticles = claim(byImportance, 3);
const relatedLinks = relatedArticles.map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  category: catLabel(a.category),
  categoryKey: a.category,
}));

// Trending — top 5 from remaining by trendingScore
const trendingItems = claim(byImportance, 5).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  category: catLabel(a.category),
  timeAgo: timeAgo(a.published_at, lang!),
}));

// Politics
const politicsAll = claimByCat("politics", 5);
const politicsFeatured = politicsAll[0] ?? null;
const politicsSidebar = politicsAll.slice(1, 5);

// Just In — 8 latest, deduplicated
const justInItems = claim([...allArticles], 8).map((a) => ({
  title: a.title,
  href: `/${lang}/news/${a.slug}`,
  timeAgo: timeAgo(a.published_at, lang!),
  category: catLabel(a.category),
}));

// Economy & Business
const econAll = claimByCat("economy", 5);
const econFeatured = econAll[0] ?? null;
const econSidebar = econAll.slice(1, 5);

// Sports
const sportsAll = claimByCat("sports", 5);
const sportsFeatured = sportsAll[0] ?? null;
const sportsSidebar = sportsAll.slice(1, 5);

// World
const worldNews = claimByCat("world", 4);

// Culture & Society (combined)
const cultureSociety = [...claimByCat("culture", 2), ...claimByCat("society", 2)];

// Science & Tech
const scienceTech = claimByCat("science", 4);

// More News — remaining articles with images
const moreNews = claim(allArticles, 8).map(mapRow);
---

<Base
  title={t(lang!, "home.title").replace("{lang}", langName)}
  description={t(lang!, "home.description").replace("{lang}", langName)}
  lang={lang}
  ogType="website"
  ogImage={`${import.meta.env.SITE ?? "https://plata.today"}/images/placeholder.svg`}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
  ]}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today",
      "description": t(lang!, "common.siteDescription"),
      "inLanguage": lang,
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Plata",
      "url": "https://plata.today",
      "logo": "https://plata.today/logo.svg"
    }
  ]}
>
  <!-- HERO -->
  <section class="hero" aria-label={t(lang!, "home.featuredStory")}>
    <a href={heroArticle.href} class="hero-link">
      <div class="hero-image">
        <img src={heroArticle.imageUrl} alt={heroArticle.title} loading="eager" />
      </div>
      <div class="hero-body">
        <div class="hero-meta-top">
          {heroArticle.isNew && <span class="hero-badge-new">NEW</span>}
          {heroArticle.subcategory && <span class="hero-cat" style={heroArticle.category ? `color: var(--cat-${heroArticle.category})` : undefined}>{heroArticle.subcategory}</span>}
        </div>
        <h1 class="hero-title">{heroArticle.title}</h1>
        <p class="hero-desc">{heroArticle.description}</p>
        <div class="meta">
          {heroArticle.timeAgo && <span class="meta-time">{heroArticle.timeAgo}</span>}
          {heroArticle.readingTime && <span class="meta-dot"></span>}
          {heroArticle.readingTime && <span class="meta-reading">{heroArticle.readingTime}</span>}
          {heroArticle.sourceLabel && <span class="meta-dot"></span>}
          {heroArticle.sourceLabel && <span class="meta-source">via {heroArticle.sourceLabel}</span>}
        </div>
      </div>
    </a>
    {relatedLinks.length > 0 && (
      <ul class="hero-related">
        {relatedLinks.map((link) => (
          <li>
            <span class="hero-related-cat" style={`color: var(--cat-${link.categoryKey})`}>{link.category}</span>
            <a href={link.href} class="hero-related-link">{link.title}</a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- TRENDING -->
  {trendingItems.length > 0 && <TrendingSection items={trendingItems} lang={lang} />}

  <!-- POLITICS -->
  {politicsAll.length > 0 && <SectionHeader title={t(lang!, "home.politics")} href={`/${lang}/category/politics`} accentColor="var(--cat-politics)" />}
  {politicsAll.length > 0 && (
    <section class="topic-section" aria-label={t(lang!, "home.politics")}>
      {politicsFeatured && (
        <div class="topic-featured">
          <ArticleCard
            title={politicsFeatured.title}
            description={politicsFeatured.description}
            href={politicsFeatured.href}
            imageUrl={politicsFeatured.imageUrl}
            timeAgo={politicsFeatured.timeAgo}
            category={politicsFeatured.subcategory}
            categoryKey={politicsFeatured.category}
            readingTime={politicsFeatured.readingTime}
            isNew={politicsFeatured.isNew}
            sourceLabel={politicsFeatured.sourceLabel}
          />
        </div>
      )}
      <aside class="topic-sidebar">
        {politicsSidebar.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            timeAgo={a.timeAgo}
            category={a.subcategory}
            categoryKey={a.category}
            readingTime={a.readingTime}
            variant="sidebar"
          />
        ))}
      </aside>
    </section>
  )}

  <!-- JUST IN -->
  {justInItems.length > 0 && <JustInFeed items={justInItems} lang={lang} />}

  <!-- ECONOMY & BUSINESS -->
  {econAll.length > 0 && <SectionHeader title={t(lang!, "home.economyBusiness")} href={`/${lang}/category/economy`} accentColor="var(--cat-economy)" />}
  {econAll.length > 0 && (
    <section class="topic-section" aria-label={t(lang!, "home.economyBusiness")}>
      {econFeatured && (
        <div class="topic-featured">
          <ArticleCard
            title={econFeatured.title}
            description={econFeatured.description}
            href={econFeatured.href}
            imageUrl={econFeatured.imageUrl}
            timeAgo={econFeatured.timeAgo}
            category={econFeatured.subcategory}
            categoryKey={econFeatured.category}
            readingTime={econFeatured.readingTime}
            isNew={econFeatured.isNew}
            sourceLabel={econFeatured.sourceLabel}
          />
        </div>
      )}
      <aside class="topic-sidebar">
        {econSidebar.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            timeAgo={a.timeAgo}
            category={a.subcategory}
            categoryKey={a.category}
            readingTime={a.readingTime}
            variant="sidebar"
          />
        ))}
      </aside>
    </section>
  )}

  <!-- FINANCIAL DASHBOARD -->
  <SectionHeader title={t(lang!, "finDash.title" as any)} href={`/${lang}/markets`} accentColor="var(--cat-economy)" />
  <FinancialDashboard lang={lang} />

  <!-- SPORTS -->
  {sportsAll.length > 0 && <SectionHeader title={t(lang!, "cat.sports")} href={`/${lang}/category/sports`} accentColor="var(--cat-sports)" />}
  {sportsAll.length > 0 && (
    <section class="topic-section" aria-label={t(lang!, "cat.sports")}>
      {sportsFeatured && (
        <div class="topic-featured">
          <ArticleCard
            title={sportsFeatured.title}
            description={sportsFeatured.description}
            href={sportsFeatured.href}
            imageUrl={sportsFeatured.imageUrl}
            timeAgo={sportsFeatured.timeAgo}
            category={sportsFeatured.subcategory}
            categoryKey={sportsFeatured.category}
            readingTime={sportsFeatured.readingTime}
            isNew={sportsFeatured.isNew}
            sourceLabel={sportsFeatured.sourceLabel}
          />
        </div>
      )}
      <aside class="topic-sidebar">
        {sportsSidebar.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            timeAgo={a.timeAgo}
            category={a.subcategory}
            categoryKey={a.category}
            readingTime={a.readingTime}
            variant="sidebar"
          />
        ))}
      </aside>
    </section>
  )}

  <!-- NEWSLETTER BANNER -->
  <NewsletterBanner lang={lang} />

  <!-- WORLD -->
  {worldNews.length > 0 && <SectionHeader title={t(lang!, "cat.world")} href={`/${lang}/category/world`} accentColor="var(--cat-world)" />}
  {worldNews.length > 0 && (
    <section class="compact-grid" aria-label={t(lang!, "cat.world")}>
      {worldNews.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- CULTURE & SOCIETY -->
  {cultureSociety.length > 0 && <SectionHeader title={t(lang!, "home.cultureSociety")} href={`/${lang}/category/culture`} accentColor="var(--cat-culture)" />}
  {cultureSociety.length > 0 && (
    <section class="compact-grid" aria-label={t(lang!, "home.cultureSociety")}>
      {cultureSociety.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          readingTime={a.readingTime}
          isNew={a.isNew}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- SCIENCE & TECH -->
  {scienceTech.length > 0 && <SectionHeader title={t(lang!, "cat.science")} href={`/${lang}/category/science`} accentColor="var(--cat-science)" />}
  {scienceTech.length > 0 && (
    <section class="sidebar-list" aria-label={t(lang!, "cat.science")}>
      {scienceTech.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.category}
          variant="sidebar"
        />
      ))}
    </section>
  )}

  <!-- MORE NEWS -->
  <SectionHeader title={t(lang!, "home.moreNews")} />
  <section class="compact-grid" id="more-news-grid" aria-label={t(lang!, "home.moreNews")}>
    {moreNews.map((a) => (
      <ArticleCard
        title={a.title}
        href={a.href}
        imageUrl={a.imageUrl}
        timeAgo={a.timeAgo}
        category={a.subcategory}
        categoryKey={a.category}
        readingTime={a.readingTime}
        variant="compact"
      />
    ))}
  </section>

  <!-- LOAD MORE -->
  <div id="load-more-container">
    <button class="load-more-btn" id="load-more-btn" type="button">
      {t(lang!, "home.loadMore" as any)}
    </button>
    <p class="load-more-end" id="load-more-end" hidden>
      {t(lang!, "home.noMoreArticles" as any)}
    </p>
  </div>
</Base>

<script is:inline define:vars={{
  initialSlugs: Array.from(usedSlugs),
  lang,
  initialOffset: allArticles.length,
  loadMoreLabel: t(lang!, "home.loadMore" as any),
  catLabels: Object.fromEntries(
    CATEGORY_LIST.map((c: string) => [c, t(lang!, `cat.${c}` as any)])
  )
}}>
(function() {
  var btn = document.getElementById('load-more-btn');
  var endMsg = document.getElementById('load-more-end');
  var grid = document.getElementById('more-news-grid');
  if (!btn || !grid) return;

  var offset = initialOffset;
  var LIMIT = 12;
  var seenSlugs = new Set(initialSlugs);
  var loading = false;

  function escapeHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function createCard(a) {
    var article = document.createElement('article');
    article.className = 'card card--compact';
    if (a.category) {
      article.style.setProperty('--cat-color', 'var(--cat-' + a.category + ', var(--color-gold-dark))');
    }

    var html = '<a href="' + escapeHtml(a.href) + '" class="card-link">';
    if (a.imageUrl) {
      html += '<div class="card-image"><img src="' + escapeHtml(a.imageUrl) + '" alt="' + escapeHtml(a.title) + '" loading="lazy" /></div>';
    }
    html += '<div class="card-body">';
    html += '<h3 class="card-title">' + escapeHtml(a.title) + '</h3>';
    html += '<div class="card-meta">';
    if (a.timeAgo) html += '<time class="card-time">' + escapeHtml(a.timeAgo) + '</time>';
    var catLabel = catLabels[a.category] || a.category;
    if (a.timeAgo && catLabel) html += '<span class="card-divider" aria-hidden="true">|</span>';
    if (catLabel) html += '<span class="card-category">' + escapeHtml(catLabel) + '</span>';
    if (a.readingTime) html += '<span class="card-divider" aria-hidden="true">|</span><span class="card-reading-time">' + escapeHtml(a.readingTime) + '</span>';
    html += '</div></div></a>';

    article.innerHTML = html;
    return article;
  }

  function loadMore() {
    if (loading) return;
    loading = true;
    btn.textContent = '...';
    btn.disabled = true;

    fetch('/api/feed?lang=' + encodeURIComponent(lang) + '&offset=' + offset + '&limit=' + LIMIT)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var articles = data.articles.filter(function(a) {
          return !seenSlugs.has(a.slug);
        });

        articles.forEach(function(a) {
          seenSlugs.add(a.slug);
          grid.appendChild(createCard(a));
        });

        offset += LIMIT;

        if (!data.hasMore || articles.length === 0) {
          btn.hidden = true;
          if (endMsg) endMsg.hidden = false;
        } else {
          btn.textContent = loadMoreLabel;
          btn.disabled = false;
        }
        loading = false;
      })
      .catch(function() {
        btn.textContent = loadMoreLabel;
        btn.disabled = false;
        loading = false;
      });
  }

  btn.addEventListener('click', loadMore);
})();
</script>

<style>
  /* ====================== */
  /* HERO                   */
  /* ====================== */
  .hero {
    margin-bottom: var(--spacing-xl);
  }

  .hero-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .hero-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .hero-link:hover .hero-title {
    text-decoration: underline;
  }

  .hero-meta-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .hero-badge-new {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    background: #b91c1c;
    color: #fff;
    padding: 1px 5px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  .hero-cat {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero-image {
    overflow: hidden;
    margin-bottom: 20px;
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .hero-link:hover .hero-image img {
    transform: scale(1.02);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }

  .meta-source {
    font-size: 0.75rem;
    font-style: italic;
  }

  .hero-related {
    list-style: none;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-related li {
    padding-left: 18px;
    position: relative;
  }

  .hero-related li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .hero-related-cat {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 2px;
  }

  .hero-related-link {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .hero-related-link:hover {
    text-decoration: underline;
    color: var(--color-link-hover);
  }

  /* ========================= */
  /* TOPIC SECTIONS            */
  /* (Economy, Sports, etc.)   */
  /* ========================= */
  .topic-section {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
  }

  .topic-sidebar {
    border-left: 1px solid var(--color-border);
    padding-left: var(--spacing-2xl);
  }

  /* ========================= */
  /* COMPACT GRID              */
  /* (Culture, World)          */
  /* ========================= */
  .compact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: var(--spacing-2xl);
  }

  .compact-grid :global(.card--compact) {
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .compact-grid :global(.card--compact:nth-child(odd)) {
    padding-right: var(--spacing-xl);
    border-right: 1px solid var(--color-border);
  }

  .compact-grid :global(.card--compact:nth-child(even)) {
    padding-left: var(--spacing-xl);
  }

  .compact-grid :global(.card--compact:nth-last-child(-n+2)) {
    border-bottom: none;
  }

  /* ========================= */
  /* SIDEBAR LIST              */
  /* (Science & Tech)          */
  /* ========================= */
  .sidebar-list {
    max-width: var(--content-width);
    margin-bottom: var(--spacing-2xl);
  }

  /* ========================= */
  /* DESKTOP HERO              */
  /* ========================= */
  @media (min-width: 1025px) {
    .hero-link {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: var(--spacing-xl);
      align-items: start;
    }

    .hero-image {
      margin-bottom: 0;
    }

    .hero-image img {
      aspect-ratio: 3 / 2;
    }

    .hero-title {
      font-size: 1.8rem;
    }

    .hero-related {
      flex-direction: row;
      gap: var(--spacing-lg);
    }

    .hero-related li {
      flex: 1;
      border-left: 2px solid var(--color-accent);
      padding-left: 12px;
      padding-top: 0;
    }

    .hero-related li::before {
      display: none;
    }
  }

  /* ========================= */
  /* TABLET                    */
  /* ========================= */
  @media (max-width: 1024px) {
    .hero-title {
      font-size: 1.75rem;
    }

    .topic-section {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-xl);
    }

    .topic-sidebar {
      padding-left: var(--spacing-xl);
    }
  }

  /* ========================= */
  /* MOBILE                    */
  /* ========================= */
  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.4rem;
    }

    .hero-image img {
      aspect-ratio: 16 / 10;
    }

    .hero-desc {
      font-size: 0.9rem;
    }

    .compact-grid {
      grid-template-columns: 1fr;
    }

    .compact-grid :global(.card--compact) {
      padding: 16px 0;
      border-bottom: 1px solid var(--color-border);
    }

    .compact-grid :global(.card--compact:nth-child(odd)) {
      padding-right: 0;
      border-right: none;
