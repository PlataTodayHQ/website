---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { LANGUAGES, CATEGORIES } from "@plata-today/shared";
import { t } from "@/i18n";
import type { Category } from "@plata-today/shared";
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkRehype from "remark-rehype";
import rehypeStringify from "rehype-stringify";
import {
  getArticleBySlug,
  getArticlesByLang,
  getArticleLangSlugs,
  timeAgo,
  readingTime,
  parseSourceNames,
} from "@/lib/db";
import { getSourceMeta, getFaviconUrl } from "@/lib/sources";

export const prerender = false;

const { lang, slug } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

// ---------------------------------------------------------------------------
// Article data from SQLite
// ---------------------------------------------------------------------------
let row: ReturnType<typeof getArticleBySlug>;
try {
  row = getArticleBySlug(lang, slug!);
} catch (err) {
  console.error("[article] DB error:", err);
  return new Response("Internal Server Error", { status: 500 });
}

if (!row) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Build correct hreflang alternate URLs using per-language slugs
const langSlugs = getArticleLangSlugs(row.event_id);
const alternateUrls = Object.fromEntries(
  Object.keys(LANGUAGES).map((code) => [
    code,
    langSlugs[code]
      ? `https://plata.today/${code}/news/${langSlugs[code]}`
      : `https://plata.today/${code}/`,
  ])
);

const catLabel = t(lang, `cat.${row.category}` as any) || CATEGORIES[row.category as Category] || row.category;
const sourceNames = parseSourceNames(row.source_names);

// Build enriched source data with metadata
const sources = sourceNames.map((name) => {
  const meta = getSourceMeta(name);
  return {
    name,
    favicon: meta ? getFaviconUrl(meta.domain) : undefined,
  };
});

const wordCount = row.word_count || row.body.split(/\s+/).length;
const computedReadingTime = readingTime(wordCount, lang);
const publishedDate = new Date(row.published_at);
let dateFormatted: string;
try {
  dateFormatted = publishedDate.toLocaleDateString(lang, {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
} catch {
  dateFormatted = publishedDate.toLocaleDateString("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
const dateISO = publishedDate.toISOString();

// Parse body as markdown → HTML
// Strip leading markdown heading if it duplicates the title
const bodyText = row.body.replace(/^#+\s+.*\n+/, "");
const bodyHtml = String(
  await unified()
    .use(remarkParse)
    .use(remarkRehype)
    .use(rehypeStringify)
    .process(bodyText)
);

// Related articles — same category, different slug
let relatedArticles: Array<{title: string; href: string; imageUrl: string; timeAgo: string; category: string; categoryKey: string; readingTime: string}> = [];
try {
  relatedArticles = getArticlesByLang(lang, 20)
    .filter((a) => a.slug !== slug)
    .slice(0, 3)
    .map((a) => ({
      title: a.title,
      href: `/${lang}/news/${a.slug}`,
      imageUrl:
        a.image_url ??
        "/images/placeholder.svg",
      timeAgo: timeAgo(a.published_at, lang),
      category: t(lang, `cat.${a.category}` as any) || CATEGORIES[a.category as Category] || a.category,
      categoryKey: a.category,
      readingTime: readingTime(a.word_count, lang),
    }));
} catch {
  // Related articles are non-critical, skip on error
}
---

<Base
  title={row.title}
  description={row.meta_description ?? bodyText.slice(0, 160) ?? ""}
  lang={lang}
  alternateUrls={alternateUrls}
  ogType="article"
  ogImage={row.image_url ?? "/images/placeholder.svg"}
  ogUrl={`https://plata.today/${lang}/news/${slug}`}
  breadcrumbs={[
    { name: t(lang, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: catLabel, url: `/${lang}/category/${row.category}` },
    { name: row.title, url: `/${lang}/news/${slug}` },
  ]}
  articleMeta={{
    publishedTime: dateISO,
    section: catLabel,
    tags: [catLabel],
    author: "Plata Newsroom",
  }}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": row.title,
    "description": row.meta_description ?? "",
    "image": row.image_url ?? "",
    "datePublished": dateISO,
    "dateModified": dateISO,
    "author": {
      "@type": "Organization",
      "name": "Plata Newsroom",
      "url": "https://plata.today"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Plata",
      "url": "https://plata.today",
      "logo": {
        "@type": "ImageObject",
        "url": "https://plata.today/logo.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://plata.today/${lang}/news/${slug}`
    },
    "articleSection": catLabel,
    "inLanguage": lang,
    "isAccessibleForFree": true,
  }}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label={t(lang, "article.readingProgress")}>
    <div class="reading-progress-bar" id="reading-progress-bar"></div>
  </div>

  <article class="article" itemscope itemtype="https://schema.org/NewsArticle">
    <!-- Header — BBC-style left-aligned -->
    <header class="article-header">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href={`/${lang}/`}>{t(lang, "common.breadcrumbHome")}</a></li>
          <li><a href={`/${lang}/category/${row.category}`}>{catLabel}</a></li>
        </ol>
      </nav>
      <a href={`/${lang}/category/${row.category}`} class="article-category">
        {catLabel}
      </a>
      <h1 class="article-title" itemprop="headline">{row.title}</h1>
      {row.meta_description && <p class="article-subtitle" itemprop="description">{row.meta_description}</p>}
      <div class="article-meta">
        <time datetime={dateISO.slice(0, 10)} itemprop="datePublished">{dateFormatted}</time>
        <span class="meta-sep" aria-hidden="true">&middot;</span>
        <span>{computedReadingTime}</span>
      </div>
      <div class="article-share" role="group" aria-label={t(lang, "article.shareArticle")}>
        <button type="button" class="share-btn" data-share="x" aria-label={t(lang, "article.shareOnX")}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
        <button type="button" class="share-btn" data-share="facebook" aria-label={t(lang, "article.shareOnFacebook")}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </button>
        <button type="button" class="share-btn" data-share="copy" aria-label={t(lang, "article.copyLink")} data-copied-label={t(lang, "article.linkCopied")}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </div>
    </header>

    <!-- Hero image -->
    {row.image_url && (
      <figure class="article-image">
        <img src={row.image_url} alt={row.title} itemprop="image" onerror="this.closest('.article-image').style.display='none'" />
        {row.image_source && (
          <figcaption class="article-image-credit">
            {t(lang, "article.photoCredit")}: {row.image_source}
          </figcaption>
        )}
      </figure>
    )}

    <!-- Body -->
    <div class="article-body" itemprop="articleBody" set:html={bodyHtml} />

    <!-- Sources -->
    {sources.length > 0 && (
      <footer class="article-sources">
        <h2>{t(lang, "article.sources")}</h2>
        <ul>
          {sources.map((src) => (
            <li>
              <span class="source-chip source-chip--plain">
                {src.favicon && (
                  <img
                    src={src.favicon}
                    alt=""
                    class="source-favicon"
                    width="16"
                    height="16"
                    loading="lazy"
                  />
                )}
                <span class="source-name">{src.name}</span>
              </span>
            </li>
          ))}
        </ul>
      </footer>
    )}
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section aria-label={t(lang, "article.relatedArticles")}>
      <SectionHeader title={t(lang, "article.relatedArticles")} />
      <div class="related-grid">
        {relatedArticles.map((a) => (
          <ArticleCard
            title={a.title}
            href={a.href}
            imageUrl={a.imageUrl}
            timeAgo={a.timeAgo}
            category={a.category}
            categoryKey={a.categoryKey}
            readingTime={a.readingTime}
          />
        ))}
      </div>
    </section>
  )}

  <script is:inline>
  (function() {
    var bar = document.getElementById('reading-progress-bar');
    var wrapper = document.getElementById('reading-progress');
    var body = document.querySelector('.article-body');
    if (!bar || !body || !wrapper) return;

    var ticking = false;
    function update() {
      var rect = body.getBoundingClientRect();
      var bodyTop = rect.top + window.scrollY;
      var bodyHeight = rect.height;
      var scrollY = window.scrollY;
      var viewH = window.innerHeight;
      var progress = 0;
      if (scrollY + viewH > bodyTop) {
        progress = Math.min(100, Math.max(0, ((scrollY + viewH - bodyTop) / (bodyHeight + viewH)) * 100));
      }
      bar.style.width = progress + '%';
      wrapper.setAttribute('aria-valuenow', String(Math.round(progress)));
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });
    update();
  })();

  // Share buttons
  (function() {
    var url = window.location.href;
    var title = document.querySelector('.article-title');
    var text = title ? title.textContent : document.title;

    document.querySelectorAll('[data-share]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var type = btn.getAttribute('data-share');
        if (type === 'x') {
          window.open('https://x.com/intent/tweet?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(text), '_blank', 'width=550,height=420');
        } else if (type === 'facebook') {
          window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url), '_blank', 'width=550,height=420');
        } else if (type === 'copy') {
          navigator.clipboard.writeText(url).then(function() {
            var orig = btn.getAttribute('aria-label');
            btn.setAttribute('aria-label', btn.getAttribute('data-copied-label') || 'Link copied!');
            btn.classList.add('share-btn--copied');
            setTimeout(function() {
              btn.setAttribute('aria-label', orig);
              btn.classList.remove('share-btn--copied');
            }, 2000);
          });
        }
      });
    });
  })();
  </script>
</Base>

<style>
  /* Reading progress bar */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 200;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-gold);
    transition: width 0.1s linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress-bar {
      transition: none;
    }
  }

  .article {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--spacing-xl) 0;
  }

  /* Breadcrumb navigation */
  .article-breadcrumb {
    margin-bottom: var(--spacing-md);
  }

  .article-breadcrumb ol {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8rem;
    color: var(--color-text-meta);
  }

  .article-breadcrumb li:not(:last-child)::after {
    content: "›";
    margin-left: 6px;
    color: var(--color-text-meta);
  }

  .article-breadcrumb a {
    color: var(--color-text-meta);
  }

  .article-breadcrumb a:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  /* Header — BBC-style left-aligned */
  .article-header {
    margin-bottom: var(--spacing-xl);
  }

  .article-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-gold-dark);
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }

  .article-category:hover {
    text-decoration: underline;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    line-height: 1.15;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .article-subtitle {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    max-width: 90%;
  }

  .article-meta {
    font-size: 0.85rem;
    color: var(--color-text-meta);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--spacing-md);
  }

  .meta-sep {
    color: var(--color-text-meta);
  }

  .article-share {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    color: var(--color-text-meta);
    background: var(--color-bg-secondary);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .share-btn:hover {
    color: var(--color-celeste-dark);
    background: var(--color-border);
  }

  .share-btn--copied {
    color: #fff;
    background: #16a34a;
  }

  /* Image — using figure/figcaption for semantics */
  .article-image {
    margin: 0 0 var(--spacing-xl) 0;
  }

  .article-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .article-image-credit {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-meta);
    margin-top: 6px;
  }

  /* Body */
  .article-body {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--spacing-2xl);
  }

  .article-body :global(p) {
    margin-bottom: var(--spacing-lg);
  }

  .article-body :global(p:first-of-type::first-letter) {
    font-family: var(--font-serif);
    font-size: 3.6em;
    font-weight: 700;
    float: left;
    line-height: 0.8;
    margin-right: 0.08em;
    margin-top: 0.05em;
    color: var(--color-text);
  }

  .article-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .article-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .article-body :global(strong) {
    font-weight: 700;
  }

  .article-body :global(em) {
    font-style: italic;
  }

  /* CJK: disable drop cap (not idiomatic), adjust line-height */
  :global(:lang(zh)) .article-body :global(p:first-of-type::first-letter),
  :global(:lang(ja)) .article-body :global(p:first-of-type::first-letter),
  :global(:lang(ko)) .article-body :global(p:first-of-type::first-letter) {
    font-size: inherit;
    float: none;
    line-height: inherit;
    margin-right: 0;
    margin-top: 0;
  }

  /* CJK article title: adjust spacing */
  :global(:lang(zh)) .article-title,
  :global(:lang(ja)) .article-title,
  :global(:lang(ko)) .article-title {
    letter-spacing: 0;
    line-height: 1.35;
  }

  /* Sources */
  .article-sources {
    border-top: 2px solid var(--color-border-section);
    padding-top: var(--spacing-lg);
    position: relative;
  }

  .article-sources::after {
    content: "";
    position: absolute;
    top: 4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-border-section);
  }

  .article-sources h2 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-meta);
    margin-bottom: var(--spacing-md);
  }

  .article-sources ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .source-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 8px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
  }

  .source-favicon {
    width: 16px;
    height: 16px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .source-name {
    font-weight: 500;
    white-space: nowrap;
  }

  /* Related Articles */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  @media (max-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .article {
      padding: var(--spacing-lg) 0;
    }

    .article-title {
      font-size: 1.65rem;
    }

    .article-subtitle {
      font-size: 1.05rem;
      max-width: 100%;
    }

    .article-category {
      font-size: 0.8rem;
    }

    .article-meta {
      font-size: 0.88rem;
    }

    .article-breadcrumb ol {
      font-size: 0.82rem;
    }

    .article-body {
      font-size: 1.12rem;
      line-height: 1.85;
    }

    .article-body :global(h2) {
      font-size: 1.3rem;
    }

    .article-body :global(h3) {
      font-size: 1.12rem;
    }

    .article-image-credit {
      font-size: 0.8rem;
    }

    .source-chip {
      font-size: 0.88rem;
    }

    .article-sources h2 {
      font-size: 0.82rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
