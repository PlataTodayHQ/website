---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "terms.pageTitle")}
  description={t(lang!, "terms.description")}
  lang={lang}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "terms.title"), url: `/${lang}/terms` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "terms.title"),
    "url": `https://plata.today/${lang}/terms`,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <article class="legal">
    <header class="legal-header">
      <h1>{t(lang!, "terms.title")}</h1>
      <p class="legal-updated">{t(lang!, "terms.updated")}</p>
    </header>

    <div class="legal-body">
      <p class="lead">{t(lang!, "terms.lead")}</p>

      <h2>{t(lang!, "terms.contentTitle")}</h2>
      <p>{t(lang!, "terms.contentText")}</p>

      <h2>{t(lang!, "terms.adviceTitle")}</h2>
      <p>{t(lang!, "terms.adviceText")}</p>

      <h2>{t(lang!, "terms.ratesTitle")}</h2>
      <p>{t(lang!, "terms.ratesText")}</p>

      <h2>{t(lang!, "terms.attributionTitle")}</h2>
      <p>{t(lang!, "terms.attributionText")}</p>

      <h2>{t(lang!, "terms.ipTitle")}</h2>
      <p>{t(lang!, "terms.ipText")}</p>

      <h2>{t(lang!, "terms.availabilityTitle")}</h2>
      <p>{t(lang!, "terms.availabilityText")}</p>

      <h2>{t(lang!, "terms.liabilityTitle")}</h2>
      <p>{t(lang!, "terms.liabilityText")}</p>

      <h2>{t(lang!, "terms.lawTitle")}</h2>
      <p>{t(lang!, "terms.lawText")}</p>

      <h2>{t(lang!, "terms.changesTitle")}</h2>
      <p>{t(lang!, "terms.changesText")}</p>

      <h2>{t(lang!, "terms.contactTitle")}</h2>
      <p>{t(lang!, "terms.contactText")}</p>
    </div>
  </article>
</Base>

<style>
  .legal {
    max-width: var(--content-width);
    margin: 0 auto;
    background: var(--color-bg);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-radius: 2px;
  }

  .legal-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .legal-header h1 {
    font-size: 2.25rem;
  }

  .legal-updated {
    font-size: 0.85rem;
    color: var(--color-text-meta);
    margin-top: var(--spacing-sm);
  }

  .legal-body .lead {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: var(--spacing-xl);
  }

  .legal-body h2 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    border-top: 3px solid var(--color-celeste);
    padding-top: var(--spacing-md);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .legal-body p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }
</style>
