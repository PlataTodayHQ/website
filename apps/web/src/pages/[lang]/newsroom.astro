---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "newsroom.title")}
  description={t(lang!, "newsroom.description")}
  lang={lang}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "about.title"), url: `/${lang}/about` },
    { name: t(lang!, "newsroom.title"), url: `/${lang}/newsroom` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "newsroom.title"),
    "url": `https://plata.today/${lang}/newsroom`,
    "description": t(lang!, "newsroom.description"),
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <article class="info-page">
    <header class="info-header">
      <h1>{t(lang!, "newsroom.title")}</h1>
      <p class="info-tagline">{t(lang!, "newsroom.heading")}</p>
    </header>

    <div class="info-body">
      <section>
        <p>{t(lang!, "newsroom.intro")}</p>
      </section>

      <section>
        <h2>{t(lang!, "newsroom.stepsTitle")}</h2>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <div>
              <h3>{t(lang!, "newsroom.step1Title")}</h3>
              <p>{t(lang!, "newsroom.step1Desc")}</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <div>
              <h3>{t(lang!, "newsroom.step2Title")}</h3>
              <p>{t(lang!, "newsroom.step2Desc")}</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <div>
              <h3>{t(lang!, "newsroom.step3Title")}</h3>
              <p>{t(lang!, "newsroom.step3Desc")}</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">4</span>
            <div>
              <h3>{t(lang!, "newsroom.step4Title")}</h3>
              <p>{t(lang!, "newsroom.step4Desc")}</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2>{t(lang!, "newsroom.sourcesTitle")}</h2>
        <p>{t(lang!, "newsroom.sourcesIntro")}</p>

        <div class="source-tiers">
          <div class="tier">
            <h3>{t(lang!, "newsroom.tier1Title")}</h3>
            <p>{t(lang!, "newsroom.tier1List")}</p>
          </div>
          <div class="tier">
            <h3>{t(lang!, "newsroom.tier2Title")}</h3>
            <p>{t(lang!, "newsroom.tier2List")}</p>
          </div>
          <div class="tier">
            <h3>{t(lang!, "newsroom.tier3Title")}</h3>
            <p>{t(lang!, "newsroom.tier3List")}</p>
          </div>
        </div>

        <p>{t(lang!, "newsroom.sourcesFooter")}</p>
      </section>

      <section>
        <h2>{t(lang!, "newsroom.filterTitle")}</h2>
        <p>{t(lang!, "newsroom.filterText")}</p>
        <p><a href={`/${lang}/standards`} class="standards-link">{t(lang!, "newsroom.standardsLink")} &rarr;</a></p>
      </section>
    </div>
  </article>
</Base>

<style>
  .info-page {
    max-width: var(--content-width);
    margin: 0 auto;
    background: var(--color-bg);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-radius: 2px;
  }

  .info-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .info-header h1 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
  }

  .info-tagline {
    font-size: 1.15rem;
    color: var(--color-text-meta);
    margin-top: var(--spacing-sm);
  }

  .info-body h2 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    border-top: 3px solid var(--color-celeste);
    padding-top: var(--spacing-md);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .info-body p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
  }

  .step {
    display: flex;
    gap: var(--spacing-md);
    align-items: flex-start;
  }

  .step-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-celeste);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50%;
  }

  .step h3 {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .step p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-meta);
    margin-bottom: 0;
  }

  /* Source tiers */
  .source-tiers {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin: var(--spacing-md) 0;
  }

  .tier {
    padding: var(--spacing-md) var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: 2px;
  }

  .tier h3 {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: var(--spacing-xs);
  }

  .tier p {
    font-size: 0.9rem;
    color: var(--color-text-meta);
    margin-bottom: 0;
  }

  .standards-link {
    color: var(--color-celeste);
    font-weight: 600;
    text-decoration: none;
  }

  .standards-link:hover {
    text-decoration: underline;
  }
</style>
