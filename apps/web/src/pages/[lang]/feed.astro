---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { CATEGORIES, CATEGORY_LIST } from "@plata-today/shared";
import type { Category } from "@plata-today/shared";
import { t } from "@/i18n";
import { getArticlesFeed, timeAgo, readingTime, type ArticleRow } from "@/lib/db";

export const prerender = false;

const { lang } = Astro.params;
const LIMIT = 20;

const { articles: initialArticles, hasMore } = getArticlesFeed(lang!, 0, LIMIT);

function mapRow(a: ArticleRow) {
  return {
    title: a.title,
    slug: a.slug,
    href: `/${lang}/news/${a.slug}`,
    description: a.meta_description ?? "",
    imageUrl: a.image_url || "",
    category: a.category,
    categoryLabel: t(lang!, `cat.${a.category}` as any) || CATEGORIES[a.category as Category] || a.category,
    timeAgo: timeAgo(a.published_at, lang!),
    readingTime: readingTime(a.word_count, lang!),
    publishedAt: a.published_at,
  };
}

const articles = initialArticles.map(mapRow);

const categoryTabs = [
  { key: "", label: t(lang!, "feed.all" as any) },
  ...CATEGORY_LIST.map((key) => ({
    key,
    label: t(lang!, `cat.${key}` as any) || CATEGORIES[key],
  })),
];
---

<Base
  title={t(lang!, "feed.title" as any)}
  description={t(lang!, "feed.description" as any)}
  lang={lang}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "feed.title" as any), url: `/${lang}/feed` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${t(lang!, "feed.title" as any)} — Plata`,
    "url": `https://plata.today/${lang}/feed`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <div class="feed-page" data-lang={lang} data-limit={LIMIT} data-no-more={t(lang!, "feed.noMore" as any)}>
    <h1 class="feed-heading">{t(lang!, "feed.title" as any)}</h1>

    <!-- Category filter tabs -->
    <nav class="feed-tabs" aria-label={t(lang!, "feed.filterByCategory")}>
      {categoryTabs.map((tab) => (
        <button
          class:list={["feed-tab", { active: tab.key === "" }]}
          data-category={tab.key}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    <!-- Articles list -->
    <div class="feed-list" id="feed-list">
      {articles.map((a) => (
        <ArticleCard
          lang={lang}
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.categoryLabel}
          categoryKey={a.category}
          readingTime={a.readingTime}
          variant="list"
        />
      ))}
    </div>

    <!-- Infinite scroll sentinel -->
    <div class="feed-status" id="feed-status">
      {hasMore ? (
        <div class="feed-loader" id="feed-loader">
          <div class="loading-spinner"></div>
          <span>{t(lang!, "feed.loadMore" as any)}</span>
        </div>
      ) : (
        <p class="feed-end">{t(lang!, "feed.noMore" as any)}</p>
      )}
    </div>
  </div>
</Base>

<script is:inline define:vars={{
  lang,
  LIMIT,
  catLabels: Object.fromEntries(
    CATEGORY_LIST.map((c: string) => [c, t(lang!, `cat.${c}` as any) || CATEGORIES[c as Category] || c])
  )
}}>
(function() {
  var page = document.querySelector('.feed-page');
  if (!page) return;

  var list = document.getElementById('feed-list');
  var status = document.getElementById('feed-status');
  var tabs = page.querySelectorAll('.feed-tab');

  var offset = list.children.length;
  var loading = false;
  var hasMore = !!document.getElementById('feed-loader');
  var activeCategory = '';

  // Category tab switching
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var cat = tab.dataset.category;
      if (cat === activeCategory) return;
      activeCategory = cat;
      tabs.forEach(function(t) { t.classList.toggle('active', t.dataset.category === cat); });
      list.innerHTML = '';
      offset = 0;
      hasMore = true;
      status.innerHTML = '<div class="feed-loader" id="feed-loader"><div class="loading-spinner"></div></div>';
      loadMore();
    });
  });

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function createItem(a) {
    var article = document.createElement('article');
    article.className = 'card card--list';
    if (a.category) {
      article.style.setProperty('--cat-color', 'var(--cat-' + a.category + ', var(--color-gold-dark))');
    }

    var categoryLabel = catLabels[a.category] || a.category;
    var desc = a.description ? '<p class="card-desc">' + escapeHtml(a.description) + '</p>' : '';
    var thumb = a.imageUrl ? '<a href="' + escapeHtml(a.href) + '" class="card-thumb" aria-hidden="true" tabindex="-1"><img src="' + escapeHtml(a.imageUrl) + '" alt="' + escapeHtml(a.title) + '" onerror="this.parentElement.style.display=\'none\'" /></a>' : '';

    article.innerHTML =
      '<div class="card-body">' +
        '<div class="card-meta">' +
          '<span class="card-category">' + escapeHtml(categoryLabel) + '</span>' +
          '<span class="card-divider" aria-hidden="true">&middot;</span>' +
          '<time class="card-time">' + escapeHtml(a.timeAgo) + '</time>' +
          (a.readingTime ? '<span class="card-divider" aria-hidden="true">&middot;</span><span class="card-reading-time">' + escapeHtml(a.readingTime) + '</span>' : '') +
        '</div>' +
        '<a href="' + escapeHtml(a.href) + '" class="card-link"><h3 class="card-title">' + escapeHtml(a.title) + '</h3></a>' +
        desc +
      '</div>' +
      thumb;

    return article;
  }

  function loadMore() {
    if (loading || !hasMore) return;
    loading = true;

    var url = '/api/feed?lang=' + lang + '&offset=' + offset + '&limit=' + LIMIT;
    if (activeCategory) url += '&category=' + activeCategory;

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        data.articles.forEach(function(a) {
          list.appendChild(createItem(a));
        });
        offset += data.articles.length;
        hasMore = data.hasMore;
        if (!hasMore) {
          status.innerHTML = '<p class="feed-end">' + (page.dataset.noMore || 'No more articles') + '</p>';
        }
        loading = false;
      })
      .catch(function() {
        loading = false;
        status.innerHTML = '<p class="feed-end" style="color:#dc2626;">Error loading articles. Please try again.</p>';
      });
  }

  // Intersection Observer for infinite scroll
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && hasMore && !loading) {
        loadMore();
      }
    }, { rootMargin: '400px' });
    observer.observe(status);
  }
})();
</script>

<style is:global>
  .feed-page {
    max-width: 800px;
  }

  .feed-page .feed-heading {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-lg);
  }

  /* Category tabs */
  .feed-page .feed-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .feed-page .feed-tab {
    display: inline-block;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    border: none;
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .feed-page .feed-tab:hover {
    background: var(--color-celeste);
    color: #fff;
  }

  .feed-page .feed-tab.active {
    background: var(--color-celeste);
    color: #fff;
  }

  /* Feed list */
  .feed-page .feed-list {
    display: flex;
    flex-direction: column;
  }

  /* Status / loader */
  .feed-page .feed-status {
    padding: var(--spacing-xl) 0;
    text-align: center;
  }

  .feed-page .feed-loader {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--color-text-meta);
    font-size: 0.85rem;
  }

  .feed-page .feed-end {
    color: var(--color-text-meta);
    font-size: 0.85rem;
  }

  /* ========================================= */
  /* Dynamic card styles for JS-appended items */
  /* ========================================= */
  .feed-list .card--list {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    background: transparent;
    border: none;
    border-radius: 0;
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .feed-list .card--list:first-child {
    padding-top: 0;
  }

  .feed-list .card--list:last-child {
    border-bottom: none;
  }

  .feed-list .card--list:hover {
    box-shadow: none;
    transform: none;
  }

  .feed-list .card--list .card-body {
    flex: 1;
    min-width: 0;
    padding: 0;
  }

  .feed-list .card--list .card-meta {
    font-size: 0.75rem;
    color: var(--color-text-meta);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }

  .feed-list .card--list .card-category {
    color: var(--cat-color, var(--color-gold-dark));
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
  }

  .feed-list .card--list .card-divider {
    color: var(--color-border);
  }

  .feed-list .card--list .card-reading-time {
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  .feed-list .card--list .card-link {
    display: block;
    color: var(--color-text);
    text-decoration: none;
  }

  .feed-list .card--list .card-link:hover .card-title {
    text-decoration: underline;
  }

  .feed-list .card--list .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
    color: var(--color-text);
  }

  .feed-list .card--list .card-desc {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0;
  }

  .feed-list .card--list .card-thumb {
    flex-shrink: 0;
    width: 180px;
  }

  .feed-list .card--list .card-thumb img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: 2px;
    transition: transform 0.2s;
  }

  .feed-list .card--list .card-thumb:hover img {
    transform: scale(1.03);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .feed-page .feed-heading {
      font-size: 1.6rem;
    }

    .feed-page .feed-tabs {
      gap: 6px;
    }

    .feed-page .feed-tab {
      padding: 5px 12px;
      font-size: 0.75rem;
    }

    .feed-list .card--list .card-title {
      font-size: 0.95rem;
    }

    .feed-list .card--list .card-desc {
      display: none;
    }

    .feed-list .card--list .card-thumb {
      width: 110px;
    }
  }
</style>
