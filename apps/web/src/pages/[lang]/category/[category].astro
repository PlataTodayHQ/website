---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { LANGUAGES, CATEGORIES, SUBCATEGORIES } from "@plata-today/shared";
import type { Category } from "@plata-today/shared";
import { t } from "@/i18n";
import {
  getArticlesByCategory,
  timeAgo,
  readingTime,
  type ArticleRow,
} from "@/lib/db";

export const prerender = false;

const { lang, category } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const catKey = category as Category;
const catLabel = t(lang!, `cat.${catKey}` as any) || CATEGORIES[catKey] || category;
const subcats = SUBCATEGORIES[catKey] ?? {};

// ---------------------------------------------------------------------------
// Fetch articles from SQLite (server-rendered)
// ---------------------------------------------------------------------------
const dbArticles = getArticlesByCategory(lang!, catKey, 20);

function mapRow(a: ArticleRow) {
  return {
    title: a.title,
    href: `/${lang}/news/${a.slug}`,
    description: a.meta_description ?? "",
    imageUrl: a.image_url ?? "/images/placeholder.svg",
    timeAgo: timeAgo(a.published_at, lang!),
    subcategory: t(lang!, `cat.${a.category}` as any) || CATEGORIES[a.category as Category] || a.category,
    categoryKey: a.category,
    readingTime: readingTime(a.word_count, lang!),
  };
}

const articles = dbArticles.map(mapRow);
const featured = articles[0] ?? null;
const latestArticles = articles.slice(1, 5);
const olderArticles = articles.slice(5);
---

<Base
  title={t(lang!, "category.newsTitle" as any).replace("{cat}", catLabel)}
  description={t(lang!, "category.newsDesc" as any).replace("{cat}", catLabel.toLowerCase())}
  lang={lang}
  activeCategory={category}
  ogType="website"
  ogImage={featured?.imageUrl ?? "/images/placeholder.svg"}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: catLabel, url: `/${lang}/category/${category}` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${catLabel} — Plata`,
    "description": `Latest ${catLabel.toLowerCase()} news from Argentina`,
    "url": `https://plata.today/${lang}/category/${category}`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <!-- Category header -->
  <div class="cat-header">
    <h1 class="cat-title">{catLabel}</h1>
    <nav class="cat-subs" aria-label={`${catLabel} subcategories`}>
      {Object.entries(subcats).map(([subKey, subLabel]) => (
        <a href={`/${lang}/category/${category}?sub=${subKey}`} class="sub-pill">
          {subLabel}
        </a>
      ))}
    </nav>
  </div>

  <!-- Featured article -->
  {featured && (
    <section class="cat-featured" aria-label={`Featured ${catLabel.toLowerCase()} article`}>
      <ArticleCard
        title={featured.title}
        description={featured.description}
        href={featured.href}
        imageUrl={featured.imageUrl}
        timeAgo={featured.timeAgo}
        category={featured.subcategory}
        categoryKey={featured.categoryKey}
        readingTime={featured.readingTime}
        variant="hero"
      />
    </section>
  )}

  <!-- Latest in category -->
  {latestArticles.length > 0 && <SectionHeader title={t(lang!, "category.latestIn" as any).replace("{cat}", catLabel)} />}
  {latestArticles.length > 0 && (
    <section class="cat-grid" aria-label={t(lang!, "category.latestIn" as any).replace("{cat}", catLabel)}>
      {latestArticles.map((a) => (
        <ArticleCard
          title={a.title}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.categoryKey}
          readingTime={a.readingTime}
          variant="compact"
        />
      ))}
    </section>
  )}

  <!-- Older articles -->
  {olderArticles.length > 0 && <SectionHeader title={t(lang!, "category.earlier" as any)} />}
  {olderArticles.length > 0 && (
    <section class="cat-list" aria-label="Earlier articles">
      {olderArticles.map((a) => (
        <ArticleCard
          title={a.title}
          description={a.description}
          href={a.href}
          imageUrl={a.imageUrl}
          timeAgo={a.timeAgo}
          category={a.subcategory}
          categoryKey={a.categoryKey}
          readingTime={a.readingTime}
          variant="list"
        />
      ))}
    </section>
  )}

  <!-- Empty state -->
  {articles.length === 0 && (
    <div class="cat-empty">
      <p>{t(lang!, "category.noArticles" as any)}</p>
    </div>
  )}
</Base>

<style>
  /* ========================= */
  /* CATEGORY HEADER            */
  /* ========================= */
  .cat-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .cat-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
  }

  .cat-subs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sub-pill {
    display: inline-block;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    border-radius: 100px;
    transition: background 0.15s, color 0.15s;
  }

  .sub-pill:hover {
    background: var(--color-celeste);
    color: #fff;
    text-decoration: none;
  }

  /* ========================= */
  /* FEATURED                   */
  /* ========================= */
  .cat-featured {
    margin-bottom: var(--spacing-xl);
  }

  /* ========================= */
  /* ARTICLE GRID (compact)     */
  /* ========================= */
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: var(--spacing-xl);
  }

  .cat-grid :global(.card--compact) {
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cat-grid :global(.card--compact:nth-child(odd)) {
    padding-right: var(--spacing-xl);
    border-right: 1px solid var(--color-border);
  }

  .cat-grid :global(.card--compact:nth-child(even)) {
    padding-left: var(--spacing-xl);
  }

  .cat-grid :global(.card--compact:nth-last-child(-n+2)) {
    border-bottom: none;
  }

  /* ========================= */
  /* LIST (ArticleCard list)    */
  /* ========================= */
  .cat-list {
    max-width: var(--content-width);
    margin-bottom: var(--spacing-2xl);
  }

  /* ========================= */
  /* EMPTY STATE                */
  /* ========================= */
  .cat-empty {
    text-align: center;
    padding: var(--spacing-2xl) 0;
    color: var(--color-text-meta);
    font-size: 1.1rem;
  }

  /* ========================= */
  /* MOBILE                     */
  /* ========================= */
  @media (max-width: 640px) {
    .cat-title {
      font-size: 1.6rem;
    }

    .cat-grid {
      grid-template-columns: 1fr;
    }

    .cat-grid :global(.card--compact) {
      padding: 16px 0;
    }

    .cat-grid :global(.card--compact:nth-child(odd)) {
      padding-right: 0;
      border-right: none;
    }

    .cat-grid :global(.card--compact:nth-child(even)) {
      padding-left: 0;
    }

    .cat-grid :global(.card--compact:last-child) {
      border-bottom: none;
    }
  }
</style>
