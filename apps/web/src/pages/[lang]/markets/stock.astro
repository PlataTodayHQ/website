---
/**
 * Redirect legacy ?s=SYMBOL URLs to the new path-based route.
 * /en/markets/stock?s=YPFD → /en/markets/stock/YPFD (301)
 */
import { LANGUAGES } from "@plata-today/shared";

export const prerender = false;

const { lang } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const symbol = Astro.url.searchParams.get("s");
if (symbol) {
  return Astro.redirect(`/${lang}/markets/stock/${encodeURIComponent(symbol)}`, 301);
}

// No symbol — go to screener
return Astro.redirect(`/${lang}/markets/screener`, 302);
---
