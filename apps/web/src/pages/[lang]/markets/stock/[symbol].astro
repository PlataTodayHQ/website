---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export const prerender = false;

const { lang, symbol: rawSymbolParam } = Astro.params;

if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const rawSymbol = decodeURIComponent(rawSymbolParam ?? "");
const symbol = rawSymbol.replace(/\.BA$/i, "");

if (!symbol) {
  return Astro.redirect(`/${lang}/markets/screener`, 302);
}

// Build i18n JSON for client-side JS
const stockI18n = {
