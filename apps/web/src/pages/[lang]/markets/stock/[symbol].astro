        // ── Dividend History ──
        if (det.dividendRate != null && det.dividendRate > 0) {
          fetch('/api/stock/' + encodeURIComponent(symbol) + '?range=5y&events=div')
            .then(function(r) { return r.json(); })
            .then(function(chartData) {
