---

<Base
  title={symbol ? `${symbol} — ${t(lang, "stock.pageTitle")}` : t(lang, "stock.pageTitle")}
  description={t(lang, "stock.pageDesc")}
  lang={lang}
  ogType="website"
  canonicalUrl={symbol ? `https://plata.today/${lang}/markets/stock/${symbol}` : undefined}
  alternateUrls={symbol ? Object.fromEntries(Object.keys(LANGUAGES).map(code => [code, `https://plata.today/${code}/markets/stock/${symbol}`])) : undefined}
  noindex={!symbol}
  breadcrumbs={[
    { name: t(lang, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang, "markets.breadcrumb"), url: `/${lang}/markets` },
    { name: t(lang, "merval.breadcrumb"), url: `/${lang}/markets/merval` },
    { name: symbol || t(lang, "stock.pageTitle"), url: `/${lang}/markets/stock${symbol ? `?s=${symbol}` : ""}` },
  ]}
  jsonLd={symbol ? {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `${symbol} — ${t(lang, "stock.pageTitle")}`,
    "description": t(lang, "stock.pageDesc"),
    "url": `https://plata.today/${lang}/markets/stock/${symbol}`,
    "inLanguage": lang,
    "about": {
      "@type": "FinancialProduct",
      "name": symbol,
      "url": `https://plata.today/${lang}/markets/stock/${symbol}`,
      "provider": {
        "@type": "Exchange",
        "name": "BYMA — Bolsas y Mercados Argentinos"
      }
    },
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  } : undefined}
>
  <div class="stock-page" data-stock-page data-lang={lang} data-symbol={symbol} data-i18n={JSON.stringify(stockI18n)}>
    <MarketNav lang={lang} />

    <!-- Error state (no symbol) -->
    <div class="stock-empty" data-stock-empty style="display:none;">
      <svg class="stock-empty-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 16l4-4 3 3 4-4"/></svg>
      <h1 class="mkts-title">{t(lang, "stock.noSelected")}</h1>
      <p class="stock-empty-msg">{t(lang, "stock.selectPrompt")}</p>
      <a href={`/${lang}/markets/merval`} class="back-link">&larr; {t(lang, "stock.viewMerval")}</a>
    </div>

    <!-- Stock content (populated by JS) -->
    <div class="stock-content" data-stock-content style="display:none;">
      <header class="mkts-header">
        <div>
          <div class="stock-title-row">
            <h1 class="mkts-title" data-stock-symbol>{symbol || "\u2014"}</h1>
            <span class="rc-badge rc-badge--merval">BYMA</span>
            <button class="wl-detail-star" data-wl-detail-star aria-label="Watchlist" title="Watchlist" data-i18n-added-to-watchlist="Added to watchlist" data-i18n-removed-from-watchlist="Removed from watchlist">&#9734;</button>
            <button class="share-btn" data-share-btn aria-label={t(lang, "stock.share" as any)} title={t(lang, "stock.share" as any)} style="display:none;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l4-4m0 0H7m3 0v3M13 8v5a1 1 0 01-1 1H4a1 1 0 01-1-1V4a1 1 0 011-1h5"/></svg>
            </button>
          </div>
          <p class="mkts-subtitle" data-stock-name>{t(lang!, "common.loading")}</p>
          <div class="stock-badges" data-stock-badges style="display:none;"></div>
        </div>
        <p class="mkts-updated" data-mkts-updated role="status" aria-live="polite">{t(lang!, "common.loading")}</p>
      </header>

      <!-- Price Card -->
      <div class="price-card price-card--loading" data-price-card role="region" aria-label={t(lang, "stock.priceChart")}>
        <div class="pc-main" aria-live="polite">
          <span class="pc-price" data-stock-price>&mdash;</span>
          <span class="pc-change" data-stock-change></span>
          <span class="pc-currency" data-stock-currency>ARS</span>
        </div>
        <!-- Today's Range -->
        <div class="pc-range" data-pc-range style="display:none;">
          <div class="pc-range-head">
            <span class="pc-range-label">{t(lang, "stock.dayRange")}</span>
          </div>
          <div class="pc-range-bar">
            <span class="pc-range-lo" data-pc-range-lo></span>
            <div class="pc-range-track">
              <div class="pc-range-fill" data-pc-range-fill></div>
              <div class="pc-range-dot" data-pc-range-dot></div>
            </div>
            <span class="pc-range-hi" data-pc-range-hi></span>
          </div>
        </div>
        <div class="pc-stats">
          <div class="pc-stat">
            <span class="pc-sk">{t(lang, "stock.open")}</span>
            <span class="pc-sv" data-stock-open>&mdash;</span>
          </div>
          <div class="pc-stat">
            <span class="pc-sk">{t(lang, "stock.high")}</span>
            <span class="pc-sv" data-stock-high>&mdash;</span>
          </div>
          <div class="pc-stat">
            <span class="pc-sk">{t(lang, "stock.low")}</span>
            <span class="pc-sv" data-stock-low>&mdash;</span>
          </div>
          <div class="pc-stat">
            <span class="pc-sk">{t(lang, "stock.prevClose")}</span>
            <span class="pc-sv" data-stock-prev>&mdash;</span>
          </div>
          <div class="pc-stat">
            <span class="pc-sk">{t(lang, "stock.volume")}</span>
            <span class="pc-sv" data-stock-volume>&mdash;</span>
          </div>
        </div>
      </div>

      <!-- Section Navigation -->
      <nav class="section-nav" data-section-nav style="display:none;" aria-label={t(lang, "stock.sectionNav" as any)}></nav>

      <!-- Company Overview Hero -->
      <section class="company-hero" data-company-hero style="display:none;">
        <div class="ch-identity">
          <div class="ch-logo" data-ch-logo>
            <img class="ch-logo-img" data-ch-logo-img alt="" loading="lazy" width="64" height="64" />
            <div class="ch-logo-fallback" data-ch-logo-fb></div>
          </div>
          <div class="ch-info">
            <h2 class="ch-name" data-ch-name></h2>
            <div class="ch-tags" data-ch-tags>
              <span class="ch-tag ch-tag--sector" data-ch-sector></span>
              <span class="ch-tag ch-tag--industry" data-ch-industry></span>
            </div>
          </div>
        </div>
        <div class="ch-pills" data-ch-pills>
          <div class="ch-pill" data-ch-mcap-pill style="display:none;">
            <span class="ch-pill-icon">📊</span>
            <span class="ch-pill-v" data-ch-mcap-v></span>
          </div>
          <div class="ch-pill" data-ch-emp-pill style="display:none;">
            <span class="ch-pill-icon">👥</span>
            <span class="ch-pill-v" data-ch-emp-v></span>
          </div>
          <div class="ch-pill" data-ch-loc-pill style="display:none;">
