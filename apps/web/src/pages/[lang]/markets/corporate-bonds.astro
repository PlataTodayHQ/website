---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import MarketHeader from "@/components/MarketHeader.astro";
import EducationPanel from "@/components/EducationPanel.astro";
import AssetStats from "@/components/AssetStats.astro";
import AssetSearch from "@/components/AssetSearch.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "corporateBonds.seoTitle")}
  description={t(lang!, "corporateBonds.seoDescription")}
  lang={lang}
  ogType="website"
  alternateUrls={Object.fromEntries(Object.keys(LANGUAGES).map(code => [code, `https://plata.today/${code}/markets/corporate-bonds`]))}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "markets.breadcrumb"), url: `/${lang}/markets` },
    { name: t(lang!, "corporateBonds.breadcrumb"), url: `/${lang}/markets/corporate-bonds` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "corporateBonds.title"),
    "description": t(lang!, "corporateBonds.seoDescription"),
    "url": `https://plata.today/${lang}/markets/corporate-bonds`,
    "inLanguage": lang,
    "isPartOf": { "@type": "WebSite", "name": "Plata", "url": "https://plata.today" }
  }}
>
  <div class="asset-page" data-asset-page data-lang={lang} data-api="/api/corporate-bonds" data-asset-type="corporate_bond"
    data-i18n-updated={t(lang!, "stock.updated")}
    data-i18n-retry={t(lang!, "common.retry" as any)}
    data-i18n-error={t(lang!, "corporateBonds.loadError" as any)}
    data-i18n-no-results={t(lang!, "screener.noResults")}
    data-i18n-prev-close={t(lang!, "bonds.prevClose" as any)}
    data-i18n-high={t(lang!, "stock.high" as any)}
    data-i18n-low={t(lang!, "stock.low" as any)}
    data-stock-url={`/${lang}/markets/stock`}
  >
    <MarketNav lang={lang!} active="corporate-bonds" />

    <MarketHeader
      title={t(lang!, "corporateBonds.title")}
      subtitle={t(lang!, "corporateBonds.subtitle" as any)}
      loadingText={t(lang!, "common.loading")}
    />

    <EducationPanel
      title={t(lang!, "corporateBonds.infoTitle" as any)}
      text={t(lang!, "corporateBonds.infoText" as any)}
      open
      cards={[
        { label: t(lang!, "corporateBonds.infoIssuer" as any), value: t(lang!, "corporateBonds.infoIssuerVal" as any) },
        { label: t(lang!, "corporateBonds.infoRisk" as any), value: t(lang!, "corporateBonds.infoRiskVal" as any) },
        { label: t(lang!, "corporateBonds.infoAdvantage" as any), value: t(lang!, "corporateBonds.infoAdvantageText" as any), wide: true },
      ]}
    />

    <AssetStats stats={[
      { label: t(lang!, "bonds.instruments" as any), dataKey: "count" },
      { label: t(lang!, "screener.gainers" as any), dataKey: "gainers", colorClass: "rc-up" },
      { label: t(lang!, "screener.losers" as any), dataKey: "losers", colorClass: "rc-down" },
      { label: t(lang!, "screener.totalVolume" as any), dataKey: "volume", defaultValue: "—" },
    ]} />

    <AssetSearch placeholder={t(lang!, "screener.search")} />

    <div class="asset-table-wrap" role="region" aria-label={t(lang!, "corporateBonds.title")}>
      <table class="asset-table" data-asset-table>
        <thead>
          <tr>
            <th class="at-th at-th--name" data-sort="symbol">{t(lang!, "screener.col.symbol")} <span class="at-arrow" data-arrow="symbol"></span></th>
            <th class="at-th at-th--num" data-sort="price">{t(lang!, "corporateBonds.col.price" as any)} <span class="at-arrow" data-arrow="price"></span></th>
            <th class="at-th at-th--num" data-sort="change">{t(lang!, "screener.col.change")} <span class="at-arrow" data-arrow="change"></span></th>
            <th class="at-th at-th--num at-th--active" data-sort="volume">{t(lang!, "screener.col.volume")} <span class="at-arrow" data-arrow="volume">▼</span></th>
            <th class="at-th at-th--num at-th--hide-mobile" data-sort="previousClose">{t(lang!, "bonds.prevClose" as any)}</th>
            <th class="at-th at-th--num at-th--hide-mobile" data-sort="high">{t(lang!, "stock.high" as any)}</th>
            <th class="at-th at-th--num at-th--hide-mobile" data-sort="low">{t(lang!, "stock.low" as any)}</th>
          </tr>
        </thead>
        <tbody data-asset-tbody>
          {[...Array(10)].map(() => (
            <tr class="at-skeleton-row">
              <td class="at-td at-td--name"><span class="skeleton-shimmer" style="width:80px;height:14px;display:inline-block;"></span></td>
              <td class="at-td at-td--num"><span class="skeleton-shimmer" style="width:70px;height:14px;display:inline-block;"></span></td>
              <td class="at-td at-td--num"><span class="skeleton-shimmer" style="width:64px;height:22px;display:inline-block;border-radius:4px;"></span></td>
              <td class="at-td at-td--num"><span class="skeleton-shimmer" style="width:50px;height:14px;display:inline-block;"></span></td>
              <td class="at-td at-td--num at-td--hide-mobile"><span class="skeleton-shimmer" style="width:60px;height:14px;display:inline-block;"></span></td>
              <td class="at-td at-td--num at-td--hide-mobile"><span class="skeleton-shimmer" style="width:60px;height:14px;display:inline-block;"></span></td>
              <td class="at-td at-td--num at-td--hide-mobile"><span class="skeleton-shimmer" style="width:60px;height:14px;display:inline-block;"></span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="asset-cards" data-asset-cards>
      {[...Array(6)].map(() => (
        <div class="at-skeleton-card">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
            <div style="display:flex;flex-direction:column;gap:4px;flex:1;">
              <span class="skeleton-shimmer" style="width:56px;height:12px;"></span>
              <span class="skeleton-shimmer" style="width:90px;height:10px;"></span>
            </div>
            <span class="skeleton-shimmer" style="width:60px;height:16px;border-radius:4px;"></span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span class="skeleton-shimmer" style="width:80px;height:14px;"></span>
            <span class="skeleton-shimmer" style="width:50px;height:10px;"></span>
          </div>
        </div>
      ))}
    </div>

    <div class="asset-empty" data-asset-empty style="display:none;"></div>

    <p class="info-disclaimer">{t(lang!, "stock.disclaimer")}</p>
    <noscript><p class="info-disclaimer" style="text-align:center;padding:2rem;font-weight:600;">{t(lang!, "common.jsRequired" as any)}</p></noscript>
  </div>
</Base>

<script is:inline src="/js/market-helpers.js?v=2"></script>
<script is:inline src="/js/watchlist.js?v=1"></script>
<script is:inline src="/js/asset-listing.js?v=4"></script>

