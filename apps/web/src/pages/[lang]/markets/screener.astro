    vertical-align: middle;
  }
  :global(.scr-td--num) { text-align: right; font-weight: 600; }
  :global(.scr-td--text) { font-size: 0.75rem; color: var(--color-text-secondary); max-width: 140px; overflow: hidden; text-overflow: ellipsis; }
  :global(.scr-td--name) { padding-left: 12px; min-width: 200px; }

  /* Name cell — :global() needed because HTML is injected via JS innerHTML */
  .scr-th--name { min-width: 200px; width: 22%; }
