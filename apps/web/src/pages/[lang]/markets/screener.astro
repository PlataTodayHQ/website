    height: 100%; background: var(--color-gold); border-radius: 2px;
    opacity: 0.5;
  }
  :global(.scr-range-dot) {
    position: absolute; top: 50%; transform: translate(-50%, -50%);
    width: 8px; height: 8px; background: var(--color-gold);
    border-radius: 50%; border: 1.5px solid var(--color-bg);
  }

  /* Loading */
  .scr-loading { text-align: center; color: var(--color-text-meta); padding: var(--spacing-xl); font-size: 0.85rem; }
  .loading-spinner { margin-right: 8px; vertical-align: middle; }

  .scr-empty { text-align: center; color: var(--color-text-meta); padding: var(--spacing-2xl); font-size: 0.9rem; font-style: italic; }

  .info-disclaimer { margin-top: var(--spacing-xl); }

  /* Cards: hidden on desktop */
  .scr-cards { display: none; }

  /* Market Breadth */
  .scr-breadth {
    margin-bottom: 1rem; padding: 12px 16px;
    background: var(--color-bg-secondary); border-radius: 10px;
    border: 1px solid var(--color-border);
  }
  .scr-breadth-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;
  }
  .scr-breadth-title {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--color-text-meta);
  }
  :global(.scr-breadth-counts) {
    display: flex; gap: 12px; font-size: 0.75rem; font-weight: 700;
  }
  :global(.scr-breadth-unch-label) { color: var(--color-text-meta); }
  .scr-breadth-bar {
    display: flex; height: 10px; border-radius: 5px; overflow: hidden;
    background: var(--color-border);
  }
