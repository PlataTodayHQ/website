  /* Change pill — :global() for JS-injected HTML */
  :global(.scr-pct) {
    display: inline-block; padding: 2px 8px; border-radius: 4px;
    font-size: 0.78rem; font-weight: 700;
  }
  :global(.scr-pct.rc-up) { background: rgba(22,163,74,0.12); color: #16a34a; }
  :global(.scr-pct.rc-down) { background: rgba(220,38,38,0.12); color: #dc2626; }

  :global(.scr-dim) { color: var(--color-text-meta); font-weight: 400; }

  /* 52W Range bar */
  :global(.scr-range) { display: flex; align-items: center; gap: 6px; min-width: 140px; }
  :global(.scr-range-lo), :global(.scr-range-hi) { font-size: 0.65rem; color: var(--color-text-meta); font-variant-numeric: tabular-nums; white-space: nowrap; }
