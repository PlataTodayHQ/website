---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import DisclaimerFooter from "@/components/DisclaimerFooter.astro";
import ScrollTopButton from "@/components/ScrollTopButton.astro";
import { LANGUAGES, getEconomicIndicators } from "@plata-today/shared";
import { buildAlternateUrls, buildMarketBreadcrumbs } from "@/lib/seo";
import { t } from "@/i18n";

export const prerender = false;

const { lang } = Astro.params;
if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

const indicators = getEconomicIndicators();
const currentValue = indicators?.countryRisk ?? null;

const seoTitle = currentValue
  ? t(lang!, "countryRisk.seoTitleWithValue").replace("{value}", String(Math.round(currentValue)))
  : t(lang!, "countryRisk.seoTitle");
const seoDescription = currentValue
  ? t(lang!, "countryRisk.seoDescriptionWithValue").replace("{value}", String(Math.round(currentValue)))
  : t(lang!, "countryRisk.seoDescription");
---

<Base
  title={seoTitle}
  description={seoDescription}
  lang={lang}
  ogType="website"
  alternateUrls={buildAlternateUrls("country-risk")}
  breadcrumbs={buildMarketBreadcrumbs(lang!, "countryRisk.breadcrumb", "country-risk")}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "countryRisk.jsonLdName"),
    "description": seoDescription,
    "url": `https://plata.today/${lang}/markets/country-risk`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <div class="mkts-page cr-page" data-cr-page data-lang={lang} data-i18n-updated={t(lang!, "countryRisk.updated")} data-i18n-bps={t(lang!, "countryRisk.bps")}>
    <MarketNav lang={lang!} active={"country-risk" as any} />

    <!-- Header -->
    <header class="mkts-page-header cr-header">
      <div class="mkts-page-header-row">
        <h1 class="mkts-page-title">{t(lang!, "countryRisk.title")} <span class="cr-title-sub">{t(lang!, "countryRisk.titleSub")}</span></h1>
        <span class="mkts-page-updated" data-cr-updated role="status" aria-live="polite">{t(lang!, "countryRisk.loading")}</span>
      </div>
    </header>

    <!-- Current Value Card -->
    <div class="mkts-card cr-hero">
      <div class="cr-hero-main">
        <span class="cr-hero-value" data-cr-value>{ currentValue ? Math.round(currentValue).toLocaleString() : "—" }</span>
        <span class="cr-hero-unit">{t(lang!, "countryRisk.bps")}</span>
        <span class="cr-hero-change" data-cr-change></span>
      </div>
      <div class="cr-hero-meta">
        <span class="cr-hero-label">{t(lang!, "countryRisk.embiSpread")}</span>
        <span class="cr-hero-source">{t(lang!, "countryRisk.sourceLabel")}</span>
      </div>
    </div>

    <!-- Chart -->
    <section class="cr-chart-section">
      <div class="cr-chart-head">
        <h2 class="mkts-section-title">{t(lang!, "countryRisk.historicalTrend")}</h2>
        <div class="cr-chart-tabs" data-cr-tabs>
          <button class="cr-tab" data-cr-tab="90">{t(lang!, "countryRisk.tab90d")}</button>
          <button class="cr-tab cr-tab--active" data-cr-tab="365">{t(lang!, "countryRisk.tab1y")}</button>
        </div>
      </div>
      <div class="cr-chart-wrap" data-cr-chart-wrap>
        <svg data-cr-chart class="cr-chart-svg" role="img" aria-label={t(lang!, "countryRisk.chartAriaLabel")}></svg>
      </div>
    </section>

    <!-- Stats Grid -->
    <section class="cr-stats-section">
      <h2 class="mkts-section-title">{t(lang!, "countryRisk.keyStatistics")}</h2>
      <div class="cr-stats-grid">
        <div class="cr-stat-card">
          <span class="mkts-label">{t(lang!, "countryRisk.current")}</span>
          <span class="cr-stat-value" data-cr-stat="current">—</span>
        </div>
        <div class="cr-stat-card">
          <span class="mkts-label">{t(lang!, "countryRisk.avg30d")}</span>
          <span class="cr-stat-value" data-cr-stat="avg30">—</span>
        </div>
        <div class="cr-stat-card">
          <span class="mkts-label">{t(lang!, "countryRisk.high52w")}</span>
          <span class="cr-stat-value cr-stat-value--danger" data-cr-stat="high52">—</span>
        </div>
        <div class="cr-stat-card">
          <span class="mkts-label">{t(lang!, "countryRisk.low52w")}</span>
          <span class="cr-stat-value cr-stat-value--success" data-cr-stat="low52">—</span>
        </div>
      </div>
    </section>

    <!-- Educational Panel -->
    <section class="mkts-card cr-edu-section" data-cr-edu>
      <div class="cr-edu-head">
        <h2 class="mkts-section-title">{t(lang!, "countryRisk.whatIsCountryRisk")}</h2>
        <button class="cr-edu-dismiss" data-cr-edu-dismiss aria-label={t(lang!, "countryRisk.dismissLabel")}>&times;</button>
      </div>
      <div class="cr-edu-body">
        <div class="cr-edu-card">
          <h3 class="cr-edu-subtitle">{t(lang!, "countryRisk.eduEmbiSpread")}</h3>
          <p class="cr-edu-text">
            {t(lang!, "countryRisk.eduEmbiSpreadDesc")}
          </p>
        </div>
        <div class="cr-edu-card">
          <h3 class="cr-edu-subtitle">{t(lang!, "countryRisk.eduWhatNumberMeans")}</h3>
          <p class="cr-edu-text">
            {t(lang!, "countryRisk.eduWhatNumberMeansDesc")}
          </p>
        </div>
        <div class="cr-edu-card">
          <h3 class="cr-edu-subtitle">{t(lang!, "countryRisk.eduWhyItMatters")}</h3>
          <p class="cr-edu-text">
            {t(lang!, "countryRisk.eduWhyItMattersDesc")}
          </p>
        </div>
        <div class="cr-edu-card">
          <h3 class="cr-edu-subtitle">{t(lang!, "countryRisk.eduHistoricalContext")}</h3>
          <p class="cr-edu-text">
            {t(lang!, "countryRisk.eduHistoricalContextDesc")}
          </p>
        </div>
      </div>
    </section>

    <DisclaimerFooter text={t(lang!, "countryRisk.disclaimer")} jsRequiredText={t(lang!, "common.jsRequired" as any)} className="cr-disclaimer" />

    <ScrollTopButton label={t(lang!, "countryRisk.scrollToTop")} />
  </div>
</Base>

<script is:inline src="/js/country-risk.js?v=1"></script>

<style>
  /* ═══ Country Risk Page ═══ */
  /* Layout: .mkts-page, .mkts-page-header, .mkts-card, .mkts-label, .mkts-section-title from global.css */

  .cr-title-sub { font-size: 0.85rem; font-weight: 600; color: var(--color-text-meta); margin-inline-start: 6px; }

  /* Hero value card — .mkts-card provides bg, border, radius, shadow */
  .cr-hero {
    padding: 24px 28px; margin-bottom: var(--spacing-xl);
    border-top: 3px solid var(--color-gold);
  }
  .cr-hero-main { display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px; }
  .cr-hero-value {
    font-size: 3rem; font-weight: 900; letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums; color: var(--color-text); line-height: 1;
  }
  .cr-hero-unit { font-size: 1.1rem; font-weight: 700; color: var(--color-text-meta); }
  .cr-hero-change { font-size: 0.9rem; font-weight: 700; font-variant-numeric: tabular-nums; margin-inline-start: 8px; }
  .cr-hero-meta { display: flex; gap: var(--spacing-lg); align-items: center; }
  .cr-hero-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-meta); }
  .cr-hero-source { font-size: 0.68rem; color: var(--color-text-meta); }

  /* Chart section */
  .cr-chart-section { margin-bottom: var(--spacing-xl); }
  .cr-chart-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--spacing-sm); }
  .cr-chart-tabs { display: flex; gap: 4px; }
  .cr-tab {
    padding: 4px 12px; border-radius: 16px; font-size: 0.72rem; font-weight: 700;
    background: var(--color-bg); border: 1px solid var(--color-border);
    color: var(--color-text-meta); cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .cr-tab:hover { border-color: var(--color-gold); color: var(--color-gold); }
  .cr-tab--active { background: var(--color-gold); color: #fff; border-color: var(--color-gold); }
  .cr-tab:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 2px; }
  .cr-chart-wrap {
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 12px; padding: var(--spacing-sm) var(--spacing-md);
    overflow: hidden;
  }
  .cr-chart-svg { width: 100%; display: block; }

  /* Chart SVG elements */
  :global(.cr-axis-label) { font-size: 11px; fill: var(--color-text-meta); font-family: inherit; }
  :global(.cr-grid-line) { stroke: var(--color-border); stroke-width: 1; stroke-dasharray: 4 3; }
  :global(.cr-tt-line) { stroke: var(--color-text-meta); stroke-width: 1; stroke-dasharray: 3 2; }
  :global(.cr-tt-dot) { fill: var(--color-gold); stroke: var(--color-bg); stroke-width: 2; }
  :global(.cr-tt-bg) { fill: var(--color-bg-secondary); stroke: var(--color-border); stroke-width: 1; }
  :global(.cr-tt-text) { font-size: 11px; fill: var(--color-text); font-family: inherit; font-weight: 600; }
  :global(.cr-hover-rect) { cursor: crosshair; }

  /* Stats Grid — .mkts-label from global.css */
  .cr-stats-section { margin-bottom: var(--spacing-xl); }
  .cr-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-sm); }
  .cr-stat-card {
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 16px; display: flex; flex-direction: column;
    gap: 4px; text-align: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cr-stat-card:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .cr-stat-value {
    font-size: 1.3rem; font-weight: 800; font-variant-numeric: tabular-nums;
    color: var(--color-text); line-height: 1.2;
  }
  .cr-stat-value--danger { color: #dc2626; }
  .cr-stat-value--success { color: #16a34a; }

  /* Educational panel — .mkts-card provides bg, border, radius, shadow */
  .cr-edu-section {
    margin-bottom: var(--spacing-xl); padding: 20px 24px;
    border-inline-start: 3px solid var(--color-gold);
  }
  .cr-edu-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--spacing-md); }
  .cr-edu-dismiss {
    background: none; border: none; font-size: 1.4rem; color: var(--color-text-meta);
    cursor: pointer; padding: 4px 8px; border-radius: 4px; line-height: 1;
    transition: color 0.15s, background 0.15s;
  }
  .cr-edu-dismiss:hover { color: var(--color-text); background: rgba(128,128,128,0.1); }
  .cr-edu-dismiss:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 2px; }
  .cr-edu-body { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-md); }
  .cr-edu-card { }
  .cr-edu-subtitle { font-size: 0.82rem; font-weight: 700; margin-bottom: 4px; color: var(--color-text); }
  .cr-edu-text { font-size: 0.78rem; line-height: 1.55; color: var(--color-text-meta); }

  /* Disclaimer */
  .cr-disclaimer {
    font-size: 0.7rem; color: var(--color-text-meta); text-align: center;
    margin-top: var(--spacing-md); padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }


  /* Live dot */
  :global(.live-dot) {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: #16a34a; margin-inline-end: 4px; vertical-align: middle;
    animation: live-pulse 2s ease-in-out infinite;
  }

  .cr-stats-section, .cr-edu-section { animation: fade-in-up 0.3s ease-out; }

  /* Dark mode */
  :global([data-theme="dark"]) .cr-hero { box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  :global([data-theme="dark"]) .cr-chart-wrap { box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  :global([data-theme="dark"]) .cr-stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.3); }
  :global([data-theme="dark"]) .cr-stat-value--danger { color: #f87171; }
  :global([data-theme="dark"]) .cr-stat-value--success { color: #4ade80; }

  /* Responsive */
  @media (max-width: 768px) {
    .cr-stats-grid { grid-template-columns: 1fr 1fr; }
    .cr-edu-body { grid-template-columns: 1fr; }
    .cr-hero-value { font-size: 2.2rem; }
  }
  @media (max-width: 480px) {
    .cr-stats-grid { grid-template-columns: 1fr; }
    .cr-hero { padding: 18px 16px; }
    .cr-hero-value { font-size: 1.8rem; }
    .cr-hero-meta { flex-direction: column; gap: 4px; }
  }
</style>
