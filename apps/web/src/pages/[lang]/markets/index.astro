---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import DisclaimerFooter from "@/components/DisclaimerFooter.astro";
import { getLocalizedStaticPaths } from "@/lib/static-paths";
import { buildAlternateUrls } from "@/lib/seo";
import { t } from "@/i18n";

export const getStaticPaths = getLocalizedStaticPaths;

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "markets.seoTitle")}
  description={t(lang!, "markets.seoDescription")}
  lang={lang}
  ogType="website"
  alternateUrls={buildAlternateUrls("")}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "markets.breadcrumb"), url: `/${lang}/markets` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "markets.title"),
    "description": t(lang!, "markets.subtitle"),
    "url": `https://plata.today/${lang}/markets`,
    "inLanguage": lang,
    "isPartOf": { "@type": "WebSite", "name": "Plata", "url": "https://plata.today" }
  }}
>
  <div class="mkt" data-markets-hub data-lang={lang}
    data-i18n-fear={t(lang!, "markets.fear")}
    data-i18n-greed={t(lang!, "markets.greed")}
    data-i18n-neutral={t(lang!, "markets.neutral")}
    data-i18n-updated={t(lang!, "stock.updated")}
    data-i18n-nstocks={t(lang!, "markets.nStocks" as any)}
    data-i18n-onestock={t(lang!, "markets.oneStock" as any)}
    data-i18n-error={t(lang!, "markets.failedToLoad" as any)}
    data-i18n-retry={t(lang!, "common.retry" as any)}
    data-i18n-check-conn={t(lang!, "common.checkConnection" as any)}
    data-i18n-commodities={JSON.stringify({
      'GC=F': t(lang!, "markets.gold" as any),
      'SI=F': t(lang!, "markets.silver" as any),
      'CL=F': t(lang!, "markets.crudeOil" as any),
      'NG=F': t(lang!, "markets.naturalGas" as any),
      'HG=F': t(lang!, "markets.copper" as any),
    })}
    data-i18n-sectors={JSON.stringify({
      Energy: t(lang!, "markets.sectorEnergy" as any),
      Finance: t(lang!, "markets.sectorFinance" as any),
      Telecom: t(lang!, "markets.sectorTelecom" as any),
      Materials: t(lang!, "markets.sectorMaterials" as any),
      Agriculture: t(lang!, "markets.sectorAgriculture" as any),
      Industry: t(lang!, "markets.sectorIndustry" as any),
      Holding: t(lang!, "markets.sectorHolding" as any),
      Media: t(lang!, "markets.sectorMedia" as any),
      Consumer: t(lang!, "markets.sectorConsumer" as any),
      'Real Estate': t(lang!, "markets.sectorRealEstate" as any),
      Other: t(lang!, "markets.sectorOther" as any),
    })}
  >
    <MarketNav lang={lang!} active="hub" />

    <!-- Header -->
    <header class="mkt-header">
      <div>
        <h1 class="mkt-h1">{t(lang!, "markets.title")}</h1>
        <p class="mkt-sub">{t(lang!, "markets.subtitle")}</p>
      </div>
      <div class="mkt-header-right">
        <span class="mkt-updated" data-mkt-updated aria-live="polite" role="status"></span>
        <div class="mkt-refresh-bar" data-refresh-bar aria-hidden="true"><div class="mkt-refresh-fill" data-refresh-fill></div></div>
      </div>
    </header>

    <!-- Market Status Timeline -->
    <div class="mkt-status-bar" data-mkt-status role="status" aria-label={t(lang!, "markets.title")}></div>

    <!-- At-a-glance summary (populated by JS) -->
    <div class="mkt-glance" data-mkt-glance style="display:none;" role="region" aria-label="Market summary">
      <div class="mkt-glance-item">
        <span class="mkt-glance-icon">🇦🇷</span>
        <div class="mkt-glance-body">
          <span class="mkt-glance-label">Blue</span>
          <span class="mkt-glance-val" data-glance-blue>—</span>
        </div>
      </div>
      <div class="mkt-glance-sep"></div>
      <div class="mkt-glance-item">
        <span class="mkt-glance-icon">📈</span>
        <div class="mkt-glance-body">
          <span class="mkt-glance-label">Merval</span>
          <span class="mkt-glance-val" data-glance-merval>—</span>
        </div>
      </div>
      <div class="mkt-glance-sep"></div>
      <div class="mkt-glance-item">
        <span class="mkt-glance-icon">₿</span>
        <div class="mkt-glance-body">
          <span class="mkt-glance-label">BTC</span>
          <span class="mkt-glance-val" data-glance-btc>—</span>
        </div>
      </div>
      <div class="mkt-glance-sep"></div>
      <div class="mkt-glance-item">
        <span class="mkt-glance-icon">🥇</span>
        <div class="mkt-glance-body">
          <span class="mkt-glance-label">Gold</span>
          <span class="mkt-glance-val" data-glance-gold>—</span>
        </div>
      </div>
    </div>

    <!-- ═══ FX RATES ROW ═══ -->
    <section class="mkt-section mkt-collapsible">
      <div class="mkt-sec-head">
        <button class="mkt-sec-toggle" aria-expanded="true">
          <h2 class="mkt-sec-title">{t(lang!, "markets.fxTitle")}</h2>
          <svg class="mkt-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mkt-sec-actions">
          <span class="mkt-sec-hint" title={t(lang!, "markets.fxDesc")}><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></span>
          <a href={`/${lang}/markets/currencies`} class="mkt-sec-link">{t(lang!, "finDash.viewAll" as any)} &rarr;</a>
        </div>
      </div>
      <div class="mkt-sec-body">
      <div class="mkt-fx-grid" role="region" aria-label={t(lang!, "markets.fxTitle")}>
        <a href={`/${lang}/markets/currencies`} class="mkt-fx-card mkt-fx-card--loading" data-mkt-fx="oficial" title={t(lang!, "markets.fxTooltipOficial" as any)}>
          <div class="mkt-fx-top">
            <span class="mkt-fx-name">USD {t(lang!, "markets.official")}</span>
            <span class="mkt-fx-badge mkt-fx-badge--oficial">{t(lang!, "currencies.bcra")}</span>
          </div>
          <div class="mkt-fx-mid">
            <span class="mkt-fx-price" data-fx-price="oficial">---</span>
            <span class="mkt-fx-chg" data-fx-chg="oficial"></span>
          </div>
          <div class="mkt-fx-spark" data-fx-spark="oficial"></div>
          <div class="mkt-fx-bs">
            <span>{t(lang!, "currencies.buy")} <b data-fx-buy="oficial">—</b></span>
            <span>{t(lang!, "currencies.sell")} <b data-fx-sell="oficial">—</b></span>
          </div>
        </a>
        <a href={`/${lang}/markets/currencies`} class="mkt-fx-card mkt-fx-card--blue mkt-fx-card--loading" data-mkt-fx="blue" title={t(lang!, "markets.fxTooltipBlue" as any)}>
          <div class="mkt-fx-top">
            <span class="mkt-fx-name">USD {t(lang!, "markets.blue")}</span>
            <span class="mkt-fx-badge mkt-fx-badge--blue">{t(lang!, "currencies.informal")}</span>
          </div>
          <div class="mkt-fx-mid">
            <span class="mkt-fx-price" data-fx-price="blue">---</span>
            <span class="mkt-fx-chg" data-fx-chg="blue"></span>
          </div>
          <div class="mkt-fx-spark" data-fx-spark="blue"></div>
          <div class="mkt-fx-bs">
            <span>{t(lang!, "currencies.buy")} <b data-fx-buy="blue">—</b></span>
            <span>{t(lang!, "currencies.sell")} <b data-fx-sell="blue">—</b></span>
          </div>
          <div class="mkt-fx-spread">
            <span class="mkt-fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="mkt-fx-spread-val" data-fx-gap="blue">—</span>
          </div>
        </a>
        <a href={`/${lang}/markets/currencies`} class="mkt-fx-card mkt-fx-card--loading" data-mkt-fx="mep" title={t(lang!, "markets.fxTooltipMep" as any)}>
          <div class="mkt-fx-top">
            <span class="mkt-fx-name">MEP</span>
            <span class="mkt-fx-badge mkt-fx-badge--mep">{t(lang!, "currencies.stockMarket")}</span>
          </div>
          <div class="mkt-fx-mid">
            <span class="mkt-fx-price" data-fx-price="mep">---</span>
          </div>
          <div class="mkt-fx-spark" data-fx-spark="mep"></div>
          <div class="mkt-fx-bs">
            <span>{t(lang!, "currencies.buy")} <b data-fx-buy="mep">—</b></span>
            <span>{t(lang!, "currencies.sell")} <b data-fx-sell="mep">—</b></span>
          </div>
          <div class="mkt-fx-spread">
            <span class="mkt-fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="mkt-fx-spread-val" data-fx-gap="mep">—</span>
          </div>
        </a>
        <a href={`/${lang}/markets/currencies`} class="mkt-fx-card mkt-fx-card--loading" data-mkt-fx="ccl" title={t(lang!, "markets.fxTooltipCcl" as any)}>
          <div class="mkt-fx-top">
            <span class="mkt-fx-name">CCL</span>
            <span class="mkt-fx-badge mkt-fx-badge--ccl">{t(lang!, "currencies.settlement")}</span>
          </div>
          <div class="mkt-fx-mid">
            <span class="mkt-fx-price" data-fx-price="ccl">---</span>
          </div>
          <div class="mkt-fx-spark" data-fx-spark="ccl"></div>
          <div class="mkt-fx-bs">
            <span>{t(lang!, "currencies.buy")} <b data-fx-buy="ccl">—</b></span>
            <span>{t(lang!, "currencies.sell")} <b data-fx-sell="ccl">—</b></span>
          </div>
          <div class="mkt-fx-spread">
            <span class="mkt-fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="mkt-fx-spread-val" data-fx-gap="ccl">—</span>
          </div>
        </a>
      </div>
      </div>
    </section>

    <!-- ═══ MERVAL + TOP MOVERS ═══ -->
    <section class="mkt-section mkt-collapsible">
      <div class="mkt-sec-head">
        <button class="mkt-sec-toggle" aria-expanded="true">
          <h2 class="mkt-sec-title">{t(lang!, "markets.mervalTitle")}</h2>
          <svg class="mkt-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mkt-sec-actions">
          <span class="mkt-sec-hint" title={t(lang!, "markets.mervalDesc")}><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></span>
          <a href={`/${lang}/markets/merval`} class="mkt-sec-link">{t(lang!, "finDash.viewAll" as any)} &rarr;</a>
        </div>
      </div>
      <div class="mkt-sec-body">
      <div class="mkt-merval-row">
        <!-- Merval summary -->
        <a href={`/${lang}/markets/merval`} class="mkt-idx-card mkt-idx-card--loading">
          <div class="mkt-idx-top">
            <span class="mkt-idx-label">MERVAL</span>
            <span class="mkt-idx-badge">BYMA</span>
          </div>
          <div class="mkt-idx-price-row">
            <span class="mkt-idx-price" data-idx-price>---</span>
            <span class="mkt-idx-chg" data-idx-chg></span>
          </div>
          <div class="mkt-idx-stats">
            <div class="mkt-idx-stat">
              <span class="mkt-idx-sk">{t(lang!, "merval.high")}</span>
              <span class="mkt-idx-sv" data-idx-high>—</span>
            </div>
            <div class="mkt-idx-stat">
              <span class="mkt-idx-sk">{t(lang!, "merval.low")}</span>
              <span class="mkt-idx-sv" data-idx-low>—</span>
            </div>
            <div class="mkt-idx-stat">
              <span class="mkt-idx-sk">{t(lang!, "merval.prevClose")}</span>
              <span class="mkt-idx-sv" data-idx-prev>—</span>
            </div>
            <div class="mkt-idx-stat">
              <span class="mkt-idx-sk">{t(lang!, "merval.volume")}</span>
              <span class="mkt-idx-sv" data-idx-vol>—</span>
            </div>
          </div>
          <div class="mkt-idx-chart">
            <canvas data-idx-chart height="120" role="img" aria-label={t(lang!, "merval.chartTitle")}></canvas>
          </div>
        </a>

        <!-- Top Movers -->
        <div class="mkt-movers">
          <div class="mkt-movers-cols">
            <div class="mkt-movers-col">
              <h3 class="mkt-movers-h3 mkt-movers-h3--up">{t(lang!, "finDash.topMovers" as any)}</h3>
              <div class="mkt-movers-list" data-movers-gainers></div>
            </div>
            <div class="mkt-movers-col">
              <h3 class="mkt-movers-h3 mkt-movers-h3--down">{t(lang!, "merval.sortChange")}</h3>
              <div class="mkt-movers-list" data-movers-losers></div>
            </div>
          </div>
          <a href={`/${lang}/markets/screener`} class="mkt-movers-footer">
            {t(lang!, "screener.title")} &rarr;
          </a>
        </div>
      </div>
      <!-- Market Breadth -->
      <div class="mkt-breadth" data-mkt-breadth style="display:none;">
        <div class="mkt-breadth-labels">
          <span class="mkt-breadth-lbl rc-up" data-breadth-up></span>
          <span class="mkt-breadth-lbl mkt-breadth-lbl--pct" data-breadth-pct></span>
          <span class="mkt-breadth-lbl rc-down" data-breadth-down></span>
        </div>
        <div class="mkt-breadth-bar">
          <div class="mkt-breadth-seg mkt-breadth-seg--up" data-breadth-bar-up></div>
          <div class="mkt-breadth-seg mkt-breadth-seg--unch" data-breadth-bar-unch></div>
          <div class="mkt-breadth-seg mkt-breadth-seg--down" data-breadth-bar-down></div>
        </div>
      </div>
      </div>
    </section>

    <!-- ═══ SECTOR HEATMAP ═══ -->
    <section class="mkt-section" data-mkt-sectors style="display:none;" role="region" aria-label={t(lang!, "markets.sectorHeatmap" as any)}>
      <h2 class="mkt-sec-title">{t(lang!, "markets.sectorHeatmap" as any)}</h2>
      <div class="mkt-heatmap" data-mkt-heatmap></div>
    </section>

    <!-- ═══ FIXED INCOME QUICK ACCESS ═══ -->
    <section class="mkt-section mkt-section--visible">
      <div class="mkt-sec-head">
        <h2 class="mkt-sec-title">{t(lang!, "markets.fixedIncomeSection" as any)}</h2>
        <span class="mkt-sec-hint" title={t(lang!, "markets.fixedIncomeDesc" as any)}><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></span>
      </div>
      <div class="mkt-fi-grid">
        <a href={`/${lang}/markets/bonds`} class="mkt-fi-card">
          <div class="mkt-fi-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20"/><path d="M12 4v16"/></svg>
          </div>
          <div class="mkt-fi-body">
            <span class="mkt-fi-name">{t(lang!, "bonds.title")}</span>
            <span class="mkt-fi-desc">{t(lang!, "bonds.subtitle" as any)}</span>
          </div>
          <svg class="mkt-fi-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href={`/${lang}/markets/corporate-bonds`} class="mkt-fi-card">
          <div class="mkt-fi-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
          </div>
          <div class="mkt-fi-body">
            <span class="mkt-fi-name">{t(lang!, "corporateBonds.title")}</span>
            <span class="mkt-fi-desc">{t(lang!, "corporateBonds.subtitle" as any)}</span>
          </div>
          <svg class="mkt-fi-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href={`/${lang}/markets/letras`} class="mkt-fi-card">
          <div class="mkt-fi-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="mkt-fi-body">
            <span class="mkt-fi-name">{t(lang!, "letras.title")}</span>
            <span class="mkt-fi-desc">{t(lang!, "letras.subtitle" as any)}</span>
          </div>
          <svg class="mkt-fi-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- ═══ MARKET PULSE ═══ -->
    <section class="mkt-section" data-mkt-pulse style="display:none;">
      <h2 class="mkt-sec-title">{t(lang!, "markets.marketPulse" as any)}</h2>
      <div class="mkt-pulse-grid">
        <div class="mkt-pulse-gauge">
          <div class="mkt-pulse-arc" data-pulse-arc></div>
          <div class="mkt-pulse-label" data-pulse-label>—</div>
          <div class="mkt-pulse-score" data-pulse-score>—</div>
        </div>
        <div class="mkt-pulse-stats">
          <div class="mkt-pulse-stat">
            <span class="mkt-pulse-sk">{t(lang!, "screener.gainers" as any)}</span>
            <span class="mkt-pulse-sv rc-up" data-pulse-up>—</span>
          </div>
          <div class="mkt-pulse-stat">
            <span class="mkt-pulse-sk">{t(lang!, "screener.losers" as any)}</span>
            <span class="mkt-pulse-sv rc-down" data-pulse-down>—</span>
          </div>
          <div class="mkt-pulse-stat">
            <span class="mkt-pulse-sk">{t(lang!, "screener.avgChange" as any)}</span>
            <span class="mkt-pulse-sv" data-pulse-avgchg>—</span>
          </div>
          <div class="mkt-pulse-stat">
            <span class="mkt-pulse-sk">{t(lang!, "screener.totalVolume" as any)}</span>
            <span class="mkt-pulse-sv" data-pulse-vol>—</span>
          </div>
        </div>
        <div class="mkt-pulse-vol">
          <h3 class="mkt-pulse-vol-h">{t(lang!, "markets.volumeLeaders" as any)}</h3>
          <div class="mkt-pulse-vol-list" data-pulse-vol-list></div>
        </div>
      </div>
    </section>

    <!-- ═══ GLOBAL INDICES ═══ -->
    <section class="mkt-section" data-indices-section style="display:none;"
      data-i18n-region-americas={t(lang!, "sub.us-canada" as any)}
      data-i18n-region-europe={t(lang!, "sub.europe" as any)}
      data-i18n-region-asia={t(lang!, "sub.asia" as any)}
    >
      <h2 class="mkt-sec-title">{t(lang!, "markets.globalIndices" as any)}</h2>
      <div class="mkt-indices-grid" data-indices-grid></div>
    </section>

    <!-- ═══ COMMODITIES ═══ -->
    <section class="mkt-section mkt-collapsible">
      <div class="mkt-sec-head">
        <button class="mkt-sec-toggle" aria-expanded="true">
          <h2 class="mkt-sec-title">{t(lang!, "markets.commoditiesTitle")}</h2>
          <svg class="mkt-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="mkt-curr-toggle" data-cmd-currency-toggle>
          <button class="mkt-curr-btn mkt-curr-btn--active" data-cmd-curr="USD">USD</button>
          <button class="mkt-curr-btn" data-cmd-curr="ARS">ARS</button>
        </div>
      </div>
      <div class="mkt-sec-body">
      <div class="mkt-asset-grid" data-commodities-grid>
        {[...Array(5)].map(() => (
          <div class="mkt-asset-skel">
            <span class="mkt-shimmer" style="width:32px;height:32px;border-radius:8px;flex-shrink:0;"></span>
            <div style="flex:1;display:flex;flex-direction:column;gap:4px;">
              <span class="mkt-shimmer" style="width:60%;height:12px;"></span>
              <span class="mkt-shimmer" style="width:40%;height:10px;"></span>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
              <span class="mkt-shimmer" style="width:60px;height:14px;"></span>
              <span class="mkt-shimmer" style="width:48px;height:12px;"></span>
            </div>
          </div>
        ))}
      </div>
      </div>
    </section>

    <!-- ═══ CRYPTO ═══ -->
    <section class="mkt-section mkt-collapsible">
      <div class="mkt-sec-head">
        <button class="mkt-sec-toggle" aria-expanded="true">
          <h2 class="mkt-sec-title">{t(lang!, "markets.cryptoTitle")}</h2>
          <svg class="mkt-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <a href={`/${lang}/markets/crypto`} class="mkt-sec-link">{t(lang!, "markets.cryptoViewAll")} &rarr;</a>
      </div>
      <div class="mkt-sec-body">
      <div class="mkt-asset-grid mkt-asset-grid--crypto" data-crypto-grid>
        {[...Array(6)].map(() => (
          <div class="mkt-asset-skel">
            <span class="mkt-shimmer" style="width:32px;height:32px;border-radius:50%;flex-shrink:0;"></span>
            <div style="flex:1;display:flex;flex-direction:column;gap:4px;">
              <span class="mkt-shimmer" style="width:50%;height:12px;"></span>
              <span class="mkt-shimmer" style="width:30%;height:10px;"></span>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
              <span class="mkt-shimmer" style="width:56px;height:14px;"></span>
              <span class="mkt-shimmer" style="width:44px;height:12px;"></span>
            </div>
          </div>
        ))}
      </div>
      </div>
    </section>

    <DisclaimerFooter text={t(lang!, "markets.disclaimer")} jsRequiredText={t(lang!, "common.jsRequired" as any)} className="mkt-disclaimer" />

    <button class="scroll-top-btn" data-scroll-top aria-label="↑" title="↑">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
    </button>
  </div>
</Base>

