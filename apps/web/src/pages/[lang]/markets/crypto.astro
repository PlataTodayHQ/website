---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import MarketHeader from "@/components/MarketHeader.astro";
import DisclaimerFooter from "@/components/DisclaimerFooter.astro";
import ScrollTopButton from "@/components/ScrollTopButton.astro";
import { getLocalizedStaticPaths } from "@/lib/static-paths";
import { buildMarketPageSEO } from "@/lib/seo";
import { t } from "@/i18n";

export const getStaticPaths = getLocalizedStaticPaths;

const { lang } = Astro.params;
const seo = buildMarketPageSEO({ lang: lang!, i18nKey: "crypto", route: "crypto", breadcrumbKey: "crypto.title" });
---

<Base {...seo}>
  <div class="crypto-page" data-crypto-page data-lang={lang}
    data-i18n-scarce={t(lang!, "crypto.scarce" as any)}
    data-i18n-moderate={t(lang!, "crypto.moderate" as any)}
    data-i18n-abundant={t(lang!, "crypto.abundant" as any)}
    data-i18n-nearath={t(lang!, "crypto.nearAth" as any)}
    data-i18n-updated={t(lang!, "stock.updated" as any)}
    data-i18n-cap={t(lang!, "merval.cap" as any)}
    data-i18n-coins={t(lang!, "crypto.coins" as any)}
    data-i18n-nocoins={t(lang!, "crypto.noCoins" as any)}
    data-i18n-others={t(lang!, "crypto.others" as any)}
    data-i18n-extremefear={t(lang!, "crypto.extremeFear" as any)}
    data-i18n-fear={t(lang!, "crypto.fear" as any)}
    data-i18n-neutral={t(lang!, "crypto.neutral" as any)}
    data-i18n-greed={t(lang!, "crypto.greed" as any)}
    data-i18n-extremegreed={t(lang!, "crypto.extremeGreed" as any)}
    data-i18n-error={t(lang!, "markets.failedToLoad" as any)}
    data-i18n-retry={t(lang!, "common.retry" as any)}
    data-i18n-checkconn={t(lang!, "common.checkConnection" as any)}
    data-i18n-trydifferent={t(lang!, "common.tryDifferentSearch" as any)}
  >
    <MarketNav lang={lang!} active="crypto" />

    <MarketHeader
      title={t(lang!, "crypto.title")}
      subtitle={t(lang!, "crypto.subtitle")}
      loadingText={t(lang!, "common.loading")}
    />

    <!-- Market Overview Skeleton -->
    <div class="cr-overview cr-skeleton-overview" data-cr-overview-skeleton>
      <div class="cr-ov-card">
        <div class="skeleton-shimmer" style="width:60%;height:10px;margin-bottom:6px;"></div>
        <div class="skeleton-shimmer" style="width:80%;height:22px;"></div>
      </div>
      <div class="cr-ov-card">
        <div class="skeleton-shimmer" style="width:50%;height:10px;margin-bottom:6px;"></div>
        <div class="skeleton-shimmer" style="width:70%;height:22px;"></div>
      </div>
      <div class="cr-ov-card">
        <div class="skeleton-shimmer" style="width:55%;height:10px;margin-bottom:6px;"></div>
        <div class="skeleton-shimmer" style="width:50%;height:22px;"></div>
      </div>
      <div class="cr-ov-card">
        <div class="skeleton-shimmer" style="width:65%;height:10px;margin-bottom:6px;"></div>
        <div class="skeleton-shimmer" style="width:60%;height:22px;"></div>
      </div>
      <div class="cr-ov-card cr-ov-card--wide">
        <div class="skeleton-shimmer" style="width:30%;height:10px;margin-bottom:6px;"></div>
        <div class="skeleton-shimmer" style="width:100%;height:8px;border-radius:4px;margin-bottom:6px;"></div>
        <div style="display:flex;gap:12px;">
          <div class="skeleton-shimmer" style="width:60px;height:10px;"></div>
          <div class="skeleton-shimmer" style="width:60px;height:10px;"></div>
          <div class="skeleton-shimmer" style="width:60px;height:10px;"></div>
        </div>
      </div>
    </div>

    <!-- Market Overview -->
    <div class="cr-overview" data-cr-overview style="display:none;">
      <div class="cr-ov-card">
        <span class="cr-ov-label">{t(lang!, "crypto.totalMcap")}</span>
        <span class="cr-ov-val" data-cr-total-mcap>—</span>
      </div>
      <div class="cr-ov-card">
        <span class="cr-ov-label">{t(lang!, "crypto.vol24h")}</span>
        <span class="cr-ov-val" data-cr-total-vol>—</span>
      </div>
      <div class="cr-ov-card">
        <span class="cr-ov-label">{t(lang!, "crypto.btcDom")}</span>
        <span class="cr-ov-val" data-cr-btc-dom>—</span>
      </div>
      <div class="cr-ov-card cr-ov-card--fg" data-cr-fg-card style="display:none;">
        <span class="cr-ov-label">{t(lang!, "crypto.fearGreed")}</span>
        <div class="cr-fg" data-cr-fg-gauge>
          <svg viewBox="0 0 200 120" class="cr-fg-svg" aria-hidden="true">
            <defs>
              <linearGradient id="fg-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#ea3943"/>
                <stop offset="25%" stop-color="#ea8c00"/>
                <stop offset="50%" stop-color="#c4c400"/>
                <stop offset="75%" stop-color="#16c784"/>
                <stop offset="100%" stop-color="#16c784"/>
              </linearGradient>
            </defs>
            <!-- Arc track (background) -->
            <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="var(--color-border)" stroke-width="12" stroke-linecap="round"/>
            <!-- Arc colored -->
            <path d="M 20 100 A 80 80 0 0 1 180 100" fill="none" stroke="url(#fg-gradient)" stroke-width="12" stroke-linecap="round"/>
            <!-- Tick marks: center (100,100), r_outer=88, r_inner=74 -->
            <!-- 0 at 180deg -->
            <line x1="12" y1="100" x2="26" y2="100" stroke="var(--color-text-meta)" stroke-width="1" opacity="0.5"/>
            <!-- 25 at 135deg -->
            <line x1="37.8" y1="37.8" x2="47.7" y2="47.7" stroke="var(--color-text-meta)" stroke-width="1" opacity="0.5"/>
            <!-- 50 at 90deg -->
            <line x1="100" y1="12" x2="100" y2="26" stroke="var(--color-text-meta)" stroke-width="1" opacity="0.5"/>
            <!-- 75 at 45deg -->
            <line x1="162.2" y1="37.8" x2="152.3" y2="47.7" stroke="var(--color-text-meta)" stroke-width="1" opacity="0.5"/>
            <!-- 100 at 0deg -->
            <line x1="188" y1="100" x2="174" y2="100" stroke="var(--color-text-meta)" stroke-width="1" opacity="0.5"/>
            <!-- Tick labels -->
            <text x="8" y="113" text-anchor="middle" class="cr-fg-tick">0</text>
            <text x="32" y="33" text-anchor="middle" class="cr-fg-tick">25</text>
            <text x="100" y="8" text-anchor="middle" class="cr-fg-tick">50</text>
            <text x="168" y="33" text-anchor="middle" class="cr-fg-tick">75</text>
            <text x="192" y="113" text-anchor="middle" class="cr-fg-tick">100</text>
            <!-- Needle -->
            <g class="cr-fg-needle-g" data-cr-fg-needle>
              <line x1="100" y1="100" x2="100" y2="30" stroke="var(--color-text)" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="100" cy="100" r="5" fill="var(--color-text)"/>
              <circle cx="100" cy="100" r="3" fill="var(--color-bg)"/>
            </g>
          </svg>
          <div class="cr-fg-center">
            <span class="cr-fg-val" data-cr-fg-val>—</span>
            <span class="cr-fg-label" data-cr-fg-label>—</span>
          </div>
        </div>
      </div>
      <div class="cr-ov-card cr-ov-card--wide">
        <span class="cr-ov-label">{t(lang!, "crypto.dominance")}</span>
        <div class="cr-dom-bar" data-cr-dom-bar></div>
        <div class="cr-dom-legend" data-cr-dom-legend></div>
      </div>
    </div>

    <!-- Top Movers -->
    <div class="cr-movers" data-cr-movers style="display:none;">
      <div class="cr-movers-col" data-cr-gainers>
        <h3 class="cr-movers-title cr-movers-title--up">{t(lang!, "crypto.topGainers" as any)}</h3>
      </div>
      <div class="cr-movers-col" data-cr-losers>
        <h3 class="cr-movers-title cr-movers-title--down">{t(lang!, "crypto.topLosers" as any)}</h3>
      </div>
    </div>

    <!-- 7-Day Performance -->
    <div class="cr-perf7d" data-cr-perf7d style="display:none;">
      <h3 class="cr-perf7d-title">{t(lang!, "crypto.perf7d" as any)}</h3>
      <div class="cr-perf7d-chart" data-cr-perf7d-chart></div>
    </div>

    <!-- Liquidity Overview -->
    <div class="cr-liquidity" data-cr-liquidity style="display:none;">
      <h3 class="cr-liq-title">{t(lang!, "crypto.liquidity" as any)}</h3>
      <div class="cr-liq-grid" data-cr-liq-grid></div>
    </div>

    <!-- ATH Distance -->
    <div class="cr-ath-section" data-cr-ath style="display:none;">
      <h3 class="cr-ath-title">{t(lang!, "crypto.athDistance" as any)}</h3>
      <div class="cr-ath-grid" data-cr-ath-grid></div>
    </div>

    <!-- Supply Pressure -->
    <div class="cr-supply-section" data-cr-supply style="display:none;">
      <h3 class="cr-supply-title">{t(lang!, "crypto.supplyPressure" as any)}</h3>
      <div class="cr-supply-grid" data-cr-supply-grid></div>
    </div>

    <!-- Market Cap Treemap -->
    <div class="cr-treemap-section" data-cr-treemap style="display:none;">
      <h3 class="cr-treemap-title">{t(lang!, "crypto.mcapTreemap" as any)}</h3>
      <div class="cr-treemap" data-cr-treemap-grid></div>
    </div>

    <!-- Toolbar -->
    <div class="cr-toolbar">
      <div class="cr-search-wrap">
        <svg class="cr-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" class="cr-search" data-cr-search placeholder={t(lang!, "screener.search")} aria-label={t(lang!, "screener.search")} autocomplete="off" />
        <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
      </div>
      <span class="cr-count" data-cr-count></span>
    </div>

    <!-- Category filter chips -->
    <div class="cr-cat-chips" data-cr-cat-chips style="display:none;"></div>

    <!-- Loading state with skeleton shimmer -->
    <div class="cr-loading" data-cr-loading>
      <!-- Skeleton movers -->
      <div class="cr-skeleton-movers">
        <div class="cr-skeleton-movers-col">
          <div class="skeleton-shimmer" style="width:80px;height:10px;margin-bottom:8px;"></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:60%;height:12px;"></div><div class="skeleton-shimmer" style="width:40%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:60px;height:12px;"></div><div class="skeleton-shimmer" style="width:45px;height:10px;"></div></div></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:50%;height:12px;"></div><div class="skeleton-shimmer" style="width:35%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:55px;height:12px;"></div><div class="skeleton-shimmer" style="width:40px;height:10px;"></div></div></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:55%;height:12px;"></div><div class="skeleton-shimmer" style="width:45%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:50px;height:12px;"></div><div class="skeleton-shimmer" style="width:42px;height:10px;"></div></div></div>
        </div>
        <div class="cr-skeleton-movers-col">
          <div class="skeleton-shimmer" style="width:80px;height:10px;margin-bottom:8px;"></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:55%;height:12px;"></div><div class="skeleton-shimmer" style="width:40%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:58px;height:12px;"></div><div class="skeleton-shimmer" style="width:44px;height:10px;"></div></div></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:65%;height:12px;"></div><div class="skeleton-shimmer" style="width:38%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:52px;height:12px;"></div><div class="skeleton-shimmer" style="width:40px;height:10px;"></div></div></div>
          <div class="cr-skeleton-mover-card"><div class="skeleton-shimmer" style="width:28px;height:28px;border-radius:50%;flex-shrink:0;"></div><div style="flex:1;display:flex;flex-direction:column;gap:4px;"><div class="skeleton-shimmer" style="width:50%;height:12px;"></div><div class="skeleton-shimmer" style="width:42%;height:10px;"></div></div><div style="display:flex;flex-direction:column;align-items:end;gap:4px;"><div class="skeleton-shimmer" style="width:56px;height:12px;"></div><div class="skeleton-shimmer" style="width:38px;height:10px;"></div></div></div>
        </div>
      </div>
      <!-- Skeleton treemap -->
      <div class="cr-skeleton-treemap">
        <div class="skeleton-shimmer" style="width:140px;height:12px;margin-bottom:12px;"></div>
        <div class="cr-skeleton-treemap-grid">
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:8;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:5;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:4;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:3;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:2.5;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:2;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:1.8;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:1.5;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:1.2;"></div>
          <div class="skeleton-shimmer cr-skeleton-tm-cell" style="flex:1;"></div>
        </div>
      </div>
      <!-- Skeleton table rows -->
      <div class="cr-skeleton-table">
        <div class="cr-skeleton-table-header">
          <div class="skeleton-shimmer" style="width:30px;height:10px;"></div>
          <div class="skeleton-shimmer" style="width:120px;height:10px;"></div>
          <div class="skeleton-shimmer" style="width:60px;height:10px;margin-inline-start:auto;"></div>
          <div class="skeleton-shimmer" style="width:50px;height:10px;"></div>
