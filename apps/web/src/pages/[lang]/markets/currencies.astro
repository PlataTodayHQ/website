---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "currencies.seoTitle")}
  description={t(lang!, "currencies.seoDescription")}
  lang={lang}
  ogType="website"
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "markets.breadcrumb"), url: `/${lang}/markets` },
    { name: t(lang!, "currencies.breadcrumb"), url: `/${lang}/markets/currencies` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "currencies.title"),
    "description": t(lang!, "currencies.subtitle"),
    "url": `https://plata.today/${lang}/markets/currencies`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <div class="fx-page" data-currencies-page>
    <!-- Header -->
    <header class="fx-header">
      <div class="fx-header-left">
        <h1 class="fx-title">{t(lang!, "currencies.title")}</h1>
        <span class="fx-updated" data-mkts-updated>{t(lang!, "currencies.loading")}</span>
      </div>
    </header>

    <!-- Rate Strip -->
    <div class="fx-strip">
      <div class="fx-rate" id="official">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdOfficial")}</span>
          <span class="fx-badge">{t(lang!, "currencies.bcra")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="official">—</span>
          <span class="fx-change" data-rc-change="official"></span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="official">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="official">—</span></div>
        </div>
        <div class="fx-spark"><canvas data-spark="official" height="48"></canvas></div>
      </div>

      <div class="fx-rate fx-rate--blue" id="blue">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdBlue")}</span>
          <span class="fx-badge fx-badge--blue">{t(lang!, "currencies.informal")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="blue">—</span>
          <span class="fx-change" data-rc-change="blue"></span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="blue">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="blue">—</span></div>
        </div>
        <div class="fx-spread-row">
          <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="fx-spread-val" data-spread-pct="blue">—</span>
        </div>
        <div class="fx-spark"><canvas data-spark="blue" height="48"></canvas></div>
      </div>

      <div class="fx-rate fx-rate--mep" id="mep">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdMep")}</span>
          <span class="fx-badge fx-badge--mep">{t(lang!, "currencies.stockMarket")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="mep">—</span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="mep">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="mep">—</span></div>
        </div>
        <div class="fx-spread-row">
          <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="fx-spread-val" data-spread-pct="mep">—</span>
        </div>
      </div>

      <div class="fx-rate fx-rate--ccl" id="ccl">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdCcl")}</span>
          <span class="fx-badge fx-badge--ccl">{t(lang!, "currencies.settlement")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="ccl">—</span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="ccl">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="ccl">—</span></div>
        </div>
        <div class="fx-spread-row">
          <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="fx-spread-val" data-spread-pct="ccl">—</span>
        </div>
      </div>
    </div>

    <!-- Chart -->
    <section class="fx-chart-section">
      <div class="fx-chart-head">
        <h2 class="fx-chart-title">{t(lang!, "currencies.evoTitle")}</h2>
        <div class="fx-legend">
          <span class="fx-leg fx-leg--official"><span class="fx-dot"></span> {t(lang!, "markets.official")}</span>
          <span class="fx-leg fx-leg--blue"><span class="fx-dot"></span> {t(lang!, "markets.blue")}</span>
        </div>
      </div>
      <div class="fx-chart-wrap">
        <canvas data-evo-chart height="320"></canvas>
      </div>
    </section>

    <!-- History Table -->
    <section class="fx-table-section">
      <h2 class="fx-section-title">{t(lang!, "currencies.recentHistory")}</h2>
      <div class="fx-table-wrap">
        <table class="fx-table" data-comparison-table>
          <thead>
            <tr>
              <th>{t(lang!, "currencies.date")}</th>
              <th class="r">{t(lang!, "markets.official")}</th>
              <th class="r">{t(lang!, "markets.blue")}</th>
              <th class="r">{t(lang!, "markets.spread")}</th>
              <th class="r">{t(lang!, "currencies.gap")}</th>
            </tr>
          </thead>
          <tbody data-comparison-body>
            <tr><td colspan="5" class="fx-loading">{t(lang!, "common.loadingData")}</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <p class="fx-disclaimer">{t(lang!, "currencies.disclaimer")}</p>
  </div>
</Base>

<script is:inline src="/js/charts.js"></script>
<script is:inline>
(function() {
  var LATEST = 'https://api.bluelytics.com.ar/v2/latest';
  var EVO = 'https://api.bluelytics.com.ar/v2/evolution.json?days=30';
  var C = window.PlataCharts;

  function setEl(sel, text) {
    var el = document.querySelector(sel);
    if (el) el.textContent = text;
  }
  function setChange(sel, percent) {
    var el = document.querySelector(sel);
    if (!el) return;
    if (percent == null) { el.textContent = ''; return; }
    var sign = percent >= 0 ? '+' : '';
    el.textContent = sign + percent.toFixed(2) + '%';
    el.className = 'fx-change ' + (percent >= 0 ? 'rc-up' : 'rc-down');
  }

  var chartData = null;

  function calcSpread(rateSell, officialSell) {
    var spread = rateSell - officialSell;
    var gap = officialSell > 0 ? (spread / officialSell) * 100 : 0;
    return { spread: spread, gap: gap };
  }

  function fillRate(key, data) {
    if (!data) return;
    setEl('[data-rc-price="' + key + '"]', 'ARS ' + C.fmt(data.value_sell));
    setEl('[data-rc-buy="' + key + '"]', C.fmt(data.value_buy));
    setEl('[data-rc-sell="' + key + '"]', C.fmt(data.value_sell));
  }

  function fillSpread(key, rateSell, officialSell) {
    var s = calcSpread(rateSell, officialSell);
    setEl('[data-spread-pct="' + key + '"]', (s.gap >= 0 ? '+' : '') + s.gap.toFixed(1) + '%');
    var el = document.querySelector('[data-spread-pct="' + key + '"]');
    if (el) el.className = 'fx-spread-val ' + (s.gap >= 0 ? 'rc-up' : 'rc-down');
  }

  Promise.all([
    fetch(LATEST).then(function(r) { return r.json(); }).catch(function() { return null; }),
    fetch(EVO).then(function(r) { return r.json(); }).catch(function() { return null; }),
    fetch('/api/rates').then(function(r) { return r.json(); }).catch(function() { return null; })
  ]).then(function(res) {
    var latest = res[0];
    var evoRaw = res[1];
    var apiRates = res[2];

    setEl('[data-mkts-updated]', new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));

    if (latest && latest.oficial) {
      fillRate('official', latest.oficial);
      fillRate('blue', latest.blue);
      fillSpread('blue', latest.blue.value_sell, latest.oficial.value_sell);

      if (apiRates) {
        if (apiRates.mep) {
          fillRate('mep', apiRates.mep);
          fillSpread('mep', apiRates.mep.value_sell, latest.oficial.value_sell);
        }
        if (apiRates.ccl) {
          fillRate('ccl', apiRates.ccl);
          fillSpread('ccl', apiRates.ccl.value_sell, latest.oficial.value_sell);
        }
      }
    }

    if (evoRaw && evoRaw.length > 0) {
      var parsed = C.parseEvolution(evoRaw);
      chartData = parsed;

      if (parsed.official.length >= 2) {
        C.drawSpark(document.querySelector('[data-spark="official"]'), parsed.official.map(function(p) { return p.v; }), '#75AADB', 'rgba(117,170,219,0.18)');
      }
      if (parsed.blue.length >= 2) {
        C.drawSpark(document.querySelector('[data-spark="blue"]'), parsed.blue.map(function(p) { return p.v; }), '#F6B40E', 'rgba(246,180,14,0.18)');
      }

      if (parsed.official.length >= 2) {
        var o = parsed.official;
        setChange('[data-rc-change="official"]', ((o[o.length - 1].v - o[o.length - 2].v) / o[o.length - 2].v) * 100);
      }
      if (parsed.blue.length >= 2) {
        var b = parsed.blue;
        setChange('[data-rc-change="blue"]', ((b[b.length - 1].v - b[b.length - 2].v) / b[b.length - 2].v) * 100);
      }

      C.drawChart(document.querySelector('[data-evo-chart]'), [
        { points: parsed.official, lineColor: '#75AADB', fillColor: 'rgba(117,170,219,0.08)', label: 'Official' },
        { points: parsed.blue, lineColor: '#F6B40E', fillColor: 'rgba(246,180,14,0.08)', label: 'Blue' }
      ], { height: 320 });

      buildComparisonTable(parsed);
    }
  }).catch(function() {
    setEl('[data-mkts-updated]', '—');
  });

  function buildComparisonTable(parsed) {
    var tbody = document.querySelector('[data-comparison-body]');
    if (!tbody) return;

    var dateMap = {};
    parsed.official.forEach(function(p) { dateMap[p.d] = dateMap[p.d] || {}; dateMap[p.d].official = p.v; });
    parsed.blue.forEach(function(p) { dateMap[p.d] = dateMap[p.d] || {}; dateMap[p.d].blue = p.v; });

    var dates = Object.keys(dateMap).sort().reverse().slice(0, 7);
    if (dates.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="fx-loading">—</td></tr>'; return; }

    var html = '';
    for (var i = 0; i < dates.length; i++) {
      var d = dates[i];
      var row = dateMap[d];
      var off = row.official || 0;
      var blu = row.blue || 0;
      var spread = blu - off;
      var gap = off > 0 ? ((spread / off) * 100).toFixed(1) + '%' : '—';
      var parts = d.split('-');
      var dateStr = parseInt(parts[2]) + '/' + parseInt(parts[1]);

      html += '<tr>';
      html += '<td class="fx-td-date">' + dateStr + '</td>';
      html += '<td class="r tab">' + (off ? C.fmt(off) : '—') + '</td>';
      html += '<td class="r tab">' + (blu ? C.fmt(blu) : '—') + '</td>';
      html += '<td class="r tab">' + (spread > 0 ? C.fmt(spread) : '—') + '</td>';
      html += '<td class="r tab ' + (spread >= 0 ? 'rc-up' : 'rc-down') + '">' + gap + '</td>';
      html += '</tr>';
    }
    tbody.innerHTML = html;
  }

  var rTimer;
  window.addEventListener('resize', function() {
    clearTimeout(rTimer);
    rTimer = setTimeout(function() {
      if (!chartData) return;
      C.drawSpark(document.querySelector('[data-spark="official"]'), chartData.official.map(function(p) { return p.v; }), '#75AADB', 'rgba(117,170,219,0.18)');
      C.drawSpark(document.querySelector('[data-spark="blue"]'), chartData.blue.map(function(p) { return p.v; }), '#F6B40E', 'rgba(246,180,14,0.18)');
      C.drawChart(document.querySelector('[data-evo-chart]'), [
        { points: chartData.official, lineColor: '#75AADB', fillColor: 'rgba(117,170,219,0.08)', label: 'Official' },
        { points: chartData.blue, lineColor: '#F6B40E', fillColor: 'rgba(246,180,14,0.08)', label: 'Blue' }
      ], { height: 320 });
    }, 200);
  });
})();
</script>

<style>
  /* ═══ FX Page — Yahoo Finance / TradingView inspired ═══ */

  .fx-page { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--spacing-md); }

  /* Header */
  .fx-header { display: flex; align-items: baseline; gap: var(--spacing-md); margin-bottom: var(--spacing-lg); padding-bottom: var(--spacing-sm); border-bottom: 1px solid var(--color-border); }
  .fx-header-left { display: flex; align-items: baseline; gap: var(--spacing-md); flex-wrap: wrap; }
  .fx-title { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .fx-updated { font-size: 0.75rem; color: var(--color-text-meta); font-variant-numeric: tabular-nums; }

  /* Rate Strip — 4 cards in a row */
  .fx-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; margin-bottom: var(--spacing-xl); }

  .fx-rate { background: var(--color-bg); padding: 16px; display: flex; flex-direction: column; gap: 8px; }
  .fx-rate-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
  .fx-rate-name { font-size: 0.78rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.03em; }
  .fx-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 2px 6px; border-radius: 3px; background: rgba(117,170,219,0.12); color: #4a8abf; white-space: nowrap; }
  .fx-badge--blue { background: rgba(246,180,14,0.12); color: #b8860b; }
  .fx-badge--mep { background: rgba(76,175,80,0.12); color: #2e7d32; }
  .fx-badge--ccl { background: rgba(156,39,176,0.12); color: #7b1fa2; }

  .fx-rate-mid { display: flex; align-items: baseline; gap: 8px; }
  .fx-price { font-size: 1.5rem; font-weight: 800; font-variant-numeric: tabular-nums; letter-spacing: -0.03em; color: var(--color-text); line-height: 1.1; }
  .fx-change { font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; }

  .fx-buysell { display: flex; gap: 16px; }
  .fx-bs { display: flex; align-items: baseline; gap: 4px; }
  .fx-bs-label { font-size: 0.65rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
  .fx-bs-val { font-size: 0.85rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text); }

  .fx-spread-row { display: flex; align-items: center; gap: 6px; }
  .fx-spread-label { font-size: 0.65rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
  .fx-spread-val { font-size: 0.82rem; font-weight: 700; font-variant-numeric: tabular-nums; }

  .fx-spark { margin-top: auto; }
  .fx-spark canvas { width: 100%; display: block; }

  /* Chart Section */
  .fx-chart-section { margin-bottom: var(--spacing-xl); }
  .fx-chart-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--spacing-sm); }
  .fx-chart-title { font-size: 1rem; font-weight: 700; }
  .fx-legend { display: flex; gap: var(--spacing-md); }
  .fx-leg { display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: var(--color-text-meta); font-weight: 600; }
  .fx-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .fx-leg--official .fx-dot { background: #75AADB; }
  .fx-leg--blue .fx-dot { background: #F6B40E; }
  .fx-chart-wrap { background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: 8px; padding: var(--spacing-sm) var(--spacing-md); }
  .fx-chart-wrap canvas { width: 100%; display: block; }

  /* Table Section */
  .fx-table-section { margin-bottom: var(--spacing-xl); }
  .fx-section-title { font-size: 1rem; font-weight: 700; margin-bottom: var(--spacing-sm); }
  .fx-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .fx-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  .fx-table thead th { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-meta); font-weight: 700; padding: 8px 12px; border-bottom: 2px solid var(--color-border); white-space: nowrap; }
  .fx-table tbody td { padding: 8px 12px; border-bottom: 1px solid var(--color-border); color: var(--color-text); }
  .fx-table tbody tr:hover { background: var(--color-bg-secondary); }
  .fx-table .r { text-align: right; }
  .fx-table .tab { font-variant-numeric: tabular-nums; font-weight: 600; }
  .fx-td-date { font-weight: 600; color: var(--color-text-meta); white-space: nowrap; }
  .fx-loading { text-align: center; color: var(--color-text-meta); padding: var(--spacing-xl) !important; }

  /* Disclaimer */
  .fx-disclaimer { font-size: 0.7rem; color: var(--color-text-meta); text-align: center; margin-top: var(--spacing-md); padding-top: var(--spacing-md); border-top: 1px solid var(--color-border); }

  /* Dark mode badge overrides */
  :global([data-theme="dark"]) .fx-badge { color: #75AADB; }
  :global([data-theme="dark"]) .fx-badge--blue { color: #F6B40E; }
  :global([data-theme="dark"]) .fx-badge--mep { color: #66BB6A; }
  :global([data-theme="dark"]) .fx-badge--ccl { color: #CE93D8; }

  /* Responsive */
  @media (max-width: 900px) {
    .fx-strip { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .fx-strip { grid-template-columns: 1fr; }
    .fx-title { font-size: 1.25rem; }
    .fx-price { font-size: 1.3rem; }
    .fx-chart-head { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>
