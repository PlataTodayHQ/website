---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import DisclaimerFooter from "@/components/DisclaimerFooter.astro";
import { LANGUAGES, getRates } from "@plata-today/shared";
import { buildAlternateUrls, buildMarketBreadcrumbs } from "@/lib/seo";
import { t } from "@/i18n";

export const prerender = false;

const { lang } = Astro.params;
if (!lang || !(lang in LANGUAGES)) {
  return Astro.redirect("/en/", 302);
}

// Fetch fresh rates for SEO meta tags
const rates = getRates();
const blueRate = rates?.blue?.value_sell;
const oficialRate = rates?.oficial?.value_sell;
const seoTitle = blueRate
  ? `USD Blue: $${Math.round(blueRate)} — ${t(lang, "currencies.seoTitle")}`
  : t(lang, "currencies.seoTitle");
---

<Base
  title={seoTitle}
  description={t(lang!, "currencies.seoDescription")}
  lang={lang}
  ogType="website"
  alternateUrls={buildAlternateUrls("currencies")}
  breadcrumbs={buildMarketBreadcrumbs(lang!, "currencies.breadcrumb", "currencies")}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "currencies.title"),
    "description": t(lang!, "currencies.subtitle"),
    "url": `https://plata.today/${lang}/markets/currencies`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    },
    ...(blueRate ? {
      "mainEntity": [{
        "@type": "ExchangeRateSpecification",
        "currency": "USD",
        "name": "USD Blue Dollar",
        "currentExchangeRate": {
          "@type": "UnitPriceSpecification",
          "price": blueRate,
          "priceCurrency": "ARS"
        }
      }, ...(oficialRate ? [{
        "@type": "ExchangeRateSpecification",
        "currency": "USD",
        "name": "USD Official",
        "currentExchangeRate": {
          "@type": "UnitPriceSpecification",
          "price": oficialRate,
          "priceCurrency": "ARS"
        }
      }] : [])]
    } : {})
  }}
>
  <div class="fx-page" data-currencies-page
    data-lang={lang}
    data-i18n-current={t(lang!, "currencies.current" as any)}
    data-i18n-avg30d={t(lang!, "currencies.avg30d" as any)}
    data-i18n-max={t(lang!, "currencies.max" as any)}
    data-i18n-min={t(lang!, "currencies.min" as any)}
    data-i18n-trend={t(lang!, "currencies.trend" as any)}
    data-i18n-widening={t(lang!, "currencies.widening" as any)}
    data-i18n-narrowing={t(lang!, "currencies.narrowing" as any)}
    data-i18n-vol30d={t(lang!, "currencies.vol30d" as any)}
    data-i18n-max-daily={t(lang!, "currencies.maxDaily" as any)}
    data-i18n-avg-daily={t(lang!, "currencies.avgDaily" as any)}
    data-i18n-vol-high={t(lang!, "currencies.volHigh" as any)}
    data-i18n-vol-mod={t(lang!, "currencies.volMod" as any)}
    data-i18n-vol-low={t(lang!, "currencies.volLow" as any)}
    data-i18n-official={t(lang!, "currencies.official" as any)}
    data-i18n-blue={t(lang!, "currencies.blue" as any)}
    data-i18n-updated={t(lang!, "stock.updated")}
    data-i18n-gap-label={t(lang!, "currencies.gapLabel" as any)}
    data-i18n-vs-official={t(lang!, "currencies.vsOfficial" as any)}
    data-i18n-best-rate={t(lang!, "currencies.bestRate" as any)}
    data-i18n-mep={t(lang!, "currencies.mep" as any)}
    data-i18n-ccl={t(lang!, "currencies.ccl" as any)}
    data-i18n-all-rates={t(lang!, "currencies.allRates" as any)}
    data-i18n-per-usd={t(lang!, "currencies.perUsd" as any)}
    data-i18n-error={t(lang!, "markets.failedToLoad" as any)}
    data-i18n-retry={t(lang!, "common.retry" as any)}
    data-i18n-check-conn={t(lang!, "common.checkConnection" as any)}
  >
    <MarketNav lang={lang!} active="currencies" />

    <!-- Header -->
    <header class="fx-header">
      <div class="fx-header-left">
        <h1 class="fx-title">{t(lang!, "currencies.title")}</h1>
        <span class="fx-updated" data-mkts-updated role="status" aria-live="polite">{t(lang!, "currencies.loading")}</span>
      </div>
    </header>

    <!-- Rate Strip -->
    <div class="fx-strip-wrap">
    <div class="fx-strip" role="region" aria-label={t(lang!, "currencies.title")}>
      <div class="fx-rate fx-rate--loading" id="official">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdOfficial")}</span>
          <span class="fx-badge">{t(lang!, "currencies.bcra")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="official">—</span>
          <span class="fx-change" data-rc-change="official"></span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="official">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="official">—</span></div>
        </div>
        <div class="fx-spark"><canvas data-spark="official" height="48" role="img" aria-label={t(lang!, "currencies.usdOfficial")}></canvas></div>
      </div>

      <div class="fx-rate fx-rate--blue fx-rate--loading" id="blue">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdBlue")}</span>
          <span class="fx-badge fx-badge--blue">{t(lang!, "currencies.informal")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="blue">—</span>
          <span class="fx-change" data-rc-change="blue"></span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="blue">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="blue">—</span></div>
        </div>
        <div class="fx-gap-row" data-fx-gap-row="blue">
          <div class="fx-gap-head">
            <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="fx-spread-val" data-spread-pct="blue">—</span>
            <span class="fx-gap-arrow" data-gap-arrow="blue"></span>
          </div>
          <div class="fx-gap-bar"><div class="fx-gap-fill" data-gap-fill="blue"></div></div>
        </div>
        <div class="fx-spark"><canvas data-spark="blue" height="48" role="img" aria-label={t(lang!, "currencies.usdBlue")}></canvas></div>
      </div>

      <div class="fx-rate fx-rate--mep fx-rate--loading" id="mep">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdMep")}</span>
          <span class="fx-badge fx-badge--mep">{t(lang!, "currencies.stockMarket")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="mep">—</span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="mep">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="mep">—</span></div>
        </div>
        <div class="fx-gap-row" data-fx-gap-row="mep">
          <div class="fx-gap-head">
            <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="fx-spread-val" data-spread-pct="mep">—</span>
            <span class="fx-gap-arrow" data-gap-arrow="mep"></span>
          </div>
          <div class="fx-gap-bar"><div class="fx-gap-fill" data-gap-fill="mep"></div></div>
        </div>
      </div>

      <div class="fx-rate fx-rate--ccl fx-rate--loading" id="ccl">
        <div class="fx-rate-head">
          <span class="fx-rate-name">{t(lang!, "currencies.usdCcl")}</span>
          <span class="fx-badge fx-badge--ccl">{t(lang!, "currencies.settlement")}</span>
        </div>
        <div class="fx-rate-mid">
          <span class="fx-price" data-rc-price="ccl">—</span>
        </div>
        <div class="fx-buysell">
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.buy")}</span><span class="fx-bs-val" data-rc-buy="ccl">—</span></div>
          <div class="fx-bs"><span class="fx-bs-label">{t(lang!, "currencies.sell")}</span><span class="fx-bs-val" data-rc-sell="ccl">—</span></div>
        </div>
        <div class="fx-gap-row" data-fx-gap-row="ccl">
          <div class="fx-gap-head">
            <span class="fx-spread-label">{t(lang!, "currencies.gap")}</span>
            <span class="fx-spread-val" data-spread-pct="ccl">—</span>
            <span class="fx-gap-arrow" data-gap-arrow="ccl"></span>
          </div>
          <div class="fx-gap-bar"><div class="fx-gap-fill" data-gap-fill="ccl"></div></div>
        </div>
      </div>
    </div>
    </div>

    <!-- Quick Converter -->
    <section class="fx-converter">
      <h2 class="fx-converter-title">{t(lang!, "currencies.converter")}</h2>
      <div class="fx-conv-row">
        <div class="fx-conv-input-wrap">
          <label class="fx-conv-label" data-conv-from-label>USD</label>
          <input type="number" class="fx-conv-input" data-conv-from value="100" min="0" step="1" inputmode="decimal" />
        </div>
        <button class="fx-conv-swap" data-conv-swap title={t(lang!, "currencies.swap" as any)} aria-label={t(lang!, "currencies.swapLabel" as any)}>⇄</button>
        <div class="fx-conv-input-wrap">
          <label class="fx-conv-label" data-conv-to-label>ARS</label>
          <input type="text" class="fx-conv-input fx-conv-input--readonly" data-conv-to readonly />
        </div>
        <div class="fx-conv-rate-select">
          <select class="fx-conv-select" data-conv-rate aria-label={t(lang!, "currencies.converter")}>
            <option value="oficial">{t(lang!, "currencies.usdOfficial")}</option>
            <option value="blue" selected>{t(lang!, "currencies.usdBlue")}</option>
            <option value="mep">{t(lang!, "currencies.usdMep")}</option>
            <option value="ccl">{t(lang!, "currencies.usdCcl")}</option>
          </select>
        </div>
      </div>
      <div class="fx-conv-presets" data-conv-presets>
        <button class="fx-conv-preset" data-preset="50">50</button>
        <button class="fx-conv-preset" data-preset="100">100</button>
        <button class="fx-conv-preset" data-preset="500">500</button>
        <button class="fx-conv-preset" data-preset="1000">1,000</button>
        <button class="fx-conv-preset" data-preset="5000">5,000</button>
      </div>
    </section>

    <!-- Multi-Rate Converter -->
    <section class="fx-multiconv" data-fx-multiconv style="display:none;" aria-label={t(lang!, "currencies.converter")}>
      <h2 class="fx-section-title">{t(lang!, "currencies.allRates" as any)}</h2>
      <div class="fx-mc-input-row">
        <label class="fx-mc-label" for="mc-amount">USD</label>
        <input
          type="number"
          id="mc-amount"
          class="fx-mc-input"
          data-mc-amount
          value="100"
          min="0"
          step="1"
          inputmode="decimal"
          aria-label="Amount in USD"
        />
      </div>
      <div class="fx-mc-grid" data-mc-grid>
        <div class="fx-mc-card" data-mc-card="oficial" style="border-top-color:#75AADB">
          <span class="fx-mc-name">{t(lang!, "currencies.usdOfficial")}</span>
          <span class="fx-mc-result" data-mc-result="oficial">--</span>
          <span class="fx-mc-rate" data-mc-per="oficial"></span>
        </div>
        <div class="fx-mc-card" data-mc-card="blue" style="border-top-color:#F6B40E">
          <span class="fx-mc-name">{t(lang!, "currencies.usdBlue")}</span>
          <span class="fx-mc-result" data-mc-result="blue">--</span>
          <span class="fx-mc-rate" data-mc-per="blue"></span>
        </div>
        <div class="fx-mc-card" data-mc-card="mep" style="border-top-color:#22c55e">
          <span class="fx-mc-name">{t(lang!, "currencies.usdMep")}</span>
          <span class="fx-mc-result" data-mc-result="mep">--</span>
          <span class="fx-mc-rate" data-mc-per="mep"></span>
        </div>
        <div class="fx-mc-card" data-mc-card="ccl" style="border-top-color:#a855f7">
          <span class="fx-mc-name">{t(lang!, "currencies.usdCcl")}</span>
          <span class="fx-mc-result" data-mc-result="ccl">--</span>
          <span class="fx-mc-rate" data-mc-per="ccl"></span>
        </div>
      </div>
    </section>

    <!-- What $100 USD Gets You -->
    <section class="fx-ppp-section" data-fx-ppp style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.whatYouGet" as any)}</h2>
      <div class="fx-ppp-grid" data-fx-ppp-grid></div>
    </section>

    <!-- 30-Day Performance -->
    <section class="fx-perf-section" data-fx-perf style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.performance")}</h2>
      <div class="fx-perf-grid">
        <div class="fx-perf-card">
          <span class="fx-perf-label">{t(lang!, "currencies.usdOfficial")}</span>
          <div class="fx-perf-stats">
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.thirtyDayChg")}</span>
              <span class="fx-perf-sv" data-perf-chg="oficial">—</span>
            </div>
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.periodHigh")}</span>
              <span class="fx-perf-sv" data-perf-high="oficial">—</span>
            </div>
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.periodLow")}</span>
              <span class="fx-perf-sv" data-perf-low="oficial">—</span>
            </div>
          </div>
          <div class="fx-perf-bar-wrap">
            <div class="fx-perf-bar" data-perf-bar="oficial"></div>
          </div>
        </div>
        <div class="fx-perf-card">
          <span class="fx-perf-label">{t(lang!, "currencies.usdBlue")}</span>
          <div class="fx-perf-stats">
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.thirtyDayChg")}</span>
              <span class="fx-perf-sv" data-perf-chg="blue">—</span>
            </div>
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.periodHigh")}</span>
              <span class="fx-perf-sv" data-perf-high="blue">—</span>
            </div>
            <div class="fx-perf-stat">
              <span class="fx-perf-sk">{t(lang!, "currencies.periodLow")}</span>
              <span class="fx-perf-sv" data-perf-low="blue">—</span>
            </div>
          </div>
          <div class="fx-perf-bar-wrap">
            <div class="fx-perf-bar" data-perf-bar="blue"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Rate Spread Matrix -->
    <section class="fx-spread-section" data-fx-spread style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.spreadMatrix" as any)}</h2>
      <div class="fx-spread-grid" data-fx-spread-grid></div>
    </section>

    <!-- Visual Rate Comparison -->
    <section class="fx-bars-section" data-fx-bars style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.rateComparison" as any)}</h2>
      <div class="fx-bars" data-fx-bars-grid></div>
    </section>

    <!-- Volatility & Daily Changes -->
    <section class="fx-vol-section" data-fx-vol style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.volatility" as any)}</h2>
      <div class="fx-vol-grid" data-fx-vol-grid></div>
    </section>

    <!-- Chart -->
    <section class="fx-chart-section">
      <div class="fx-chart-head">
        <h2 class="fx-chart-title">{t(lang!, "currencies.evoTitle")}</h2>
      </div>
      <div class="fx-chart-wrap">
        <canvas data-evo-chart height="320" role="img" aria-label={t(lang!, "currencies.evoTitle")}></canvas>
      </div>
    </section>

    <!-- Rate History Table -->
    <section class="fx-history-section" data-fx-history style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.rateHistory" as any)}</h2>
      <div class="fx-history-wrap">
        <table class="fx-history-table" role="table">
          <thead>
            <tr>
              <th class="fx-ht-th">{t(lang!, "currencies.date" as any)}</th>
              <th class="fx-ht-th fx-ht-th--num">{t(lang!, "currencies.usdOfficial")}</th>
              <th class="fx-ht-th fx-ht-th--num">{t(lang!, "currencies.usdBlue")}</th>
              <th class="fx-ht-th fx-ht-th--num">{t(lang!, "currencies.gap")}</th>
              <th class="fx-ht-th fx-ht-th--num fx-ht-th--hide-mobile">{t(lang!, "currencies.officialChg" as any)}</th>
              <th class="fx-ht-th fx-ht-th--num fx-ht-th--hide-mobile">{t(lang!, "currencies.blueChg" as any)}</th>
            </tr>
          </thead>
          <tbody data-fx-history-tbody></tbody>
        </table>
      </div>
    </section>

    <!-- Gap Trend -->
    <section class="fx-gap-section" data-fx-gap style="display:none;">
      <h2 class="fx-section-title">{t(lang!, "currencies.gapTrend" as any)}</h2>
      <div class="fx-gap-chart-wrap">
        <canvas data-gap-chart height="180" role="img" aria-label={t(lang!, "currencies.gapTrend" as any)}></canvas>
      </div>
      <div class="fx-gap-stats" data-fx-gap-stats></div>
    </section>

    <DisclaimerFooter text={t(lang!, "currencies.disclaimer")} jsRequiredText={t(lang!, "common.jsRequired" as any)} className="fx-disclaimer" />

    <button class="scroll-top-btn" data-scroll-top aria-label="↑" title="↑">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
    </button>
  </div>
</Base>

<script is:inline src="/js/charts.js?v=5"></script>
<script is:inline src="/js/market-states.js?v=1"></script>
<script is:inline src="/js/market-helpers.js?v=1"></script>
<script is:inline src="/js/currencies.js?v=1"></script>


<style>
  /* Error cards use shared .mkts-error-card from global.css */

  /* ═══ FX Page — Yahoo Finance / TradingView inspired ═══ */

  .fx-page { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--spacing-md); }

  /* Header */
  .fx-header { display: flex; align-items: baseline; gap: var(--spacing-md); margin-bottom: var(--spacing-lg); padding-bottom: var(--spacing-sm); border-bottom: 1px solid var(--color-border); }
  .fx-header-left { display: flex; align-items: baseline; gap: var(--spacing-md); flex-wrap: wrap; }
  .fx-title { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .fx-updated { font-size: 0.75rem; color: var(--color-text-meta); font-variant-numeric: tabular-nums; }

  /* Rate Strip wrapper (for scroll indicators on mobile) */
  .fx-strip-wrap { position: relative; margin-bottom: var(--spacing-xl); }

  /* Rate Strip — 4 cards in a row */
  .fx-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }

  .fx-rate { background: var(--color-bg); padding: 18px 16px; display: flex; flex-direction: column; gap: 10px; transition: background-color 0.15s ease; position: relative; }
  .fx-rate:hover { background: var(--color-bg-secondary); }
  .fx-rate-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
  .fx-rate-name { font-size: 0.78rem; font-weight: 700; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.03em; }
  .fx-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 2px 6px; border-radius: 3px; background: rgba(117,170,219,0.12); color: #4a8abf; white-space: nowrap; }
  .fx-badge--blue { background: rgba(246,180,14,0.12); color: #b8860b; }
  .fx-badge--mep { background: rgba(76,175,80,0.12); color: #2e7d32; }
  .fx-badge--ccl { background: rgba(156,39,176,0.12); color: #7b1fa2; }

  .fx-rate-mid { display: flex; align-items: baseline; gap: 8px; }
  .fx-price { font-size: 1.5rem; font-weight: 800; font-variant-numeric: tabular-nums; letter-spacing: -0.03em; color: var(--color-text); line-height: 1.1; }
  .fx-change { font-size: 0.78rem; font-weight: 700; font-variant-numeric: tabular-nums; }

  .fx-buysell { display: flex; gap: 16px; }
  .fx-bs { display: flex; align-items: baseline; gap: 4px; }
  .fx-bs-label { font-size: 0.65rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
  .fx-bs-val { font-size: 0.85rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text); transition: background 0.15s; border-radius: 3px; }
  .fx-bs-val:hover { background: rgba(246,180,14,0.1); }
  .fx-price { transition: background 0.15s; border-radius: 3px; }
  .fx-price:hover { background: rgba(246,180,14,0.1); }
  :global(.fx-copied) { animation: fx-copy-flash 0.5s ease-out; }
  @keyframes fx-copy-flash { 0% { background: rgba(22,163,74,0.3); } 100% { background: transparent; } }

  .fx-gap-row { display: flex; flex-direction: column; gap: 4px; }
  .fx-gap-head { display: flex; align-items: center; gap: 6px; }
  .fx-spread-label { font-size: 0.65rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
  .fx-spread-val { font-size: 0.82rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .fx-gap-arrow { font-size: 0.7rem; font-weight: 700; transition: color 0.2s; }
