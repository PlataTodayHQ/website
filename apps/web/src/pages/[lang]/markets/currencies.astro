---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "currencies.seoTitle")}
  description={t(lang!, "currencies.seoDescription")}
  lang={lang}
  ogType="website"
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "markets.breadcrumb"), url: `/${lang}/markets` },
    { name: t(lang!, "currencies.breadcrumb"), url: `/${lang}/markets/currencies` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "currencies.title"),
    "description": t(lang!, "currencies.subtitle"),
    "url": `https://plata.today/${lang}/markets/currencies`,
    "inLanguage": lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <div class="currencies-page" data-currencies-page>
    <header class="mkts-header">
      <div>
        <h1 class="mkts-title">{t(lang!, "currencies.title")}</h1>
        <p class="mkts-subtitle">{t(lang!, "currencies.subtitle")}</p>
      </div>
      <p class="mkts-updated" data-mkts-updated>{t(lang!, "currencies.loading")}</p>
    </header>

    <!-- Rate Cards -->
    <div class="rate-cards">
      <div class="rate-card" id="official">
        <div class="rc-top">
          <span class="rc-label">{t(lang!, "currencies.usdOfficial")}</span>
          <span class="rc-badge">{t(lang!, "currencies.bcra")}</span>
        </div>
        <div class="rc-price-row">
          <span class="rc-price" data-rc-price="official">—</span>
          <span class="rc-change" data-rc-change="official"></span>
        </div>
        <div class="rc-details">
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.buy")}</span>
            <span class="rc-dv" data-rc-buy="official">—</span>
          </div>
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.sell")}</span>
            <span class="rc-dv" data-rc-sell="official">—</span>
          </div>
        </div>
        <div class="rc-spark">
          <canvas data-spark="official" height="60"></canvas>
        </div>
      </div>

      <div class="rate-card rate-card--blue" id="blue">
        <div class="rc-top">
          <span class="rc-label">{t(lang!, "currencies.usdBlue")}</span>
          <span class="rc-badge rc-badge--blue">{t(lang!, "currencies.informal")}</span>
        </div>
        <div class="rc-price-row">
          <span class="rc-price" data-rc-price="blue">—</span>
          <span class="rc-change" data-rc-change="blue"></span>
        </div>
        <div class="rc-details">
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.buy")}</span>
            <span class="rc-dv" data-rc-buy="blue">—</span>
          </div>
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.sell")}</span>
            <span class="rc-dv" data-rc-sell="blue">—</span>
          </div>
        </div>
        <div class="rc-spark">
          <canvas data-spark="blue" height="60"></canvas>
        </div>
      </div>

      <div class="rate-card rate-card--mep" id="mep">
        <div class="rc-top">
          <span class="rc-label">{t(lang!, "currencies.usdMep")}</span>
          <span class="rc-badge rc-badge--mep">{t(lang!, "currencies.stockMarket")}</span>
        </div>
        <div class="rc-price-row">
          <span class="rc-price" data-rc-price="mep">—</span>
        </div>
        <div class="rc-details">
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.buy")}</span>
            <span class="rc-dv" data-rc-buy="mep">—</span>
          </div>
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.sell")}</span>
            <span class="rc-dv" data-rc-sell="mep">—</span>
          </div>
        </div>
      </div>

      <div class="rate-card rate-card--ccl" id="ccl">
        <div class="rc-top">
          <span class="rc-label">{t(lang!, "currencies.usdCcl")}</span>
          <span class="rc-badge rc-badge--ccl">{t(lang!, "currencies.settlement")}</span>
        </div>
        <div class="rc-price-row">
          <span class="rc-price" data-rc-price="ccl">—</span>
        </div>
        <div class="rc-details">
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.buy")}</span>
            <span class="rc-dv" data-rc-buy="ccl">—</span>
          </div>
          <div class="rc-detail">
            <span class="rc-dk">{t(lang!, "currencies.sell")}</span>
            <span class="rc-dv" data-rc-sell="ccl">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Spread Bars -->
    <div class="spread-bars">
      <div class="spread-bar">
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.blueSpread")}</span>
          <span class="spread-value" data-spread-abs="blue">—</span>
        </div>
        <div class="spread-sep"></div>
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="spread-value spread-pct" data-spread-pct="blue">—</span>
        </div>
      </div>
      <div class="spread-bar spread-bar--mep">
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.mepSpread")}</span>
          <span class="spread-value" data-spread-abs="mep">—</span>
        </div>
        <div class="spread-sep"></div>
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="spread-value spread-pct" data-spread-pct="mep">—</span>
        </div>
      </div>
      <div class="spread-bar spread-bar--ccl">
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.cclSpread")}</span>
          <span class="spread-value" data-spread-abs="ccl">—</span>
        </div>
        <div class="spread-sep"></div>
        <div class="spread-item">
          <span class="spread-label">{t(lang!, "currencies.gap")}</span>
          <span class="spread-value spread-pct" data-spread-pct="ccl">—</span>
        </div>
      </div>
    </div>

    <!-- 30-Day Evolution Chart -->
    <section class="evo-section">
      <h2 class="evo-title">{t(lang!, "currencies.evoTitle")}</h2>
      <div class="evo-legend">
        <span class="evo-leg evo-leg--official"><span class="evo-dot"></span> {t(lang!, "markets.official")}</span>
        <span class="evo-leg evo-leg--blue"><span class="evo-dot"></span> {t(lang!, "markets.blue")}</span>
      </div>
      <div class="evo-wrap">
        <canvas data-evo-chart height="280"></canvas>
      </div>
    </section>

    <!-- 7-Day Comparison Table -->
    <section class="comparison-section">
      <h2 class="section-title">{t(lang!, "currencies.recentHistory")}</h2>
      <div class="table-wrap">
        <table class="comparison-table" data-comparison-table>
          <thead>
            <tr>
              <th>{t(lang!, "currencies.date")}</th>
              <th class="text-right">{t(lang!, "markets.official")}</th>
              <th class="text-right">{t(lang!, "markets.blue")}</th>
              <th class="text-right">{t(lang!, "markets.spread")}</th>
              <th class="text-right">{t(lang!, "currencies.gap")}</th>
            </tr>
          </thead>
          <tbody data-comparison-body>
            <tr><td colspan="5" class="loading-cell">{t(lang!, "common.loadingData")}</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Guide Section -->
    <section class="info-section">
      <h2 class="section-title">{t(lang!, "currencies.guideTitle")}</h2>
      <div class="explainer-card">
        <p>{t(lang!, "currencies.guideIntro")}</p>
      </div>
    </section>

    <!-- Info Section — All 4 Rates -->
    <section class="info-section">
      <h2 class="section-title">{t(lang!, "currencies.understandTitle")}</h2>
      <div class="info-grid info-grid--4">
        <div class="info-card">
          <h3>{t(lang!, "currencies.officialTitle")}</h3>
          <p>{t(lang!, "currencies.officialDesc")}</p>
        </div>
        <div class="info-card">
          <h3>{t(lang!, "currencies.blueTitle")}</h3>
          <p>{t(lang!, "currencies.blueDesc")}</p>
        </div>
        <div class="info-card">
          <h3>{t(lang!, "currencies.mepTitle")}</h3>
          <p>{t(lang!, "currencies.mepDesc")}</p>
        </div>
        <div class="info-card">
          <h3>{t(lang!, "currencies.cclTitle")}</h3>
          <p>{t(lang!, "currencies.cclDesc")}</p>
        </div>
      </div>
    </section>

    <!-- Why Multiple Rates Explainer -->
    <section class="info-section">
      <h2 class="section-title">{t(lang!, "currencies.whyTwoRates")}</h2>
      <div class="explainer-card">
        <p>{t(lang!, "currencies.whyTwoRatesDesc")}</p>
      </div>
    </section>

    <!-- Who Uses Each Rate -->
    <section class="info-section">
      <h2 class="section-title">{t(lang!, "currencies.whoUsesTitle")}</h2>
      <div class="info-grid info-grid--4">
        <div class="info-card info-card--compact">
          <h3>{t(lang!, "currencies.whoUsesOfficialLabel")}</h3>
          <p>{t(lang!, "currencies.whoUsesOfficialDesc")}</p>
        </div>
        <div class="info-card info-card--compact">
          <h3>{t(lang!, "currencies.whoUsesBlueLabel")}</h3>
          <p>{t(lang!, "currencies.whoUsesBlueDesc")}</p>
        </div>
        <div class="info-card info-card--compact">
          <h3>{t(lang!, "currencies.whoUsesMepLabel")}</h3>
          <p>{t(lang!, "currencies.whoUsesMepDesc")}</p>
        </div>
        <div class="info-card info-card--compact">
          <h3>{t(lang!, "currencies.whoUsesCclLabel")}</h3>
          <p>{t(lang!, "currencies.whoUsesCclDesc")}</p>
        </div>
      </div>
    </section>

    <!-- Data Sources -->
    <section class="info-section">
      <h2 class="section-title">{t(lang!, "currencies.rateSourcesTitle")}</h2>
      <div class="explainer-card">
        <p>{t(lang!, "currencies.rateSourcesDesc")}</p>
      </div>
    </section>

    <p class="info-disclaimer">{t(lang!, "currencies.disclaimer")}</p>
  </div>
</Base>

<script is:inline src="/js/charts.js"></script>
<script is:inline>
(function() {
  var LATEST = 'https://api.bluelytics.com.ar/v2/latest';
  var EVO = 'https://api.bluelytics.com.ar/v2/evolution.json?days=30';
  var C = window.PlataCharts;

  function setEl(sel, text) {
    var el = document.querySelector(sel);
    if (el) el.textContent = text;
  }
  function setChange(sel, percent) {
    var el = document.querySelector(sel);
    if (!el) return;
    if (percent == null) { el.textContent = ''; return; }
    var sign = percent >= 0 ? '+' : '';
    el.textContent = sign + percent.toFixed(2) + '%';
    el.className = 'rc-change ' + (percent >= 0 ? 'rc-up' : 'rc-down');
  }

  var chartData = null;

  function calcSpread(rateSell, officialSell) {
    var spread = rateSell - officialSell;
    var gap = officialSell > 0 ? (spread / officialSell) * 100 : 0;
    return { spread: spread, gap: gap };
  }

  function fillRate(key, data) {
    if (!data) return;
    setEl('[data-rc-price="' + key + '"]', 'ARS ' + C.fmt(data.value_sell));
    setEl('[data-rc-buy="' + key + '"]', C.fmt(data.value_buy));
    setEl('[data-rc-sell="' + key + '"]', C.fmt(data.value_sell));
  }

  function fillSpread(key, rateSell, officialSell) {
    var s = calcSpread(rateSell, officialSell);
    setEl('[data-spread-abs="' + key + '"]', 'ARS ' + C.fmt(s.spread));
    setEl('[data-spread-pct="' + key + '"]', s.gap.toFixed(1) + '%');
  }

  Promise.all([
    fetch(LATEST).then(function(r) { return r.json(); }).catch(function() { return null; }),
    fetch(EVO).then(function(r) { return r.json(); }).catch(function() { return null; }),
    fetch('/api/rates').then(function(r) { return r.json(); }).catch(function() { return null; })
  ]).then(function(res) {
    var latest = res[0];
    var evoRaw = res[1];
    var apiRates = res[2];

    setEl('[data-mkts-updated]', 'Updated ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));

    if (latest && latest.oficial) {
      fillRate('official', latest.oficial);
      fillRate('blue', latest.blue);
      fillSpread('blue', latest.blue.value_sell, latest.oficial.value_sell);

      // MEP and CCL from internal API
      if (apiRates) {
        if (apiRates.mep) {
          fillRate('mep', apiRates.mep);
          fillSpread('mep', apiRates.mep.value_sell, latest.oficial.value_sell);
        }
        if (apiRates.ccl) {
          fillRate('ccl', apiRates.ccl);
          fillSpread('ccl', apiRates.ccl.value_sell, latest.oficial.value_sell);
        }
      }
    }

    if (evoRaw && evoRaw.length > 0) {
      var parsed = C.parseEvolution(evoRaw);
      chartData = parsed;

      // Sparklines
      if (parsed.official.length >= 2) {
        C.drawSpark(document.querySelector('[data-spark="official"]'), parsed.official.map(function(p) { return p.v; }), '#75AADB', 'rgba(117,170,219,0.25)');
      }
      if (parsed.blue.length >= 2) {
        C.drawSpark(document.querySelector('[data-spark="blue"]'), parsed.blue.map(function(p) { return p.v; }), '#F6B40E', 'rgba(246,180,14,0.25)');
      }

      // Change %
      if (parsed.official.length >= 2) {
        var o = parsed.official;
        setChange('[data-rc-change="official"]', ((o[o.length - 1].v - o[o.length - 2].v) / o[o.length - 2].v) * 100);
      }
      if (parsed.blue.length >= 2) {
        var b = parsed.blue;
        setChange('[data-rc-change="blue"]', ((b[b.length - 1].v - b[b.length - 2].v) / b[b.length - 2].v) * 100);
      }

      // Evolution chart
      C.drawChart(document.querySelector('[data-evo-chart]'), [
        { points: parsed.official, lineColor: '#75AADB', fillColor: 'rgba(117,170,219,0.12)', label: 'Official' },
        { points: parsed.blue, lineColor: '#F6B40E', fillColor: 'rgba(246,180,14,0.12)', label: 'Blue' }
      ]);

      // Comparison table (last 7 days)
      buildComparisonTable(parsed);
    }
  }).catch(function() {
    setEl('[data-mkts-updated]', 'Unable to load data');
  });

  function buildComparisonTable(parsed) {
    var tbody = document.querySelector('[data-comparison-body]');
    if (!tbody) return;

    // Merge dates, take last 7
    var dateMap = {};
    parsed.official.forEach(function(p) { dateMap[p.d] = dateMap[p.d] || {}; dateMap[p.d].official = p.v; });
    parsed.blue.forEach(function(p) { dateMap[p.d] = dateMap[p.d] || {}; dateMap[p.d].blue = p.v; });

    var dates = Object.keys(dateMap).sort().reverse().slice(0, 7);
    if (dates.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="loading-cell">No data available</td></tr>'; return; }

    var html = '';
    for (var i = 0; i < dates.length; i++) {
      var d = dates[i];
      var row = dateMap[d];
      var off = row.official || 0;
      var blu = row.blue || 0;
      var spread = blu - off;
      var gap = off > 0 ? ((spread / off) * 100).toFixed(1) + '%' : '—';
      var parts = d.split('-');
      var dateStr = parseInt(parts[2]) + '/' + parseInt(parts[1]);

      html += '<tr>';
      html += '<td>' + dateStr + '</td>';
      html += '<td class="text-right tabular">' + (off ? C.fmt(off) : '—') + '</td>';
      html += '<td class="text-right tabular">' + (blu ? C.fmt(blu) : '—') + '</td>';
      html += '<td class="text-right tabular">' + (spread > 0 ? C.fmt(spread) : '—') + '</td>';
      html += '<td class="text-right tabular">' + gap + '</td>';
      html += '</tr>';
    }
    tbody.innerHTML = html;
  }

  // Resize handler
  var rTimer;
  window.addEventListener('resize', function() {
    clearTimeout(rTimer);
    rTimer = setTimeout(function() {
      if (!chartData) return;
      C.drawSpark(document.querySelector('[data-spark="official"]'), chartData.official.map(function(p) { return p.v; }), '#75AADB', 'rgba(117,170,219,0.25)');
      C.drawSpark(document.querySelector('[data-spark="blue"]'), chartData.blue.map(function(p) { return p.v; }), '#F6B40E', 'rgba(246,180,14,0.25)');
      C.drawChart(document.querySelector('[data-evo-chart]'), [
        { points: chartData.official, lineColor: '#75AADB', fillColor: 'rgba(117,170,219,0.12)', label: 'Official' },
        { points: chartData.blue, lineColor: '#F6B40E', fillColor: 'rgba(246,180,14,0.12)', label: 'Blue' }
      ]);
    }, 200);
  });
})();
</script>

<style>
  .rate-cards { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-lg); margin-bottom: var(--spacing-xl); }
  .rate-card { background: var(--color-bg-secondary); border-radius: 8px; padding: var(--spacing-lg); border: 1px solid var(--color-border); }
  .rc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-md); }
  .rc-label { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; color: var(--color-text); }
  .rc-badge { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 8px; border-radius: 3px; background: rgba(117,170,219,0.15); color: #4a8abf; }
  .rc-badge--blue { background: rgba(246,180,14,0.15); color: #b8860b; }
  .rc-badge--mep { background: rgba(76,175,80,0.15); color: #2e7d32; }
  .rc-badge--ccl { background: rgba(156,39,176,0.15); color: #7b1fa2; }
  .rc-price-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: var(--spacing-md); }
  .rc-price { font-size: 1.75rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text); letter-spacing: -0.02em; }
  .rc-change { font-size: 0.85rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .rc-details { display: flex; gap: var(--spacing-lg); padding-top: var(--spacing-sm); border-top: 1px solid var(--color-border); margin-bottom: var(--spacing-md); }
  .rc-detail { display: flex; flex-direction: column; gap: 2px; }
  .rc-dk { font-size: 0.7rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .rc-dv { font-size: 0.95rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-text); }
  .rc-spark { margin-top: var(--spacing-sm); }
  .rc-spark canvas { width: 100%; display: block; }

  .spread-bars { display: flex; flex-direction: column; gap: var(--spacing-sm); margin-bottom: var(--spacing-2xl); }
  .spread-bar { display: flex; align-items: center; justify-content: center; gap: var(--spacing-xl); background: var(--color-celeste); color: #fff; padding: var(--spacing-md) var(--spacing-lg); border-radius: 6px; }
  .spread-bar--mep { background: #2e7d32; }
  .spread-bar--ccl { background: #7b1fa2; }
  .spread-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.2); }
  .spread-item { display: flex; align-items: center; gap: 8px; }
  .spread-label { font-size: 0.8rem; color: rgba(255,255,255,0.7); font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
  .spread-value { font-size: 1.1rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .spread-pct { color: var(--color-gold); }

  .evo-section { margin-bottom: var(--spacing-2xl); }
  .evo-title { font-size: 1.3rem; font-weight: 700; margin-bottom: var(--spacing-sm); }
  .evo-legend { display: flex; gap: var(--spacing-lg); margin-bottom: var(--spacing-md); }
  .evo-leg { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; color: var(--color-text-secondary); font-weight: 600; }
  .evo-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .evo-leg--official .evo-dot { background: #75AADB; }
  .evo-leg--blue .evo-dot { background: #F6B40E; }
  .evo-wrap { background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: 8px; padding: var(--spacing-md); }
  .evo-wrap canvas { width: 100%; display: block; }

  .comparison-section { margin-bottom: var(--spacing-2xl); }
  .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .comparison-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .comparison-table th { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-meta); font-weight: 700; padding: var(--spacing-sm) var(--spacing-md); border-bottom: 2px solid var(--color-border); }
  .comparison-table td { padding: var(--spacing-sm) var(--spacing-md); border-bottom: 1px solid var(--color-border); color: var(--color-text); }
  .comparison-table .text-right { text-align: right; }
  .comparison-table .tabular { font-variant-numeric: tabular-nums; font-weight: 600; }
  .loading-cell { text-align: center; color: var(--color-text-meta); padding: var(--spacing-xl) !important; }

  :global([data-theme="dark"]) .rc-badge { color: #75AADB; }
  :global([data-theme="dark"]) .rc-badge--blue { color: #F6B40E; }
  :global([data-theme="dark"]) .rc-badge--mep { color: #66BB6A; }
  :global([data-theme="dark"]) .rc-badge--ccl { color: #CE93D8; }

  @media (max-width: 640px) {
    .rate-cards { grid-template-columns: 1fr; }
    .spread-bar { flex-direction: column; gap: var(--spacing-sm); }
    .spread-sep { width: 80%; height: 1px; }
    .rc-price { font-size: 1.4rem; }
    .evo-title { font-size: 1.1rem; }
    .spread-bars { gap: var(--spacing-xs); }
  }
</style>
