  :global([data-theme="dark"]) .fx-chart-wrap { box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  :global([data-theme="dark"]) .fx-converter { box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  :global([data-theme="dark"] .fx-ppp-card:hover) { box-shadow: 0 4px 16px rgba(0,0,0,0.3); }
  :global([data-theme="dark"] .fxv-card:hover) { box-shadow: 0 4px 16px rgba(0,0,0,0.3); }

  /* Responsive */
  @media (max-width: 900px) {
    .fx-strip { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    /* Swipeable FX rate strip */
    .fx-strip {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
      border-radius: 12px;
      background: var(--color-border);
      border: 1px solid var(--color-border);
    }
    .fx-strip::-webkit-scrollbar { display: none; }
    .fx-rate {
      min-width: 75%;
      scroll-snap-align: start;
      flex-shrink: 0;
      padding: 14px 12px;
    }
    /* Fade gradient edges for scroll indicators */
    .fx-strip-wrap {
      position: relative;
    }
    .fx-strip-wrap::before,
    .fx-strip-wrap::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0; width: 24px;
      z-index: 2;
      pointer-events: none;
    }
    .fx-strip-wrap::before {
      inset-inline-start: 0;
      background: linear-gradient(to right, var(--color-bg), transparent);
      opacity: 0;
      transition: opacity 0.2s;
    }
    .fx-strip-wrap::after {
      inset-inline-end: 0;
      background: linear-gradient(to left, var(--color-bg), transparent);
    }
    .fx-strip-wrap--scrolled::before { opacity: 1; }
    .fx-strip-wrap--at-end::after { opacity: 0; }

    /* Tighter card spacing */
    .fx-rate { gap: 8px; }
    .fx-converter { padding: 14px 16px; }
    .fx-mc-card { padding: 10px 12px; }
    :global(.fx-ppp-card) { padding: 12px; }
    :global(.fxv-card) { padding: 12px; }
    .fx-perf-card { padding: 12px; }
    :global(.fx-sp-card) { padding: 10px; }
  }
  @media (max-width: 640px) {
    /* Full-width search inputs */
    .fx-conv-input-wrap { min-width: 100%; }
    .fx-conv-row { gap: 8px; }
    .fx-mc-input { width: 100%; }
  }
  @media (max-width: 520px) {
    .fx-title { font-size: 1.25rem; }
    .fx-price { font-size: 1.3rem; }
    .fx-chart-head { flex-direction: column; align-items: start; gap: 4px; }
    .fx-rate { min-width: 80%; padding: 10px; }
