  /* Performance Section */
  /* What $100 USD Gets You */
  .fx-ppp-section { margin-bottom: var(--spacing-xl); }
  :global(.fx-ppp-grid) { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--spacing-md); }
