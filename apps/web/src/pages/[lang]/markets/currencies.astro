  :global(.fxv-level) { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 8px; border-radius: 3px; background: rgba(128,128,128,0.1); color: var(--color-text-meta); }
  :global(.fxv-bar-wrap) { height: 8px; background: var(--color-border); border-radius: 4px; overflow: hidden; margin-bottom: 10px; }
  :global(.fxv-bar) { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
  :global(.fxv-stats) { display: flex; gap: var(--spacing-lg); flex-wrap: wrap; }
  :global(.fxv-stat) { display: flex; flex-direction: column; gap: 2px; }
  :global(.fxv-sk) { font-size: 0.62rem; color: var(--color-text-meta); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  :global(.fxv-sv) { font-size: 0.88rem; font-weight: 800; font-variant-numeric: tabular-nums; color: var(--color-text); }
  @media (max-width: 640px) { :global(.fx-vol-grid) { grid-template-columns: 1fr; } }

  /* Section Titles */
  .fx-section-title { font-size: 1rem; font-weight: 700; margin-bottom: var(--spacing-sm); }
  .fx-loading { text-align: center; color: var(--color-text-meta); padding: var(--spacing-xl) !important; }

  /* Section fade-in */
  @keyframes fx-fade-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .fx-spread-section, .fx-ppp-section, .fx-bars-section, .fx-vol-section, .fx-perf-section, .fx-gap-section {
    animation: fx-fade-in 0.3s ease-out;
  }

  /* Shimmer loading */
  @keyframes fx-shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
  .fx-shimmer { background: linear-gradient(90deg, var(--color-bg-secondary) 25%, var(--color-border) 50%, var(--color-bg-secondary) 75%); background-size: 200% 100%; animation: fx-shimmer 1.5s ease-in-out infinite; border-radius: 4px; color: transparent !important; }
  .fx-rate--loading .fx-price,
  .fx-rate--loading .fx-bs-val,
  .fx-rate--loading .fx-spread-val { background: linear-gradient(90deg, var(--color-bg-secondary) 25%, var(--color-border) 50%, var(--color-bg-secondary) 75%); background-size: 200% 100%; animation: fx-shimmer 1.5s ease-in-out infinite; border-radius: 4px; color: transparent !important; min-width: 80px; display: inline-block; }

  /* Rate History Table */
  .fx-history-section { margin-top: var(--spacing-lg); }
  .fx-history-wrap {
