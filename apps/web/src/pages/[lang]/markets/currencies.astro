  /* Disclaimer */
  .fx-disclaimer { font-size: 0.7rem; color: var(--color-text-meta); text-align: center; margin-top: var(--spacing-md); padding-top: var(--spacing-md); border-top: 1px solid var(--color-border); }

  /* Scroll to top */
  .scroll-top-btn {
    position: fixed; bottom: 24px; inset-inline-end: 24px; z-index: 90;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--color-bg-secondary); border: 1px solid var(--color-border);
    color: var(--color-text-meta); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, border-color 0.15s, color 0.15s;
    transform: translateY(8px);
  }
  .scroll-top-btn--visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .scroll-top-btn:hover { color: var(--color-gold); border-color: var(--color-gold); }
  .scroll-top-btn:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 2px; }

  /* Dark mode badge overrides */
  :global([data-theme="dark"]) .fx-badge { color: #75AADB; }
  :global([data-theme="dark"]) .fx-badge--blue { color: #F6B40E; }
  :global([data-theme="dark"]) .fx-badge--mep { color: #66BB6A; }
  :global([data-theme="dark"]) .fx-badge--ccl { color: #CE93D8; }
