---
import Base from "@/layouts/Base.astro";
import MarketNav from "@/components/MarketNav.astro";
import MarketHeader from "@/components/MarketHeader.astro";
import EducationPanel from "@/components/EducationPanel.astro";
import AssetStats from "@/components/AssetStats.astro";
import AssetSearch from "@/components/AssetSearch.astro";
import AssetTable from "@/components/AssetTable.astro";
import AssetCards from "@/components/AssetCards.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "cedears.seoTitle")}
  description={t(lang!, "cedears.seoDescription")}
  lang={lang}
  ogType="website"
  alternateUrls={Object.fromEntries(Object.keys(LANGUAGES).map(code => [code, `https://plata.today/${code}/markets/cedears`]))}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "markets.breadcrumb"), url: `/${lang}/markets` },
    { name: t(lang!, "cedears.breadcrumb"), url: `/${lang}/markets/cedears` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "cedears.title"),
    "description": t(lang!, "cedears.seoDescription"),
    "url": `https://plata.today/${lang}/markets/cedears`,
    "inLanguage": lang,
    "isPartOf": { "@type": "WebSite", "name": "Plata", "url": "https://plata.today" }
  }}
>
  <div class="asset-page" data-asset-page data-lang={lang} data-api="/api/cedears" data-asset-type="cedear"
    data-i18n-updated={t(lang!, "stock.updated")}
    data-i18n-retry={t(lang!, "common.retry" as any)}
    data-i18n-error={t(lang!, "cedears.loadError" as any)}
    data-i18n-no-results={t(lang!, "screener.noResults")}
    data-stock-url={`/${lang}/markets/stock`}
  >
    <MarketNav lang={lang!} active="cedears" />

    <MarketHeader
      title={t(lang!, "cedears.title")}
      subtitle={t(lang!, "cedears.subtitle" as any)}
      loadingText={t(lang!, "common.loading")}
    />

    <EducationPanel
      title={t(lang!, "cedears.infoTitle" as any)}
      text={t(lang!, "cedears.infoText" as any)}
      cards={[
        { label: t(lang!, "cedears.infoRatio" as any), value: t(lang!, "cedears.infoRatioTip" as any) },
        { label: t(lang!, "cedears.infoUnderlying" as any), value: t(lang!, "cedears.infoUnderlyingTip" as any) },
      ]}
    />

    <AssetStats stats={[
      { label: t(lang!, "screener.stocks"), dataKey: "count" },
      { label: t(lang!, "screener.gainers" as any), dataKey: "gainers", colorClass: "rc-up" },
      { label: t(lang!, "screener.losers" as any), dataKey: "losers", colorClass: "rc-down" },
      { label: t(lang!, "screener.totalVolume" as any), dataKey: "volume", defaultValue: "—" },
    ]} />

    <AssetSearch placeholder={t(lang!, "screener.search")} />

    <AssetTable
      ariaLabel={t(lang!, "cedears.title")}
      columns={[
        { label: t(lang!, "screener.col.symbol"), sortKey: "symbol", align: "name" },
        { label: t(lang!, "screener.col.price"), sortKey: "price" },
        { label: t(lang!, "screener.col.change"), sortKey: "change" },
        { label: t(lang!, "screener.col.volume"), sortKey: "volume", active: true, defaultArrow: "▼" },
        { label: t(lang!, "stock.high" as any), sortKey: "high", hideMobile: true },
        { label: t(lang!, "stock.low" as any), sortKey: "low", hideMobile: true },
      ]}
    />

    <AssetCards />

    <!-- No results -->
    <div class="asset-empty" data-asset-empty style="display:none;"></div>

    <p class="info-disclaimer">{t(lang!, "stock.disclaimer")}</p>
    <noscript><p class="info-disclaimer" style="text-align:center;padding:2rem;font-weight:600;">{t(lang!, "common.jsRequired" as any)}</p></noscript>
  </div>
</Base>

<script is:inline src="/js/market-helpers.js?v=2"></script>
<script is:inline src="/js/watchlist.js?v=1"></script>
<script is:inline src="/js/asset-listing.js?v=4"></script>

