---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "about.title")}
  description={t(lang!, "about.description")}
  lang={lang}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "about.title"), url: `/${lang}/about` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": t(lang!, "about.title"),
    "url": `https://plata.today/${lang}/about`,
    "description": t(lang!, "about.description"),
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <article class="about-hub">
    <header class="about-header">
      <h1>{t(lang!, "about.title")}</h1>
      <p class="about-tagline">{t(lang!, "about.hubTagline")}</p>
    </header>

    <div class="hub-grid">
      <a href={`/${lang}/mission`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9878;</span>
        <h2>{t(lang!, "about.missionCard")}</h2>
        <p>{t(lang!, "about.missionCardDesc")}</p>
      </a>

      <a href={`/${lang}/newsroom`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9881;</span>
        <h2>{t(lang!, "about.newsroomCard")}</h2>
        <p>{t(lang!, "about.newsroomCardDesc")}</p>
      </a>

      <a href={`/${lang}/founder`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9733;</span>
        <h2>{t(lang!, "about.founderCard")}</h2>
        <p>{t(lang!, "about.founderCardDesc")}</p>
      </a>

      <a href={`/${lang}/contact`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9993;</span>
        <h2>{t(lang!, "about.contactCard")}</h2>
        <p>{t(lang!, "about.contactCardDesc")}</p>
      </a>

      <a href={`/${lang}/standards`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9745;</span>
        <h2>{t(lang!, "about.standardsCard")}</h2>
        <p>{t(lang!, "about.standardsCardDesc")}</p>
      </a>

      <a href={`/${lang}/corrections`} class="hub-card">
        <span class="hub-icon" aria-hidden="true">&#9998;</span>
        <h2>{t(lang!, "about.correctionsCard")}</h2>
        <p>{t(lang!, "about.correctionsCardDesc")}</p>
      </a>
    </div>
  </article>
</Base>

<style>
  .about-hub {
    max-width: var(--content-width);
    margin: 0 auto;
    background: var(--color-bg);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-radius: 2px;
  }

  .about-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .about-header h1 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
  }

  .about-tagline {
    font-size: 1.15rem;
    color: var(--color-text-meta);
    margin-top: var(--spacing-sm);
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .hub-card {
    display: block;
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-gold);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .hub-card:hover {
    border-color: var(--color-celeste);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .hub-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .hub-card h2 {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: var(--spacing-xs);
  }

  .hub-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-meta);
    margin: 0;
  }

  @media (max-width: 900px) {
    .hub-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
