---
import Base from "@/layouts/Base.astro";
import { LANGUAGES } from "@plata-today/shared";
import { t } from "@/i18n";

export function getStaticPaths() {
  return Object.keys(LANGUAGES).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Base
  title={t(lang!, "corrections.pageTitle")}
  description={t(lang!, "corrections.description")}
  lang={lang}
  breadcrumbs={[
    { name: t(lang!, "common.breadcrumbHome"), url: `/${lang}/` },
    { name: t(lang!, "corrections.title"), url: `/${lang}/corrections` },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": t(lang!, "corrections.title"),
    "url": `https://plata.today/${lang}/corrections`,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Plata",
      "url": "https://plata.today"
    }
  }}
>
  <article class="legal">
    <header class="legal-header">
      <h1>{t(lang!, "corrections.title")}</h1>
      <p class="legal-updated">{t(lang!, "corrections.updated")}</p>
    </header>

    <div class="legal-body">
      <p class="lead">{t(lang!, "corrections.lead")}</p>

      <h2>{t(lang!, "corrections.policyTitle")}</h2>
      <p>{t(lang!, "corrections.policyText")}</p>

      <h2>{t(lang!, "corrections.howTitle")}</h2>
      <ul class="corrections-list">
        <li>{t(lang!, "corrections.howMinor")}</li>
        <li>{t(lang!, "corrections.howFactual")}</li>
        <li>{t(lang!, "corrections.howMajor")}</li>
      </ul>

      <h2>{t(lang!, "corrections.reportTitle")}</h2>
      <p>{t(lang!, "corrections.reportText")}</p>

      <h2>{t(lang!, "corrections.logTitle")}</h2>
      <p class="log-empty">{t(lang!, "corrections.logEmpty")}</p>
    </div>
  </article>
</Base>

<style>
  .legal {
    max-width: var(--content-width);
    margin: 0 auto;
    background: var(--color-bg);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-radius: 2px;
  }

  .legal-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .legal-header h1 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
  }

  .legal-updated {
    font-size: 0.85rem;
    color: var(--color-text-meta);
    margin-top: var(--spacing-sm);
  }

  .legal-body h2 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    border-top: 3px solid var(--color-celeste);
    padding-top: var(--spacing-md);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .legal-body p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .corrections-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .corrections-list li {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    padding-left: var(--spacing-md);
    border-left: 3px solid var(--color-gold);
  }

  .log-empty {
    font-style: italic;
    color: var(--color-text-meta);
  }
</style>
